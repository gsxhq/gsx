A hole inside a multi-line js"…" attribute value survives re-indentation (the
@{expr} form is preserved tight; no sentinel leaks).

-- input.gsx --
package p

component C(id string) {
	<form x-data=js"{
url: '@{id}',
k: 1,
}"/>
}
-- fmt.golden --
package p

component C(id string) {
	<form
		x-data=js"{
		url: '@{id}',
		k: 1,
		}"
	/>
}
