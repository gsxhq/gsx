An if body indents one level under its { and dedents the closing }.

-- input.gsx --
package p

import "github.com/gsxhq/gsx"

component C(x string) {
	{{
		a := gsx.Attrs{{Key: "@x", Value: js`
if (x) {
foo();
bar();
}
`}}
	}}
	<div {a...}>y</div>
}
-- fmt.golden --
package p

import "github.com/gsxhq/gsx"

component C(x string) {
	{{
		a := gsx.Attrs{
			{
				Key:   "@x",
				Value: js`
					if (x) {
						foo();
						bar();
					}
				`,
			},
		}
	}}
	<div { a... }>y</div>
}
