# An imported component publishes the same authored ordinary and reserved roles
# as a local component.
-- go.mod --
module example.com/app

go 1.26.1
-- ui/card.gsx --
package ui

import "github.com/gsxhq/gsx"

component Card(title string, children gsx.Node, attrs gsx.Attrs) {
	<div class="card" { attrs... }><h2>{title}</h2>{children}</div>
}
-- pages/home.gsx --
package pages

import "example.com/app/ui"

component Home() {
	<ui.Card title="T" class="x">body</ui.Card>
}
-- invoke --
pages.Home()
