# A skipped generic tag (inference-unavailable warning) must still CONSUME its
# attribute values with compiling Go: a fallthrough value whose final pipeline
# stage returns (T, error), and an f-literal with a (T, error) hole, both land
# inside the never-executed sink. The sibling tag renders unaffected.
-- go.mod --
module example.com/app

go 1.26.1
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

func Check(s string) (string, error) {
	return s + "!", nil
}
-- components/widget.gsx --
package components

type secret string

component Widget[T secret | string](label T) {
	<span>{string(label)}</span>
}

component Button(label string) {
	<button>{label}</button>
}
-- pages/helpers.go --
package pages

func stamp(v string) (string, error) {
	return v, nil
}
-- pages/home.gsx --
package pages

import "example.com/app/components"

component Home(tag string) {
	<components.Widget label=f`v-@{stamp(tag)}` data-x={tag |> check} />
	<components.Button label="ok" />
}
-- invoke --
pages.Home("t")
-- diagnostics.golden --
6:46: components.Widget has no attrs param; unexpected attribute "data-x"
-- generated.x.go.golden --
-- render.golden --
