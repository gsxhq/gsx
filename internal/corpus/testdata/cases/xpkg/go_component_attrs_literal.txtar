# A component from a plain Go package exposes the exact static parameter `p`.
# The caller constructs the author-owned WidgetProps value explicitly; gsx does
# not infer a fallthrough role from its Attrs field.
-- go.mod --
module example.com/app

go 1.26.1
-- uigo/widget.go --
package uigo

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

type WidgetProps struct {
	Attrs gsx.Attrs
}

func Widget(p WidgetProps) gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		gw := gsx.W(w)
		gw.S("<span")
		gw.Spread(ctx, p.Attrs, nil, nil, nil, nil, nil)
		gw.S("></span>")
		return gw.Err()
	})
}
-- pages/home.gsx --
package pages

import (
	"example.com/app/uigo"
	"github.com/gsxhq/gsx"
)

component Home() {
	<uigo.Widget p={uigo.WidgetProps{Attrs: gsx.Attrs{{Key: "data-x", Value: "1"}}}}/>
}
-- invoke --
pages.Home()
-- diagnostics.golden --
-- render.golden --
<span data-x="1"></span>
