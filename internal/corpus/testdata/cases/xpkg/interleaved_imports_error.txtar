# Context: an `import` after a declaration is invalid Go. The .gsx file's top-level
# Go regions are parsed once, up front, by checkReservedDecls (the pass that
# reserves the `_gsx` prefix): a region that will not parse is a region whose
# declarations cannot be checked, so it is reported right there — positioned at the
# stray import in the .gsx (5:1), not at a line/column relative to the pass-through
# block, and the file is skipped before the skeleton is built.
-- input.gsx --
package views

func helper() string { return "x" }

import "fmt"

var _ = fmt.Sprintf

component Bad() {
	<p>{helper()}</p>
}
-- diagnostics.golden --
5:1: imports must appear before other declarations
