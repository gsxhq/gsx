# Imported gsx components expose their authored parameter names and reserved
# roles to callers, so bare attrs contributors and attrs literals behave like
# same-package calls.
-- go.mod --
module example.com/app

go 1.26.1
-- ui/card.gsx --
package ui


import "github.com/gsxhq/gsx"
component DataGrid(children gsx.Node, attrs gsx.Attrs) {
	<div class="grid" { attrs... }>{children}</div>
}

component Panel(children gsx.Node, attrs gsx.Attrs) {
	<section { attrs... }>{children}</section>
}
-- pages/home.gsx --
package pages

import "example.com/app/ui"

component Home() {
	<ui.DataGrid class="md:grid-cols-2" data-role="main">
		<span>grid</span>
	</ui.DataGrid>
	<ui.Panel attrs={{ "data-a": "1", "data-b": "2" }}>panel</ui.Panel>
}
-- invoke --
pages.Home()
-- diagnostics.golden --
-- render.golden --
<div class="grid md:grid-cols-2" data-role="main"><span>grid</span></div><section data-a="1" data-b="2">panel</section>
