# Imported gsx components expose their generated Props fields to callers, so
# bare fallthrough attrs and ordered-attrs literals behave like same-package calls.
-- go.mod --
module example.com/app

go 1.26.1
-- ui/card.gsx --
package ui

component DataGrid() {
	<div class="grid" { attrs... }>{children}</div>
}

component Panel() {
	<section { attrs... }>{children}</section>
}
-- pages/home.gsx --
package pages

import "example.com/app/ui"

component Home() {
	<ui.DataGrid class="md:grid-cols-2" data-role="main">
		<span>grid</span>
	</ui.DataGrid>
	<ui.Panel attrs={{ "data-a": "1", "data-b": "2" }}>panel</ui.Panel>
}
-- invoke --
pages.Home()
-- diagnostics.golden --
-- render.golden --
<div class="grid md:grid-cols-2" data-role="main"><span>grid</span></div><section data-a="1" data-b="2">panel</section>
