# A plain-Go component whose exact signature has only `p WidgetProps` declares
# no reserved `attrs` role. An authored attrs contributor is therefore rejected
# at the call site; gsx never guesses from struct fields or emits a wrapper.
-- go.mod --
module example.com/app

go 1.26.1
-- uigo/widget.go --
package uigo

import "github.com/gsxhq/gsx"

type WidgetProps struct {
	Label string
}

func Widget(p WidgetProps) gsx.Node {
	return gsx.Raw(p.Label)
}
-- pages/home.gsx --
package pages

import "example.com/app/uigo"

component Home() {
	<uigo.Widget attrs={{ "data-x": "1" }}/>
}
-- invoke --
pages.Home()
-- diagnostics.golden --
6:15: uigo.Widget has no attrs param; unexpected attrs contributor
-- render.golden --
