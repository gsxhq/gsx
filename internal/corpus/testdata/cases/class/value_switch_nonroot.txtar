# emitClassAttr CF branch: the root element has no own class so the value-form
# switch sits on a NON-ROOT child element, exercising emitClassAttr (not
# emitRootComposedClass).
-- input.gsx --
package views

component Widget(variant int) {
	<div><span class={ "x", switch variant {
	case 1:
		{ "a" }
	default:
		{ "b" }
	} }>y</span></div>
}
-- invoke --
Widget(WidgetProps{Variant: 1})
