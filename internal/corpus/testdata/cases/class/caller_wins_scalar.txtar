-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Link(children gsx.Node, attrs gsx.Attrs) {
	<a href="/default" onclick="track()" { attrs... }>{children}</a>
}
-- invoke --
Link(nil, gsx.Attrs{{Key: "href", Value: "/custom"}})
-- diagnostics.golden --
-- render.golden --
<a onclick="track()" href="/custom"></a>
