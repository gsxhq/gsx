# Regression for #69: two sibling generated-component tags, each carrying a
# value-form CF class part that falls through into the child's forwarding bag.
# Each such class hoists a `_gsxvN` var+if into the SHARED skeleton function; a
# per-tag counter reset made both emit `_gsxv0` → `_gsxv0 redeclared in this
# block` (a spurious generate-time error on valid input). A per-skeleton-function
# counter keeps the temps globally unique.
-- input.gsx --
package views

component Chip() {
	<span { attrs... }>x</span>
}

component Page(on bool) {
	<div>
		<Chip class={ if on { "a" } else { "b" } }/>
		<Chip class={ if on { "a" } else { "b" } }/>
	</div>
}
-- invoke --
Page(PageProps{On: true})
-- diagnostics.golden --
-- render.golden --
<div><span class="a">x</span><span class="a">x</span></div>
