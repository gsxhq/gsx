# value-form if without else — false branch: the CF variable stays "" (zero value),
# contributing nothing to the class list. Proves if-without-else == additive guard:
# "extra": on equivalence — false means class="base" only.
-- input.gsx --
package views

component Toggle(on bool) {
	<i class={ "base", if on { "extra" } }>y</i>
}
-- invoke --
Toggle(ToggleProps{On: false})
-- render.golden --
<i class="base">y</i>
