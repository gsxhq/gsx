# value-form if arm that contains a pipeline: { theme |> upper } inside an arm
# exercises lowerClassPartSeed's pipeline lowering (lowerPipe) via armExpr in
# hoistValueCF. Confirms arm stages are handled identically to plain-part stages.
-- input.gsx --
package views

component C(theme string, on bool) {
	<div class={ "base", if on { theme |> upper } else { "off" } }>x</div>
}
-- invoke --
C(CProps{Theme: "dark", On: true})
-- render.golden --
<div class="base DARK">x</div>
