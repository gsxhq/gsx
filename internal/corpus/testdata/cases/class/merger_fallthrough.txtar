-- gsx.toml --
class_merger = "corpustest/cases/class_merger_fallthrough/mrg.Keep"
-- mrg/mrg.go --
package mrg

// Keep is a deterministic, NON-default merger: it joins raw class strings with
// "|" and keeps duplicates, so the golden visibly differs from DefaultClassMerge.
func Keep(tokens []string) string {
	out := ""
	for i, t := range tokens {
		if i > 0 {
			out += "|"
		}
		out += t
	}
	return out
}
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component C(children gsx.Node, attrs gsx.Attrs) { <div class={ "btn" } { attrs... }>{ children }</div> }
-- invoke --
C(gsx.Raw("x"), gsx.Attrs{{Key: "class", Value: "btn extra"}})
