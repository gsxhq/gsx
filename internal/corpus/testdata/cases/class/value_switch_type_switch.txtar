# Regression: a non-binding type switch as a value-form tag. The tag
# `v.(type)` and type-name case lists are only legal inside a switch
# statement — `_ = (v.(type))` / `_ = (string)` are not expressions — so the
# skeleton must reference them in statement position.
-- input.gsx --
package views

component C(v any) {
	<span class={ switch v.(type) {
	case string: "str"
	default: "other"
	} }>x</span>
}
-- invoke --
C("hi")
-- diagnostics.golden --
