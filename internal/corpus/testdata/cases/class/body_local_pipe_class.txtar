# Regression for #70 (fixed by PR #76): a body-local declared in a `{{ }}` block
# and referenced in a piped `class={ s |> upper }` on a normal element must
# type-check in scope AND lower its pipeline. This was the pipe-after-local
# skeleton bug (p5b); it now generates and renders cleanly.
-- input.gsx --
package views

component C() {
	{{ s := "hi" }}
	<b class={ s |> upper }>x</b>
}
-- invoke --
C()
-- diagnostics.golden --
-- render.golden --
<b class="HI">x</b>
