# Regression for #70 (fixed by PR #76): a body-local declared in a `{{ }}` block
# and referenced in a plain `class={n}` on a normal element must type-check in
# scope. This was the `undefined: n` skeleton bug (p5e); it now generates and
# renders cleanly.
-- input.gsx --
package views

component C() {
	{{ n := "hi" }}
	<b class={n}>x</b>
}
-- invoke --
C()
-- diagnostics.golden --
-- render.golden --
<b class="hi">x</b>
