-- gsx.toml --
class_merger = "corpustest/cases/class_merger_composable/mrg.Keep"
-- mrg/mrg.go --
package mrg

// Keep is a deterministic, NON-default merger: it joins raw class strings with
// "|" and keeps duplicates, so the golden visibly differs from DefaultClassMerge.
func Keep(tokens []string) string {
	out := ""
	for i, t := range tokens {
		if i > 0 {
			out += "|"
		}
		out += t
	}
	return out
}
-- input.gsx --
package views

component C(on bool) { <div class={ "btn", "btn-on": on }>y</div> }
-- invoke --
C(true)
