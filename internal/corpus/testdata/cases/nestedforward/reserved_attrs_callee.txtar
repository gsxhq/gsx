# The wrapper's attrs role feeds a declared value parameter and also contributes
# an unmatched attribute to Card's explicit attrs role. Both routes are bound
# independently and Card forwards only its attrs value to the leaf element.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func strAttr(a gsx.Attrs, key string) string {
	v, _ := a.Get(key)
	s, _ := v.(string)
	return s
}

component Card(title string, attrs gsx.Attrs) {
	<div { attrs... }>{title}</div>
}

component Wrapper(attrs gsx.Attrs) {
	<Card title={ strAttr(attrs, "t") } data-x="1"/>
}

component Page() {
	<Wrapper t="hello"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-x="1">hello</div>
