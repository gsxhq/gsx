# Callee-kind: a receiver-qualified dotted tag (`<p.Item { attrs... }/>`)
# whose wrapper is itself a method component on the SAME receiver type. Two
# forwarding hops (Home -> Row -> Item), all methods on Site, prove the
# uniform binding and bag assembly work identically for method components.
-- input.gsx --
package views

type Site struct{}

component (p Site) Item() {
	<li { attrs... }>x</li>
}

component (p Site) Row() {
	<p.Item { attrs... }/>
}

component (p Site) Home() {
	<p.Row data-x="1"/>
}
-- invoke --
(Site{}).Home()
