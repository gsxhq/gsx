# A derived-bag spread `{ attrs.Without("id")... }` forwards into a nested
# component tag: per the D1 forwarding-position rule, this is STILL the
# forwarding spread of Wrapper's own call (any attrs-referencing spread is),
# so id is dropped before Panel ever sees it and data-keep survives.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Panel(attrs gsx.Attrs) {
	<div { attrs... }>p</div>
}

component Wrapper(attrs gsx.Attrs) {
	<Panel { attrs.Without("id")... }/>
}

component Page() {
	<Wrapper id="ignore-me" data-keep="yes"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-keep="yes">p</div>
