# Uniform-binding position: `attrs` referenced from inside an ordered-attrs
# `attrs={{ "k": v }}` literal pair value on a nested component tag. The pair
# Value field is `any`, so a plain string (from strAttr) is directly
# assignable — no assertion needed at the call site.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func strAttr(a gsx.Attrs, key string) string {
	v, _ := a.Get(key)
	s, _ := v.(string)
	return s
}

component Panel(attrs gsx.Attrs) {
	<div { attrs... }>p</div>
}

component Wrapper(attrs gsx.Attrs) {
	<Panel attrs={{ "data-n": strAttr(attrs, "n") }}/>
}

component Page() {
	<Wrapper n="7"/>
}
-- invoke --
Page()
