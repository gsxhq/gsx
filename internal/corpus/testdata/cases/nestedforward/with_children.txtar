# A forwarding wrapper passes BOTH `{ attrs... }` and children through to a
# nested component tag that places {children} — the same-package mirror of
# xpkg/imported_attrs_literal_merge.txtar's cross-package shape, with an
# added forwarding layer (Wrapper) so attrs genuinely nest.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Panel(children gsx.Node, attrs gsx.Attrs) {
	<section { attrs... }>{children}</section>
}

component Wrapper(attrs gsx.Attrs) {
	<Panel { attrs... }>text child</Panel>
}

component Page() {
	<Wrapper data-x="1"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<section data-x="1">text child</section>
