# Uniform-binding position: `attrs` referenced ONLY from a pipeline STAGE ARG
# (`|> default(strAttr(attrs, "fallback"))`) on a nested component tag —
# pins the refsStages branch of attrsRefAttrs/usesAttrs, distinct from a
# reference in the stage's seed Expr. `default` is std's real filter name
# (std.Default, lowerFirst'd) — resolved without an explicit import, same as
# any other std filter (see textattr/whole_pipe_url_safe.txtar).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func strAttr(a gsx.Attrs, key string) string {
	v, _ := a.Get(key)
	s, _ := v.(string)
	return s
}

component Icon(name string) {
	<span data-name={name}>i</span>
}

component Wrapper(base string) {
	<Icon name={ base |> default(strAttr(attrs, "fallback")) }/>
}

component Page() {
	<Wrapper base="" fallback="gear"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<span data-name="gear">i</span>
