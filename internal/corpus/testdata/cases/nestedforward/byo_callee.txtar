# Callee-kind: forwarding into a component backed by a hand-written (byo)
# Props struct with its own Attrs field (the boxProps shape from
# attrsonly/merge_order.txtar), reached through the attrs-only Box factory —
# a bare spread of the reserved `attrs` identifier onto a byo component TAG
# directly is always the whole-struct-splat form (never an Attrs merge, see
# childPropsLiteral's isByoChild branch), so forwarding routes through Box
# exactly as merge_order.txtar's own Page does, with an added Wrapper hop.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type boxProps struct {
	Attrs gsx.Attrs
}

component renderBox(p boxProps) {
	<div { p.Attrs... }>box</div>
}

func Box(attrs gsx.Attrs) gsx.Node {
	return renderBox(boxProps{Attrs: attrs})
}

component Wrapper() {
	<Box class="w-5" { attrs... }/>
}

component Page() {
	<Wrapper class="text-red" data-x="1"/>
}
-- invoke --
Page()
-- diagnostics.golden --
