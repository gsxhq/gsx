# Callee-kind: genuine byo-callee forwarding coverage. The wrapper's implicit
# bag feeds a byo DECLARED prop by value (`title={ strAttr(attrs, "t") }` —
# uniform binding in an ExprAttr on a byo tag; strAttr unwraps Attrs.Get's
# (any, bool)), and the unmatched named attr data-x falls through into the
# byo struct's `Attrs gsx.Attrs` field, which Card's body spreads onto its
# element. Spread-forwarding (`{ attrs... }`) onto a byo tag is impossible
# by design — a spread there is always the whole-Props splat — see
# byo_with_attrs_spread_rejected.txtar.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func strAttr(a gsx.Attrs, key string) string {
	v, _ := a.Get(key)
	s, _ := v.(string)
	return s
}

type CardProps struct {
	Title string
	Attrs gsx.Attrs
}

component Card(p CardProps) {
	<div { p.Attrs... }>{p.Title}</div>
}

component Wrapper() {
	<Card title={ strAttr(attrs, "t") } data-x="1"/>
}

component Page() {
	<Wrapper t="hello"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-x="1">hello</div>
