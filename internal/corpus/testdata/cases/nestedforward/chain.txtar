# A three-level forward chain, Page -> A -> B -> C (C's own element is the
# leaf): each hop's OWN class contribution merges through the leaf's class
# aggregation in the order the bag reaches it (C's own root class first,
# then B's addition, then A's addition, then Page's, since each is
# concatenated onto the END of the bag as it descends). The leaf's own scalar
# default (data-scalar="c-default") is overridden by the SAME key set by the
# outermost caller (Page), since forwarded bag entries are positioned after
# the leaf's own literal attrs.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component C(attrs gsx.Attrs) {
	<div class="c-root" data-scalar="c-default" { attrs... }>leaf</div>
}

component B(attrs gsx.Attrs) {
	<C class="b-add" { attrs... }/>
}

component A(attrs gsx.Attrs) {
	<B class="a-add" { attrs... }/>
}

component Page() {
	<A class="page-cls" data-scalar="page-value"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div class="c-root b-add a-add page-cls" data-scalar="page-value">leaf</div>
