# Reserved-by-usage: a package-level `var attrs` in a sibling hand-written .go
# file does NOT collide with the implicit fallthrough bag. Panel's body
# references `attrs` (via the spread), so gsx binds the implicit bag locally
# as `attrs` inside Panel's generated function — an ordinary Go local
# shadowing the package-scope var of the same name. The caller's attr wins;
# data-pkg (the package var's own payload) never renders.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Panel(attrs gsx.Attrs) {
	<div { attrs... }>p</div>
}

component Page() {
	<Panel data-caller="yes"/>
}
-- helpers.go --
package views

import "github.com/gsxhq/gsx"

var attrs = gsx.Attrs{{Key: "data-pkg", Value: "1"}}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-caller="yes">p</div>
