# Forwarding the implicit attrs bag onto a GENERIC callee whose type args
# are INFERRED (not written): <List items={...} { attrs... }/>. The spread is
# the wrapper's ONLY reference to `attrs`, so the caller-side inference probe
# (which infers T from `items`) must still consume the synthesized Attrs bag
# expression — otherwise the skeleton trips `declared and not used: attrs`.
# The render proves the forwarded attr lands on List's own leaf <ul>.
-- input.gsx --
package views

component List[T any](items []T) {
	<ul class="list" { attrs... }>
		{ for _, it := range items {
			<li>{ it |> printf("%v") }</li>
		} }
	</ul>
}

component Wrap() {
	<List items={[]string{"a", "b"}} { attrs... }/>
}

component Page() {
	<Wrap data-flag="1" class="hot"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<ul class="list hot" data-flag="1"><li>a</li><li>b</li></ul>
