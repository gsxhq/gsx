# Forwarding an explicit attrs parameter onto a generic callee whose type args
# are inferred from items. The render proves the contributor lands on List's
# own leaf <ul> without interfering with type inference.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component List[T any](items []T, attrs gsx.Attrs) {
	<ul class="list" { attrs... }>
		{ for _, it := range items {
			<li>{ it |> printf("%v") }</li>
		} }
	</ul>
}

component Wrap(attrs gsx.Attrs) {
	<List items={[]string{"a", "b"}} { attrs... }/>
}

component Page() {
	<Wrap data-flag="1" class="hot"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<ul class="list hot" data-flag="1"><li>a</li><li>b</li></ul>
