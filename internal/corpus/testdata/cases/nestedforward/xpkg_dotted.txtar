# Cross-package nested forwarding: a `pages` wrapper forwards its implicit
# attrs bag into a dotted `<ui.Panel { attrs... }/>` tag. The uniform-binding
# scan and the bag assembly work identically for a dotted (qualified) tag as
# for a same-package one.
-- go.mod --
module example.com/app

go 1.26.1
-- ui/panel.gsx --
package ui


import "github.com/gsxhq/gsx"
component Panel(children gsx.Node, attrs gsx.Attrs) {
	<section { attrs... }>{children}</section>
}
-- pages/home.gsx --
package pages


import "github.com/gsxhq/gsx"
import "example.com/app/ui"

component Wrapper(attrs gsx.Attrs) {
	<ui.Panel { attrs... }>p</ui.Panel>
}

component Home() {
	<Wrapper data-x="1"/>
}
-- invoke --
pages.Home()
-- diagnostics.golden --
-- render.golden --
<section data-x="1">p</section>
