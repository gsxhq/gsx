# An attrs contributor forwarded from a wrapper is rejected when the callee
# does not declare the reserved attrs parameter.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Plain(title string) {
	<h1>{title}</h1>
}

component Wrapper(attrs gsx.Attrs) {
	<Plain { attrs... }/>
}

component Page() {
	<Wrapper data-x="1"/>
}
-- invoke --
Page()
-- diagnostics.golden --
10:9: Plain has no attrs param; unexpected attrs-bag contributor
-- render.golden --
