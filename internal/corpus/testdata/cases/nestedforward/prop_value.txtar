# Uniform-binding position: `attrs` referenced from the value-form Expr of a
# DECLARED prop (ExprAttr) on a nested component tag — not a spread, not a
# cond, not a class part. strAttr extracts a string out of the two-value
# Attrs.Get so the prop stays a plain string param.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func strAttr(a gsx.Attrs, key string) string {
	v, _ := a.Get(key)
	s, _ := v.(string)
	return s
}

component Icon(name string) {
	<span data-name={name}>i</span>
}

component Wrapper(attrs gsx.Attrs) {
	<Icon name={ strAttr(attrs, "n") }/>
}

component Page() {
	<Wrapper n="search"/>
}
-- invoke --
Page()
