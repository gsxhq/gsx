# Forwarding contributors onto a generic callee that does not declare attrs.
# Type inference still resolves T from items before the precise missing-attrs
# diagnostics are reported for both contributors.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Bare[T any](items []T) {
	<ul>
		{ for _, it := range items {
			<li>{ it |> printf("%v") }</li>
		} }
	</ul>
}

component Wrap(attrs gsx.Attrs) {
	<Bare items={[]string{"a"}} data-x="1" { attrs... }/>
}

component Page() {
	<Wrap/>
}
-- invoke --
Page()
-- diagnostics.golden --
14:30: Bare has no attrs param; unexpected attribute "data-x"
14:41: Bare has no attrs param; unexpected attrs-bag contributor
-- render.golden --
