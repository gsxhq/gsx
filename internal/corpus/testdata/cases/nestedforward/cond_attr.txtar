# Uniform-binding position: `attrs` referenced from a CondAttr's Cond on a
# nested component tag (`{ if attrs.Has("hot") { data-hot="1" } }`), distinct
# from the bare `{ attrs... }` spread spread_basic.txtar already pins.
-- input.gsx --
package views

component Icon(name string) {
	<span data-name={name} { attrs... }>i</span>
}

component Wrapper() {
	<Icon name="x" { if attrs.Has("hot") { data-hot="1" } }/>
}

component Page() {
	<Wrapper hot="1"/>
}
-- invoke --
Page()
