# Craft-check: OTHER interps BEFORE and AFTER an element's conditional class
# part in the SAME component, pinning the emitProbes/collectExprs k-th-probe
# alignment across the #88 widening. emitProbes and collectExprs walk in
# lockstep — a byte-identical condition change is required in BOTH (the
# element-branch class-part loop in emitProbes and its counterpart in
# collectExprs) or every _gsxuse probe emitted AFTER the conditional class
# part desyncs by one, mis-typing `after` (and, transitively, any later
# probe in the file). before/after are plain string interps with no renderer
# of their own, so a desync here would either fail the skeleton's own
# go/types check or silently render the wrong text — either way a loud,
# observable failure, not a silent no-op.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_elem_class_cond_alignment/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_elem_class_cond_alignment/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Page(before string, val pg.Text, on bool, after string) {
	<span>{before}</span>
	<div class={ val: on }>x</div>
	<span>{after}</span>
}
-- invoke --
Page(PageProps{Before: "b", Val: mkText("btn", true), On: true, After: "a"})
-- diagnostics.golden --
-- generated.x.go.golden --
