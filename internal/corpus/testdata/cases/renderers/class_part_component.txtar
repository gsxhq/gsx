# A composable class={ mkText(...) } attribute ON A COMPONENT
# (<Card class={ mkText(name, true) }/>), whose value has the REGISTERED type
# pg.Text: this lowers through classEntryExpr (the component-prop sibling of
# composedParts, used to build the child's Attrs-bag "class" entry as
# rtPkg.ClassJoin(rtPkg.Class(...))) — a SEPARATE implementation from the
# element-level path class_part.txtar pins, found via the same "every
# .Class(...)/.ClassIf(...) argument needs a literal string" enumeration.
# Card has no class prop of its own, so the rendered string reaches the leaf
# via the fallthrough Attrs bag and Attrs.Class() merge.
#
# A CALL expression, not a bare identifier: this case predates #85, which
# closed the gap this comment used to document (classEntryExpr's probe/
# skeleton pass previously only stubbed CALL expressions to `""`, so a bare
# identifier/selector of a non-string type failed the skeleton's own go/types
# check before harvest ever ran, independent of renderers). The probe now
# stubs EVERY class-part value expr regardless of shape; the bare-identifier
# and bare-selector cases are pinned by class_bare_ident.txtar, the
# conditional-part case by class_bare_cond.txtar, and the value-form CF-arm
# case by class_bare_cfarm.txtar.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_class_part_component/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_class_part_component/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title string) { <div { attrs... }>{title}</div> }

component Page(name string) {
	<Card title="hi" class={ mkText(name, true) }/>
}
-- invoke --
Page(PageProps{Name: "btn primary"})
