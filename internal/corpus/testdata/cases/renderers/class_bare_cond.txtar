# A conditional class part (class={ val: cond }) whose unconditional VALUE is
# a BARE IDENTIFIER of the REGISTERED type pg.Text — the ClassIf sibling of
# class_bare_ident.txtar's plain-part case. Before #85 the probe stubbed
# nothing in this arm (probeWrap left expr untouched), so a bare non-string
# value failed the skeleton's own go/types check the same way. Probe mode now
# stubs the value expr with "" here too; the cond guard is untouched, and the
# renderer applies at emit exactly as classEntryExpr's unconditional arm does.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_class_bare_cond/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
import "corpustest/cases/renderers_class_bare_cond/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title string, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(val pg.Text, on bool) {
	<Card title="hi" class={ val: on }/>
}
-- invoke --
Page(mkText("btn", true), true)
