# The style={ val: on } sibling of elem_class_cond.txtar on a plain element:
# the renderer applies through StyleValue(...) exactly as the unconditional
# style_part.txtar case does, then ClassIf lowers it into the conditional
# style contribution. Before #88 this failed the same way as the class case
# (resolved[p] stayed nil for a conditional plain part in the element
# branch), just against StyleValue's argument instead of ClassIf's.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgColor"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_elem_style_cond/pg"

func PgColor(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_elem_style_cond/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Page(val pg.Text, on bool) {
	<div style={ val: on }>x</div>
}
-- invoke --
Page(PageProps{Val: mkText("color:red", true), On: true})
-- diagnostics.golden --
-- generated.x.go.golden --
