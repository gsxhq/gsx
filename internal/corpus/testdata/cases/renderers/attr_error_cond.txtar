# A renderer func(pg.Text) (string, error) as an ExprAttr value inside a
# component conditional-attr branch (`{ if hot { data-x={ val } } }` on a
# CHILD component invocation) — a DISTINCT boundary from the plain-element
# attr path (attr_error.txtar): the value is built into an
# `_gsxrt.Attrs{...}` bag literal inside a `func() (_gsxrt.Attrs, error)`
# thunk (condAttrsExpr/condBranchAttrs), so the renderer's error hoists
# through the thunk's OWN two-value return shape `return nil, _gsxerr`, never
# the enclosing render closure's single-value `return _gsxerr` — mirrors the
# existing pipeerr/cond_attr_branch_attr_tuple.txtar hoist shape for a plain
# (T, error) call, just with the value routed through the renderer registry
# first. Invoked with an invalid value so the error path (not just the
# success path) is pinned.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_attr_error_cond/pg"
)

func PgText(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import (
	"github.com/gsxhq/gsx"

	"corpustest/cases/renderers_attr_error_cond/pg"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title gsx.Node, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(hot bool, val pg.Text) {
	<Card title="Hi" { if hot { data-x={ val } } } />
}
-- invoke --
Page(true, mkText("hi", false))
-- diagnostics.golden --
