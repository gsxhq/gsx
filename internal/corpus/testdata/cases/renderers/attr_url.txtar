# SECURITY: renderer FIRST, whole-value URL sanitization AFTER — the same
# order as a piped URL attr (whole_pipe_url_safe.txtar). danger's renderer
# returns "javascript:alert(1)"; _gsxgw.URL() runs on THAT output and
# neutralizes it to "about:invalid#gsx" (same sink behavior as a raw
# javascript: string attr, e.g. security/url_blocked.txtar). safe's renderer
# returns an ordinary https URL, which passes through unsanitized-in-form (no
# scheme rewrite) to prove the renderer path isn't itself broken for a benign
# value.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_attr_url/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_attr_url/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Link(danger pg.Text, safe pg.Text) {
	<div>
		<a href={ danger }>bad</a>
		<a href={ safe }>good</a>
	</div>
}
-- invoke --
Link(LinkProps{Danger: mkText("javascript:alert(1)", true), Safe: mkText("https://example.com", true)})
-- diagnostics.golden --
-- generated.x.go.golden --
