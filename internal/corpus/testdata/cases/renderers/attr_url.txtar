		_gsxgw.URL(string(_gsxf6.PgText((danger))))
		_gsxgw.S("\">bad</a>")
//line input.gsx:10:3
		_gsxgw.S("<a href=\"")
		_gsxgw.URL(string(_gsxf6.PgText((safe))))
