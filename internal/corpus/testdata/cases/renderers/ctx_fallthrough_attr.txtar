# An UNMATCHED ExprAttr on a child-component invocation whose value's
# registered renderer wants ctx — the ctx-taking sibling of
# fallthrough_attr.txtar: `data-x={ val }` lands in the fallthrough Attrs-bag
# literal (childPropsLiteral's bag splice), a STATIC boundary, so ctx
# injection + the (R, error) hoist must both apply BEFORE the value enters
# the bag as `any`. Pins `_gsxvN, _gsxerr := rend.PgText(ctx, (val)); if
# _gsxerr != nil { return _gsxerr }` — single-value errReturn (the enclosing
# render closure, not a thunk; the thunk case is ctx_cond_attr.txtar).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"context"
	"errors"

	"corpustest/cases/renderers_ctx_fallthrough_attr/pg"
)

func PgText(ctx context.Context, t pg.Text) (string, error) {
	if ctx == nil {
		return "", errors.New("pgtext: no ctx")
	}
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return "RENDERED:" + t.String, nil
}
-- input.gsx --
package views

import (
	"github.com/gsxhq/gsx"

	"corpustest/cases/renderers_ctx_fallthrough_attr/pg"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title gsx.Node, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(val pg.Text) {
	<Card title="Hi" data-x={ val } />
}
-- invoke --
Page(mkText("hi", true))
-- diagnostics.golden --
