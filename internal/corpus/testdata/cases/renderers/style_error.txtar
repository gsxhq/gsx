# A renderer func(pg.Text) (string, error) at the <style> boundary: the hoist
# shape is `_gsxvN, _gsxerr := _gsxf0.PgColor((val)); if _gsxerr != nil { return
# _gsxerr }` — the SAME per-context error-return applyRenderer's caller passes
# at every other boundary (mirrors renderers/text_error.txtar and
# style/block_tuple_error.txtar, which already pins that the CSS boundary's
# native (T, error) unwrap uses this identical hoist/return shape). Invoked
# with an invalid value so the renderer's own error halts output right after
# the partial "<style>" tag already written.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgColor"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_style_error/pg"
)

func PgColor(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgcolor: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import "corpustest/cases/renderers_style_error/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<style>.a{color:@{ val }}</style>
}
-- invoke --
Tag(TagProps{Val: mkText("red", false)})
