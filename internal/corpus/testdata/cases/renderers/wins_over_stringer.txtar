# pg.Text also implements fmt.Stringer (String() string), which would
# otherwise make it natively renderable via the Stringer rule. Registration
# wins unconditionally: render.golden must show the renderer's output, never
# the "STRINGER" sentinel the String() method would produce, and the
# generated call must go through _gsxf<i>.PgText, not a native .String() /
# fmt.Sprint reach.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	Value string
	Valid bool
}

func (t Text) String() string { return "STRINGER" }
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_wins_over_stringer/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return "RENDERED:" + t.Value
}
-- input.gsx --
package views

import "corpustest/cases/renderers_wins_over_stringer/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{Value: s, Valid: valid} }

component Tag(val pg.Text) {
	<div>{ val }</div>
}
-- invoke --
Tag(TagProps{Val: mkText("hi", true)})
-- diagnostics.golden --
-- generated.x.go.golden --
