	_gsxrt "github.com/gsxhq/gsx"
	_gsxio "io"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{Value: s, Valid: valid} }

type TagProps struct {
	Val pg.Text
}

//line input.gsx:7:1
func Tag(_gsxp TagProps) _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		val := _gsxp.Val
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.S("<div>")
//line input.gsx:8:7
		_gsxgw.Text(string(_gsxf25.PgText((val))))
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
-- render.golden --
<div>RENDERED:hi</div>
