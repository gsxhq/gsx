# SECURITY: ctx-taking sibling of attr_url.txtar — the renderer runs BEFORE
# whole-value URL sanitization, same order, now with ctx threaded through.
# The renderer proves ctx is real via the "NO-CTX" guard; danger's renderer
# returns "javascript:alert(1)" (neutralized by _gsxgw.URL to
# "about:invalid#gsx"), safe's renderer returns an ordinary https URL that
# passes through unsanitized-in-form.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"context"

	"corpustest/cases/renderers_ctx_attr_url/pg"
)

func PgText(ctx context.Context, t pg.Text) string {
	if ctx == nil {
		return "NO-CTX"
	}
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_ctx_attr_url/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Link(danger pg.Text, safe pg.Text) {
	<div>
		<a href={ danger }>bad</a>
		<a href={ safe }>good</a>
	</div>
}
-- invoke --
Link(LinkProps{Danger: mkText("javascript:alert(1)", true), Safe: mkText("https://example.com", true)})
-- diagnostics.golden --
