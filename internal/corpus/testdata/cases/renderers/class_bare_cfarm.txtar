# A value-form CF arm (class={ if on { val } else { other } }) where BOTH arms
# are BARE IDENTIFIERS of the REGISTERED type pg.Text — the CF-arm sibling of
# class_bare_ident.txtar's plain-part case and valuecf_arm.txtar's call-expr
# case. Before #85 the probe only stubbed CALL-expr arms (isCallExpr(expr)),
# so a bare-identifier arm failed the skeleton's own go/types check the same
# way class_bare_ident.txtar's plain part did. Probe mode now stubs every arm
# value expr with "" regardless of shape; at emit, each taken arm's value
# still runs through applyClassRenderer exactly as valuecf_arm.txtar pins for
# a call expr.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_class_bare_cfarm/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_class_bare_cfarm/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text, other pg.Text, on bool) {
	<div class={ if on { val } else { other } }>x</div>
}
-- invoke --
Tag(TagProps{Val: mkText("on-class", true), Other: mkText("off-class", true), On: true})
