# A renderer func(pg.Text) (string, error): the hoist shape is
# `_gsxvN, _gsxerr := _gsxf0.PgText((val)); if _gsxerr != nil { return _gsxerr }`
# — the SAME per-context error-return applyRenderer's caller passes as any
# other hoisted tuple. Invoked with an invalid value so the renderer's own
# error propagates as a render error (halting output right after the partial
# "<div>" already written), pinning that a hasErr renderer flows through
# hoistTupleReturning exactly like a hasErr pipe filter.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_text_error/pg"
)

func PgText(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import "corpustest/cases/renderers_text_error/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<div>{ val }</div>
}
-- invoke --
Tag(TagProps{Val: mkText("hi", false)})
-- diagnostics.golden --
