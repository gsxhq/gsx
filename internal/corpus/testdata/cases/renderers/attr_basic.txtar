# A plain (non-URL) attribute value whose type has a registered renderer:
# both data-x={ val } and title={ val } of type pg.Text emit
# _gsxf<i>.PgText((val)) and render the renderer's string result through the
# ordinary attribute escaper (gw.AttrValue) — same renderer, same "" (T,
# error) auto-unwrap-then-classify order emitExprAttr already used for a
# native type, just with the renderer call spliced in first. The invoked
# value carries a double-quote and an angle bracket to prove the renderer's
# OUTPUT is what gets attribute-escaped, not emitted raw.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_attr_basic/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_attr_basic/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<div data-x={ val } title={ val }>ok</div>
}
-- invoke --
Tag(TagProps{Val: mkText("a\"b<x>", true)})
-- diagnostics.golden --
