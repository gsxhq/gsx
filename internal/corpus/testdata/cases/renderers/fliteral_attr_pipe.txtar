# A whole-literal-piped attr f-literal (title=`hi-@{name}` |> wrapText): the
# assembled literal is piped through a filter returning the REGISTERED type
# pg.Text, so the renderer applies to the PIPE's OWN result — this is
# emitEmbeddedTextAttr's Stages>0 branch applyRenderer call (the OTHER Task 5
# hand-off site, distinct from holeStringExpr, which fliteral_attr.txtar
# covers). Non-URL context (title), so the rendered string routes through
# the ordinary emitAttrValue escaper.
-- gsx.toml --
filter_packages = ["./wrapf"]

[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_fliteral_attr_pipe/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- wrapf/wrapf.go --
package wrapf

import "corpustest/cases/renderers_fliteral_attr_pipe/pg"

// WrapText is the filter `wrapText`.
func WrapText(s string) pg.Text { return pg.Text{String: s, Valid: true} }
-- input.gsx --
package views

component Tag(name string) {
	<div title={f`hi-@{name}` |> wrapText}>ok</div>
}
-- invoke --
Tag(TagProps{Name: "<b>x</b>"})
-- diagnostics.golden --
