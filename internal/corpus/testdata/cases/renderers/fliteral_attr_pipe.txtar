	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		name := _gsxp.Name
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:4:2
		_gsxgw.S("<div title=\"")
		_gsxgw.AttrValue(string(_gsxf12.PgText((_gsxf0.WrapText(("hi-" + string(name)))))))
