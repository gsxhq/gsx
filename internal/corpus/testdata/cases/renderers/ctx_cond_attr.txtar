# A ctx-taking + (R, error) renderer as an ExprAttr value inside a component
# conditional-attr branch (`{ if hot { data-x={ val } } }` on a CHILD
# component invocation) — the ctx-taking sibling of attr_error_cond.txtar.
# The value is built into an `_gsxrt.Attrs{...}` bag literal inside a `func()
# (_gsxrt.Attrs, error)` thunk (condAttrsExpr/condBranchAttrs); this pins
# that pipeCtxIdent ("ctx") is STILL in scope and correctly threaded at that
# nesting depth — the renderer's error hoists through the thunk's own
# two-value return shape `return nil, _gsxerr`, never the enclosing render
# closure's single-value `return _gsxerr`. Invoked with an invalid value so
# the error path (not just the success path) is pinned.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"context"
	"errors"

	"corpustest/cases/renderers_ctx_cond_attr/pg"
)

func PgText(ctx context.Context, t pg.Text) (string, error) {
	if ctx == nil {
		return "", errors.New("pgtext: no ctx")
	}
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import (
	"github.com/gsxhq/gsx"

	"corpustest/cases/renderers_ctx_cond_attr/pg"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title gsx.Node, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(hot bool, val pg.Text) {
	<Card title="Hi" { if hot { data-x={ val } } } />
}
-- invoke --
Page(true, mkText("hi", false))
-- diagnostics.golden --
14:2: attribute "title" cannot be passed to github.com/gsxhq/gsx.Node: zero.go:2:18: cannot use "Hi" (constant of type string) as _gsxwant value in variable declaration: string does not implement gsx.Node (missing method Render)
-- generated.x.go.golden --
-- render.golden --
