-- gsx.toml --
[renderers]
"./pg.Timestamptz" = "./rend.Timestamptz"
-- pg/pg.go --
package pg

type Timestamptz struct {
	Label string
}
-- rend/renderers.gsx --
package rend

import (
	"github.com/gsxhq/gsx"
	"corpustest/cases/renderers_package_cross/pg"
)

func Timestamptz(v pg.Timestamptz) gsx.Node {
	return <time>{v.Label}</time>
}

component OwnerPreview(v pg.Timestamptz) {
	<div>{v}</div>
}
-- views/input.gsx --
package views

import "corpustest/cases/renderers_package_cross/pg"

func Sample(label string) pg.Timestamptz { return pg.Timestamptz{Label: label} }

component Page(v pg.Timestamptz) {
	<article>{v}</article>
}
-- invoke --
views.Page(views.PageProps{V: views.Sample("14 Jul 2026")})
-- diagnostics.golden --
-- render.golden --
<article><time>14 Jul 2026</time></article>
