# An UNMATCHED ExprAttr on a child-component invocation — the fallthrough
# Attrs-bag boundary (childPropsLiteral's bag splice): `data-x={ val }` on
# <Card> matches no CardProps field, so its value lands in the fallthrough
# bag literal `{Key: "data-x", Value: ...}` and renders as an attribute at
# the leaf via Spread. This is a STATIC render boundary (the value's type is
# known at codegen), so the renderer applies BEFORE the value enters the bag
# as `any` — pre-fix the raw pg.Text struct was spliced in and the runtime's
# fmt.Sprint fallback rendered `data-x="{hi true}"`, and the (R, error)
# renderer's error branch was unreachable (silently swallowed). The renderer
# is (R, error) deliberately: the generated golden must pin the hoist
# `_gsxvN, _gsxerr := rend.PgText((val)); if _gsxerr != nil { return _gsxerr }`
# — single-value errReturn, since childPropsLiteral's bag hoists into the
# enclosing render closure (same shape as its final-pipe-stage hoist), NOT a
# thunk (the thunk case is the cond-attr branch, attr_error_cond.txtar).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_fallthrough_attr/pg"
)

func PgText(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return "RENDERED:" + t.String, nil
}
-- input.gsx --
package views

import (
	"github.com/gsxhq/gsx"

	"corpustest/cases/renderers_fallthrough_attr/pg"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title gsx.Node, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(val pg.Text) {
	<Card title="Hi" data-x={ val } />
}
-- invoke --
Page(mkText("hi", true))
-- diagnostics.golden --
-- generated.x.go.golden --
