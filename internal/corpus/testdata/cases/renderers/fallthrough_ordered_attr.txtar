# A registered-type value inside an ordered-attrs {{ }} literal targeting the
# Attrs bag: `attrs={{ "data-b": val }}` splices each pair as {Key, Value: any}
# into a gsx.Attrs literal — the same static render boundary as an unmatched
# fallthrough attr (fallthrough_attr.txtar), reached through
# childPropsLiteral's OrderedAttrsAttr case + genChildComponent's
# literal-rebuild pass instead of the bag splice. Pre-fix the raw pg.Text
# struct went in as `any` and the runtime's fmt.Sprint fallback rendered
# `data-b="{hi true}"`. The renderer is applied when the literal is (re)built,
# so the golden pins `Value: _gsxf<i>.PgText((val))` inside the rebuilt
# gsx.Attrs{...}; the sibling non-registered pair ("data-c") is untouched.
# A pure (no-error) renderer keeps the rebuild the only shape change.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_fallthrough_ordered_attr/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return "RENDERED:" + t.String
}
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
import "corpustest/cases/renderers_fallthrough_ordered_attr/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Panel(attrs gsx.Attrs) {
	<section { attrs... }>x</section>
}

component Page(val pg.Text) {
	<Panel data-a="1" attrs={{ "data-b": val, "data-c": "9" }} />
}
-- invoke --
Page(mkText("hi", true))
-- diagnostics.golden --
