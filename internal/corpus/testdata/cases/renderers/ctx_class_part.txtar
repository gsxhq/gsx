# A composable class={ val } attribute on a component, val a BARE IDENTIFIER
# of the registered type pg.Text (not a call expr — relies on Task 1's #85
# fix that stubs every class-part value expr in probe mode regardless of
# shape, not just CALL expressions) whose renderer wants ctx: pins that
# applyClassRenderer's call site (classEntryExpr, the component-prop sibling
# of composedParts) also threads ctx through. Card has no class prop of its
# own, so the rendered string reaches the leaf via the fallthrough Attrs bag
# and Attrs.Class() merge — same shape as class_part_component.txtar.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"context"

	"corpustest/cases/renderers_ctx_class_part/pg"
)

func PgText(ctx context.Context, t pg.Text) string {
	if ctx == nil {
		return "NO-CTX"
	}
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
import "corpustest/cases/renderers_ctx_class_part/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Card(title string, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(name pg.Text) {
	<Card title="hi" class={ name }/>
}
-- invoke --
Page(mkText("btn primary", true))
-- diagnostics.golden --
