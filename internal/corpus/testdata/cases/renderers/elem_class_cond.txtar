# A conditional class part (class={ val: on }) on a PLAIN ELEMENT (not a
# component) whose unconditional VALUE is the REGISTERED type pg.Text — the
# element-branch counterpart of class_bare_cond.txtar (which pins the same
# shape on a component's class attr). Before #88's fix the element-branch
# probe loop in emitProbes only harvested UNCONDITIONAL plain parts
# (`ca.Parts[i].Cond == ""`), so a conditional part's resolved[p] stayed nil
# and composedParts' applyRenderer call never fired — the skeleton's own
# go/types check failed with "cannot use val (variable of struct type
# pg.Text) as string value in argument to _gsxrt.ClassIf". The harvest now
# also covers conditional plain parts, so the renderer applies exactly as it
# does for the unconditional case.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_elem_class_cond/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_elem_class_cond/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Page(val pg.Text, on bool) {
	<div class={ val: on }>x</div>
}
-- invoke --
Page(PageProps{Val: mkText("btn", true), On: true})
-- diagnostics.golden --
