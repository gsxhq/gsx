# A <script> child interpolation whose type has a registered renderer: { val }
# of type pg.Text emits _gsxf0.PgJS((val)) and the renderer's string result
# feeds the SAME JS string-context escaper (gw.JSStr) any other string would —
# pinned by invoking with a value containing "</script>" so the render.golden
# shows JS-context escaping of the RENDERER'S output, not the raw pg.Text.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgJS"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_script_hole/pg"

func PgJS(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_script_hole/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<script>const s = "x@{ val }";</script>
}
-- invoke --
Tag(TagProps{Val: mkText("</script>", true)})
-- diagnostics.golden --
-- generated.x.go.golden --
