# A renderer func(pg.Text) (string, error) at a plain attribute-value
# boundary: the hoist shape is `_gsxvN, _gsxerr := _gsxf<i>.PgText((val)); if
# _gsxerr != nil { return _gsxerr }` — the SAME single-value errReturn a
# hasErr text-position renderer uses (text_error.txtar), just spliced in
# before emitAttrValue's classify switch instead of emitRender's. The hoist
# lands BEFORE the attribute name/opening quote are written (emitExprAttr
# resolves the value ahead of writing ` name="`, exactly as a plain (T,
# error) attr value already did pre-renderer), so invoking with an invalid
# value halts output right after the open tag's `<div`, before any attribute
# text at all.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_attr_error/pg"
)

func PgText(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import "corpustest/cases/renderers_attr_error/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<div data-x={ val }>ok</div>
}
-- invoke --
Tag(TagProps{Val: mkText("hi", false)})
-- diagnostics.golden --
