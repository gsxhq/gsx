# "*./pg.Text" registers ONLY the pointer type: a *pg.Text hole is wrapped in
# the renderer, while a same-package pg.Text VALUE hole (not registered here)
# falls back to its native .String field read, unaffected. Pins that pointer
# and value registrations are distinct canonical keys (rendererKey's "*"
# prefix), so registering one never silently covers the other.
-- gsx.toml --
[renderers]
"*./pg.Text" = "./rend.PgTextPtr"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_pointer/pg"

func PgTextPtr(t *pg.Text) string {
	if t == nil || !t.Valid {
		return ""
	}
	return "PTR:" + t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_pointer/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }
func mkTextPtr(s string, valid bool) *pg.Text {
	v := mkText(s, valid)
	return &v
}

component Tag(ptr *pg.Text, val pg.Text) {
	<div>
		<p>{ ptr }</p>
		<p>{ val.String }</p>
	</div>
}
-- invoke --
Tag(mkTextPtr("hi", true), mkText("plain", true))
