# A renderer returning a NUMERIC type (func(pg.Count) int): the emit paths
# take the numeric fast-path arm (gw.IntInto(_gsxnum[:], ...)) on the
# renderer's RESULT type, so the _gsxnum scratch-declaration prescan
# (scopeUsesNumeric/attrsUseNumericScratch/resolvedTypeIsNumeric) must also
# see the post-renderer type — pre-fix it classified the raw registered type
# (pg.Count, a struct: not numeric), skipped declaring `var _gsxnum [32]byte`,
# and the generated .x.go failed to compile with an undefined _gsxnum. Both a
# TEXT hole and a (non-URL) ATTR hole are covered in one template, since the
# prescan reaches them through different scans (interpIsNumeric vs
# attrsUseNumericScratch) but the same resolvedTypeIsNumeric core.
-- gsx.toml --
[renderers]
"./pg.Count" = "./rend.CountVal"
-- pg/pg.go --
package pg

type Count struct {
	N     int
	Valid bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_numeric_result/pg"

func CountVal(c pg.Count) int {
	if !c.Valid {
		return 0
	}
	return c.N
}
-- input.gsx --
package views

import "corpustest/cases/renderers_numeric_result/pg"

func mkCount(n int, valid bool) pg.Count { return pg.Count{N: n, Valid: valid} }

component Tag(val pg.Count) {
	<div data-n={ val }>{ val }</div>
}
-- invoke --
Tag(TagProps{Val: mkCount(42, true)})
-- diagnostics.golden --
