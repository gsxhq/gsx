	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		val := _gsxp.Val
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.S("<div>")
//line input.gsx:8:7
		_gsxgw.Text(string(_gsxf0.PgText((val))))
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
-- render.golden --
<div>&lt;b&gt;hi&lt;/b&gt;</div>
