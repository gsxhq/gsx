# A text hole whose type has a registered renderer: {p.Val} of type pg.Text
# emits _gsxf0.PgText((val)) and renders the renderer's string result — no
# .String reach, no pipe. mkText keeps the invoke file from needing its own
# import of the case-local pg package (the entry file is single-package, so
# only the "gsx." qualifier gets an auto-import — see writeEntry).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_text_basic/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_text_basic/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<div>{ val }</div>
}
-- invoke --
Tag(TagProps{Val: mkText("<b>hi</b>", true)})
-- diagnostics.golden --
-- generated.x.go.golden --
