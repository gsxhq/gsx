# A <style> child interpolation whose type has a registered renderer: { val }
# of type pg.Text emits _gsxf0.PgColor((val)) and the renderer's string result
# feeds the SAME CSS-value filter (gw.CSS) any other string would — pinned by
# invoking with a value that triggers the filter's ZgotmplZ substitution
# (mirrors style/block_import_injection.txtar).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgColor"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_style_hole/pg"

func PgColor(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_style_hole/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<style>.a{color:@{ val }}</style>
}
-- invoke --
Tag(TagProps{Val: mkText("@import url(evil.css)", true)})
