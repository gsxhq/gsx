# An explicit CSS attribute literal (data-style=css`...@{ val }...`) hole
# whose type has a registered renderer: emitCSSAttrInterp/emitRenderCSSAttr
# had no applyRenderer wiring before this task (unlike its <style>-block
# sibling emitCSSInterp, wired in Task 6) — a genuine remaining boundary
# found by the classify() enumeration. { val } of type pg.Text emits
# _gsxf<i>.PgColor((val)) and the renderer's string result feeds the SAME
# gsx.StyleValue + gw.AttrValue chain any other string would — pinned by
# invoking with a value that triggers the CSS-value filter's ZgotmplZ
# substitution (mirrors style_hole.txtar's <style>-block sibling case).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgColor"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_css_attr_hole/pg"

func PgColor(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import (
	"corpustest/cases/renderers_css_attr_hole/pg"
	"github.com/gsxhq/gsx"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text, a gsx.Attrs, b gsx.Attrs) {
	<div data-style=css`color:@{ val }`>inline</div>
	<div { a... } data-style=css`color:@{ val }` { b... }>fold</div>
}
-- invoke --
Tag(TagProps{Val: mkText("@import url(evil.css)", true)})
