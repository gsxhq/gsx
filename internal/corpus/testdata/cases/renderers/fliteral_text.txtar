# A body f-literal WHOLE-PIPE hole: {f`hi-@{name}` |> wrapText} pipes the
# assembled literal through a filter that returns the REGISTERED type
# pg.Text, so the renderer applies to the PIPE's result exactly like
# renderers/pipe_result.txtar's bare-interp case — but here the pipeline's
# SEED is an f-literal (*ast.EmbeddedInterp), which emitEmbeddedInterp's
# own Stages>0 branch assembles+pipes+unwraps+applyRenderer's independently
# of genInterp (the bare-{expr} path pipe_result.txtar already pins). This
# is the "fliteral_text" render boundary: emitEmbeddedInterp's applyRenderer
# call, distinct from genInterp's.
-- gsx.toml --
filter_packages = ["./wrapf"]

[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_fliteral_text/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- wrapf/wrapf.go --
package wrapf

import "corpustest/cases/renderers_fliteral_text/pg"

// WrapText is the filter `wrapText`.
func WrapText(s string) pg.Text { return pg.Text{String: s, Valid: true} }
-- input.gsx --
package views

component Tag(name string) {
	<div>{f`hi-@{name}` |> wrapText}</div>
}
-- invoke --
Tag(TagProps{Name: "<b>world</b>"})
-- diagnostics.golden --
-- generated.x.go.golden --
