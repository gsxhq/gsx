# A renderer func(pg.Text) (string, error) applied to a CONDITIONAL class
# part on a plain element — the error-hoist sibling of elem_class_cond.txtar,
# mirroring style_error.txtar's per-context hoist shape (`_gsxvN, _gsxerr :=
# ...; if _gsxerr != nil { return _gsxerr }`) BEFORE the ClassIf call, at the
# TOP-LEVEL render closure's own single-value `return _gsxerr` (no bag/thunk
# involved, unlike attr_error_cond.txtar's component cond-attr-branch path).
# Invoked with an invalid value so the renderer's own error path is pinned.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_elem_class_cond_error/pg"
)

func PgText(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import "corpustest/cases/renderers_elem_class_cond_error/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Page(val pg.Text, on bool) {
	<div class={ val: on }>x</div>
}
-- invoke --
Page(mkText("btn", false), true)
-- diagnostics.golden --
