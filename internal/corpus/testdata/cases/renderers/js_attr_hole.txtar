# An explicit JS attribute literal (@click=js`save(@{ val })`) hole whose
# type has a registered renderer: emitJSAttrInterp/emitJSAttrValue had no
# applyRenderer wiring before this task (unlike its <script>-block sibling
# emitJSInterp, wired in Task 6) — a genuine remaining boundary found by the
# classify() enumeration. { val } of type pg.Text emits
# _gsxf<i>.PgJS((val)) and the renderer's string result feeds the SAME
# gw.JSValAttr JSON-encode chain any other value context would (mirrors
# script_hole.txtar's <script>-block sibling case, adjusted for the JS value
# context's JSON encoding of the *string*).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgJS"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_js_attr_hole/pg"

func PgJS(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_js_attr_hole/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<button @click=js`save(@{ val })`>Save</button>
}
-- invoke --
Tag(TagProps{Val: mkText("</script>", true)})
