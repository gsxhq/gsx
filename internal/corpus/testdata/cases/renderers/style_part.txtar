# A composable style={ val } part whose value is the REGISTERED type
# pg.Text: unlike class parts, StyleValue(any) already ACCEPTS any type (so
# this compiles either way) — but pre-fix it would fmt.Sprint the raw
# pg.Text struct instead of the author's rendered string. The renderer now
# applies FIRST, so StyleValue CSS-filters the RENDERED string, not the raw
# struct — pinned by invoking with a value that would trigger the CSS-value
# filter's substitution if it ever leaked through unrendered.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgColor"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_style_part/pg"

func PgColor(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_style_part/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<div style={ val }>x</div>
}
-- invoke --
Tag(TagProps{Val: mkText("color:red", true)})
-- diagnostics.golden --
-- generated.x.go.golden --
