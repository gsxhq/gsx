# srcset is a URL-LIST sink (see srcset-sanitize/static_expr.txtar): the
# renderer runs FIRST, producing the candidate list, then _gsxgw.Srcset
# whole-value-parses THAT output and neutralizes any javascript: candidate to
# "about:invalid#gsx" (the whole candidate — URL + descriptor — collapses;
# see escape.go's srcsetSanitize). val's renderer returns
# "ok.jpg 1x, javascript:alert(1) 1.5x"; the safe "ok.jpg 1x" candidate passes
# through unchanged and the dangerous one is neutralized with its descriptor
# dropped.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_srcset_hole/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_srcset_hole/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Pic(val pg.Text) {
	<img srcset={ val }/>
}
-- invoke --
Pic(PicProps{Val: mkText("ok.jpg 1x, javascript:alert(1) 1.5x", true)})
-- diagnostics.golden --
-- render.golden --
<img srcset="ok.jpg 1x, about:invalid#gsx"/>
-- generated.x.go.golden --
