	_gsxf40 "corpustest/cases/renderers_srcset_hole/rend"
	_gsxrt "github.com/gsxhq/gsx"
	_gsxio "io"
)

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

type PicProps struct {
	Val pg.Text
}

//line input.gsx:7:1
func Pic(_gsxp PicProps) _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		val := _gsxp.Val
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.S("<img srcset=\"")
		_gsxgw.Srcset(string(_gsxf40.PgText((val))))
		_gsxgw.S("\"/>")
		return _gsxgw.Err()
	})
}
