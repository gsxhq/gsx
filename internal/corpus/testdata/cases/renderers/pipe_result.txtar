# { x |> wrap } where the filter `wrap` returns the registered type pg.Text:
# the renderer applies to the PIPE's result, not to x itself — the emitted
# shape is _gsxf<i>.PgText((_gsxf<j>.Wrap((x)))), pinning that applyRenderer
# runs on resolved[n] (the pipeline's result type) after lowerPipe, exactly
# once, never touching the pipeline's intermediate stages.
-- gsx.toml --
filter_packages = ["./wrapf"]

[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_pipe_result/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- wrapf/wrapf.go --
package wrapf

import "corpustest/cases/renderers_pipe_result/pg"

// Wrap is the filter `wrap`.
func Wrap(s string) pg.Text { return pg.Text{String: s, Valid: true} }
-- input.gsx --
package views

component Tag(x string) {
	<div>{ x |> wrap }</div>
}
-- invoke --
Tag(TagProps{X: "hi"})
-- diagnostics.golden --
