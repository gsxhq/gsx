# A component param of the registered type pg.Text, forwarded as a CHILD
# component prop (`<Child val={val}/>`): renderers apply only at a render
# boundary (this task wires text only), never to a value merely flowing
# through a component-prop position. generated.x.go.golden pins that the
# caller passes the raw value (`Child(val)`), not a renderer call —
# the renderer fires only inside Child's own body where val.String is
# explicitly read as a plain string (no pg.Text interpolation occurs there).
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_component_arg_negative/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_component_arg_negative/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Child(val pg.Text) {
	<span>{ val.String }</span>
}

component Parent(val pg.Text) {
	<Child val={val}/>
}
-- invoke --
Parent(mkText("hi", true))
