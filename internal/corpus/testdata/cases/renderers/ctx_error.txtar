# A ctx-taking renderer func(ctx context.Context, pg.Text) (string, error) —
# the ctx-taking sibling of text_error.txtar: the hoist shape is
# `_gsxvN, _gsxerr := _gsxfN.PgText(ctx, (val)); if _gsxerr != nil { return
# _gsxerr }`, pinning that ctx injection and error-hoisting compose (same
# combination pipeerr/ctx_err_filter.txtar pins for a pipe filter). Invoked
# with an invalid value so the renderer's own error propagates as a render
# error, halting output right after the partial "<div>" already written.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"context"
	"errors"

	"corpustest/cases/renderers_ctx_error/pg"
)

func PgText(ctx context.Context, t pg.Text) (string, error) {
	if ctx == nil {
		return "", errors.New("pgtext: no ctx")
	}
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import "corpustest/cases/renderers_ctx_error/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text) {
	<div>{ val }</div>
}
-- invoke --
Tag(mkText("hi", false))
-- diagnostics.golden --
-- generated.x.go.golden --
