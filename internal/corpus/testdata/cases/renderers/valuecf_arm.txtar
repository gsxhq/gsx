# A value-form CF arm (class={ if cond { val } else { "off" } }) whose taken
# arm is the REGISTERED type pg.Text: hoistValueCF's armExpr had no renderer
# handling before this task — the arm's value assigns directly into the
# `var _gsxvN string` value-form temp, so a registered non-string arm value
# previously failed to compile (same gsx.Class(s string) constraint as
# class_part.txtar). The OTHER arm ("off") is a plain string literal with no
# registered renderer, proving per-arm type resolution: only the pg.Text arm
# routes through the renderer.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_valuecf_arm/pg"

func PgText(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_valuecf_arm/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text, on bool) {
	<div class={ if on { val } else { "off" } }>x</div>
}
-- invoke --
Tag(TagProps{Val: mkText("on-class", true), On: true})
