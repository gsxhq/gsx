# A css`...` literal PART inside a composable style={ ... } whose @{ } hole
# has the REGISTERED type pg.Text: cssLiteralStylePartExpr's own applyRenderer
# branch (distinct from composedParts' plain-part path style_part.txtar pins,
# and from the explicit css-ATTR literal css_attr_hole.txtar pins). Two
# discriminators, both verified RED with this branch's applyRenderer
# temporarily reverted:
#   - generated: the renderer call sits INSIDE the css-literal part's concat,
#     "color:" + gsx.StyleValue(_gsxf<i>.PgColor((val))) — RED emitted the
#     raw StyleValue(val);
#   - render: "color:red" — RED rendered "color:ZgotmplZ", because
#     StyleValue(any)'s fmt.Sprint of the raw struct ("{red true}") trips the
#     CSS-value filter, while the renderer's "red" passes it. (The filter
#     itself still runs on the renderer's OUTPUT — renderer-then-filter order
#     is pinned with a hostile value by the sibling cases style_hole /
#     css_attr_hole; this case's job is the raw-struct-vs-rendered-string
#     split, which a hostile value would mask since both sides ZgotmplZ.)
# A second static part ("display:block": on) keeps the case a real
# multi-part composition like style/composed_css_literal.txtar.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgColor"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/renderers_style_css_literal_part/pg"

func PgColor(t pg.Text) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import "corpustest/cases/renderers_style_css_literal_part/pg"

func mkText(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Tag(val pg.Text, on bool) {
	<div style={ "display:block": on, css`color:@{ val }` }>x</div>
}
-- invoke --
Tag(mkText("red", true), true)
-- diagnostics.golden --
