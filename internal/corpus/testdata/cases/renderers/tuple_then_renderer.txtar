# A hole that is itself a (T, error) call — { load(s, valid) } returning
# (pg.Text, error) — where T is the registered type AND the renderer is the
# (R, error) variant: pins the wiring ORDER at the text boundary. The hole's
# own tuple unwraps FIRST (hoist + return _gsxerr), THEN applyRenderer wraps
# the unwrapped temp, hoisting the renderer's own error the same way — two
# stacked hoists in the generated golden:
#   _gsxv0, _gsxerr := load((s), valid); if _gsxerr != nil { return _gsxerr }
#   _gsxv1, _gsxerr := _gsxf<i>.PgText((_gsxv0)); if _gsxerr != nil { ... }
# The corpus supports one invoke per case, so render.golden pins the
# RENDERER-level error (load succeeds with an invalid value; the renderer
# rejects it); the hole-level hoist shape is pinned by generated.x.go.golden.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import (
	"errors"

	"corpustest/cases/renderers_tuple_then_renderer/pg"
)

func PgText(t pg.Text) (string, error) {
	if !t.Valid {
		return "", errors.New("pgtext: invalid value")
	}
	return t.String, nil
}
-- input.gsx --
package views

import (
	"errors"

	"corpustest/cases/renderers_tuple_then_renderer/pg"
)

func load(s string, valid bool) (pg.Text, error) {
	if s == "" {
		return pg.Text{}, errors.New("load: empty input")
	}
	return pg.Text{String: s, Valid: valid}, nil
}

component Tag(s string, valid bool) {
	<div>{ load(s, valid) }</div>
}
-- invoke --
Tag(TagProps{S: "hi", Valid: false})
-- diagnostics.golden --
-- generated.x.go.golden --
