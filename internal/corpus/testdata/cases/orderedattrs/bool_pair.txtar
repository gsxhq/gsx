# Bool values in a {{ }} bag are name-driven at the leaf: a boolean-attribute key
# toggles (true → bare, false → omitted), any other key stringifies to
# "true"/"false" (the value IS the state for data-*/aria-*). gsx.Toggle forces
# presence on a name the spec cannot know.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(toggleAttrs gsx.Attrs) {
	<div { toggleAttrs... }></div>
}

component Page() {
	<Card toggleAttrs={{ "disabled": true, "checked": false, "data-show": true, "data-hide": false, "active": gsx.Toggle(true) }}/>
}
-- invoke --
Page()
