# Motivating Datastar example: ordered data-* directives bound to a component prop.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Counter(signals gsx.OrderedAttrs) {
	<button { signals... }>{children}</button>
}

component Page() {
	<Counter signals={{ "data-signals": "{count:0}", "data-text": "$count", "data-on-click": "$count++" }}>Count</Counter>
}
-- invoke --
Page()
-- diagnostics.golden --
