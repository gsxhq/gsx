# Duplicate keys in {{ }} render twice in source order (browser applies first-wins).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(dupAttrs gsx.OrderedAttrs) {
	<div { dupAttrs... }></div>
}

component Page() {
	<Card dup-attrs={{ "data-x": "1", "data-x": "2" }}/>
}
-- invoke --
Page()
