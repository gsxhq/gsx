# Duplicate scalar keys in {{ }} preserve source order in the generated bag, but
# Spread renders the last scalar value so later pairs override earlier ones.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(dupAttrs gsx.Attrs) {
	<div { dupAttrs... }></div>
}

component Page() {
	<Card dup-attrs={{ "data-x": "1", "data-x": "2" }}/>
}
-- invoke --
Page()
-- diagnostics.golden --
10:8: Card has no attrs param; unexpected attribute "dup-attrs"
