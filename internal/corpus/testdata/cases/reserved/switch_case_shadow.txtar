# Shadow-FIRST switch: case "a" declares a nested `attrs` shadow, case "b" uses
# `attrs` FREE (the implicit fallthrough bag). Each case gets its OWN copy of the
# clause env, so the case-"a" shadow does not leak into case "b" — the free use is
# detected and the Attrs prop synthesized. Before the fix a single shared switch
# env leaked case "a"'s shadow into case "b", false-rejecting with
# `undefined: attrs`. Render proves both: the shadow case spreads its LOCAL bag
# (data-local), the free case spreads the CALLER bag (data-caller).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component C(mode string) {
	{ switch mode {
	case "a":
		{{ attrs := gsx.Attrs{{Key: "data-local", Value: "1"}} }}
		<span { attrs... }>a</span>
	case "b":
		<div { attrs... }>b</div>
	} }
}
-- invoke --
gsx.Fragment(C(CProps{Mode: "a", Attrs: gsx.Attrs{{Key: "data-caller", Value: "9"}}}), C(CProps{Mode: "b", Attrs: gsx.Attrs{{Key: "data-caller", Value: "9"}}}))
-- diagnostics.golden --
-- render.golden --
<span data-local="1">a</span><div data-caller="9">b</div>
