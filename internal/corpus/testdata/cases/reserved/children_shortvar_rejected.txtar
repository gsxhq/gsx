# Rejection (spec §14): a body-scope `children :=` collides with the implicit
# children slot local that `{children}` placement brings into scope. Reserved
# regardless of the type mismatch.
-- input.gsx --
package views

component Page() {
	{{ children := "hi" }}
	<div>{children}</div>
}
-- diagnostics.golden --
4:5: identifier "children" is reserved (the implicit children slot) — rename the variable
4:14: no new variables on left side of :=
4:17: cannot use "hi" (constant of type string) as gsx.Node value in assignment: string does not implement gsx.Node (missing method Render)
