# Positive (spec §8): a body places `{children}` AND a separate GoBlock uses
# `children` as an ordinary value (`children != nil`) feeding a data attribute.
# Placement is what makes `children` usable as a value anywhere in the body —
# slot-first, per the model — regardless of the two fragments' relative source
# order. Pins the positive side of the documented asymmetry (the unplaced
# negative is `reserved/children_value_unplaced`).
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Kids(children gsx.Node) {
	{{ hasKids := children != nil }}
	<section data-has-kids={hasKids}>{children}</section>
}

component Page() {
	<Kids>hi</Kids>
}
-- invoke --
Page()
-- diagnostics.golden --
