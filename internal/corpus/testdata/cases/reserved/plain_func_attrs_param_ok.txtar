# Positive (spec §9): a plain top-level `.gsx` func — not a `component`
# declaration — names its variadic param `attrs` and spreads it with
# `{ attrs... }` inside an element literal. This is the real one-learning
# `ds/icon/named.gsx` shape (`func(attrs ...gsx.Attr) gsx.Node`). Reservation
# is a component-body concept only (checkReservedBodyBindings walks
# `ast.Component.Body`; checkReservedParams/checkReservedRecvVar gate
# component params/receivers) — a plain func's own param list is untouched by
# any of it, so naming a param `attrs` here is ordinary Go, not a collision.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func Icon(attrs ...gsx.Attr) gsx.Node {
	return (
		<svg { attrs... }>x</svg>
	)
}

component Page() {
	<div>{ Icon(gsx.Attr{Key: "class", Value: "ic"}) }</div>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div><svg class="ic">x</svg></div>
