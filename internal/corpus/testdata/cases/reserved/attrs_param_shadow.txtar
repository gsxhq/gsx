# Companion to children_param_shadow: `attrs`, like `children`, is an ordinary
# captured parameter — `attrs := …` in a {{ }} block shadows it in the render
# closure's nested scope and compiles. (`ctx`, the closure's OWN parameter,
# still collides — see reserved/ctx_shortvar_rejected.)
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Panel(attrs gsx.Attrs) {
	{{ attrs := "hi" }}
	<div>{attrs}</div>
}
-- invoke --
Panel(nil)
