# Component-child reserved-name shadow PLUS an outer sibling free use — the mixed
# shape final review flagged. Inside <Wrap>'s children `{{ attrs := … }}` is a
# closure-scoped shadow (component children lower into a nested gsx.Func slot
# closure, emitSlotClosure); the outer `<span { attrs... }>` is a FREE use, so C
# gets an Attrs prop and `attrs := _gsxp.Attrs` at the render closure's top scope.
# The skeleton is flat, so probing the child shadow at top scope collided with
# that binding (`no new variables on left side of :=`) — a skeleton-only false
# rejection. The fix wraps the component-slot probes in a Go block, restoring
# emit ≡ probe. Render proves both scopes: the inner div spreads the SHADOW bag
# (data-inner), the outer span spreads the CALLER bag (data-outer).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Wrap() {
	<section>{children}</section>
}

component C() {
	<Wrap>
		{{ attrs := gsx.Attrs{{Key: "data-inner", Value: "1"}} }}
		<div { attrs... }>in</div>
	</Wrap>
	<span { attrs... }>out</span>
}
-- invoke --
C(CProps{Attrs: gsx.Attrs{{Key: "data-outer", Value: "9"}}})
-- diagnostics.golden --
-- render.golden --
<section><div data-inner="1">in</div></section><span data-outer="9">out</span>
