# Component-child reserved-name shadow plus an outer sibling body-local binding.
# Inside <Wrap>'s children `{{ attrs := … }}` is a closure-scoped shadow
# (component children lower into a nested gsx.Func slot closure,
# emitSlotClosure); the outer `<span { attrs... }>` uses the ordinary local
# declared in C's render closure. Render proves both scopes: the inner div
# spreads the shadow bag (data-inner), while the outer span spreads the outer
# body-local bag (data-outer).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Wrap(children gsx.Node) {
	<section>{children}</section>
}

component C() {
	{{ attrs := gsx.Attrs{{Key: "data-outer", Value: "9"}} }}
	<Wrap>
		{{ attrs := gsx.Attrs{{Key: "data-inner", Value: "1"}} }}
		<div { attrs... }>in</div>
	</Wrap>
	<span { attrs... }>out</span>
}
-- invoke --
C()
-- diagnostics.golden --
-- render.golden --
<section><div data-inner="1">in</div></section><span data-outer="9">out</span>
