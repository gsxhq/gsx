# Positive (spec §7): `{{ attrs = attrs.Without("id") }}` is the bag-filtering
# idiom — a plain assignment (not `:=`), so it is not a body-scope binding; the
# RHS's free use of `attrs` still fires the trigger correctly. The render
# proves the filtering actually took effect: the caller's `id` attribute is
# GONE from the spread, while the other attribute survives.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Panel(attrs gsx.Attrs) {
	{{ attrs = attrs.Without("id") }}
	<div { attrs... }>x</div>
}
-- invoke --
Panel(gsx.Attrs{{Key: "id", Value: "p1"}, {Key: "class", Value: "box"}})
-- diagnostics.golden --
-- render.golden --
<div class="box">x</div>
