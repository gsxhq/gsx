# Shadow-FIRST if/else: the Then branch declares a nested `attrs` shadow
# (`{{ attrs := … }}`, closure-scoped by the block), the Else branch uses `attrs`
# FREE (the implicit fallthrough bag). The free-use walker threads an INDEPENDENT
# env copy per branch, so the Then shadow does NOT mark `attrs` bound for the
# Else — the Else's free use is detected and the Attrs prop is synthesized. Before
# the fix a single shared branch env leaked the Then shadow into the Else,
# dropping the prop and false-rejecting with `undefined: attrs`. Render proves it:
# the shadow branch (cond=true) spreads its LOCAL bag (data-local, no caller key),
# the free branch (cond=false) spreads the CALLER bag (data-caller).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component C(cond bool) {
	{ if cond {
		{{ attrs := gsx.Attrs{{Key: "data-local", Value: "1"}} }}
		<span { attrs... }>t</span>
	} else {
		<div { attrs... }>e</div>
	} }
}
-- invoke --
gsx.Fragment(C(CProps{Cond: true, Attrs: gsx.Attrs{{Key: "data-caller", Value: "9"}}}), C(CProps{Cond: false, Attrs: gsx.Attrs{{Key: "data-caller", Value: "9"}}}))
-- diagnostics.golden --
-- render.golden --
<span data-local="1">t</span><div data-caller="9">e</div>
