# Positive: a reserved-name binding INSIDE a component element's children is
# legal. Component children lower into a nested gsx.Func slot closure
# (emitSlotClosure), a NEW Go scope — so `{{ attrs := … }}` there is an
# ordinary closure-scoped shadow, not a body-scope collision: the reservation
# pass must NOT flag it (its `bag`-renamed twin builds fine, so flagging would
# reject correct code), and the free-use walker must NOT leak the binding
# outward (Page gets NO Attrs prop — the only `attrs` occurrences are the
# closure-scoped binding and the spread of that SHADOW inside the closure).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Wrap(children gsx.Node) {
	<section>{children}</section>
}

component Page() {
	<Wrap>
		{{ attrs := gsx.Attrs{{Key: "id", Value: "x"}} }}
		<span { attrs... }>hi</span>
	</Wrap>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<section><span id="x">hi</span></section>
