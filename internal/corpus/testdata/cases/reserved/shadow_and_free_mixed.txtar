# A body with BOTH a range-scoped shadow of `attrs` AND a separate free use
# on the root element's spread. freeUseAttrs must fire on the free
# occurrence (root `{ attrs... }`) while the range clause's own `attrs`
# stays a shadow independent of it — the implicit bag is synthesized
# exactly ONCE (one Attrs field on MixedProps), and the loop var never
# aliases the prop: the inner spans get the loop bags, the outer div gets
# the caller-supplied bag, proven by the render (three distinct class
# values, none bleeding into each other).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func bags() []gsx.Attrs {
	return []gsx.Attrs{
		{{Key: "class", Value: "a"}},
		{{Key: "class", Value: "b"}},
	}
}

component Mixed(attrs gsx.Attrs) {
	<div { attrs... }>{ for _, attrs := range bags() { <span { attrs... }>i</span> } }</div>
}
-- invoke --
Mixed(gsx.Attrs{{Key: "class", Value: "root"}})
-- diagnostics.golden --
-- render.golden --
<div class="root"><span class="a">i</span><span class="b">i</span></div>
