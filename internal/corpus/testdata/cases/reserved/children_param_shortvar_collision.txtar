# An explicit children parameter and `children :=` occupy the same Go function
# scope. This is an ordinary Go redeclaration/type error, not a GSX reserved-name
# diagnostic; nested Go scopes may shadow the parameter normally.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Page(children gsx.Node) {
	{{ children := "hi" }}
	<div>{children}</div>
}
-- diagnostics.golden --
6:14: no new variables on left side of :=
6:17: cannot use "hi" (constant of type string) as gsx.Node value in assignment: string does not implement gsx.Node (missing method Render)
