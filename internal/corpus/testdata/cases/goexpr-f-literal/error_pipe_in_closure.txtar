# The SAME error-returning filter (`must`) in an f`…@{…}…` literal WORKS in a
# render-context position: an Interp.Embedded hole `{ take(f`…`) }` in a component
# body lowers inside the render closure, whose buffer holds the
# `_gsxv, _gsxerr := …; if _gsxerr != nil { return _gsxerr }` hoist before the
# consuming statement. Must-keep-working counterpart to diag_error_pipe_toplevel;
# the generated golden pins the hoist.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

func Must(s string) (string, error) {
	if s == "" {
		return "", errors.New("empty")
	}
	return s, nil
}
-- take.go --
package demo

import "github.com/gsxhq/gsx"

func take(s string) gsx.Node { return gsx.Raw(s) }
-- input.gsx --
package demo

component Page(v string) {
	<div>{ take(f`Hi @{v |> must}`) }</div>
}
-- invoke --
Page("a")
-- diagnostics.golden --
-- generated.x.go.golden --
