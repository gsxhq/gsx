# Context: an interpolating f`…@{expr}…` literal used as a first-class Go VALUE
# in a top-level `var` initializer (`var greeting = f`hello @{name}``). The
# literal lowers to a plain Go string concat — the SAME assembly the body/attr
# embedded forms use (embeddedValueExpr) — so `greeting` is an ordinary
# `string`, referenced from a component like any other package var. The hole
# `@{name}` resolves against package scope.
-- input.gsx --
package demo

var name = "world"

var greeting = f`hello @{name}`

component Uses() {
	<p>{ greeting }</p>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<p>hello world</p>
