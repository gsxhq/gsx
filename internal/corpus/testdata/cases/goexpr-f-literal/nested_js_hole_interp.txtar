# W3: a nested js`` literal inside an f`` literal's @{ } hole, the whole f`
# literal riding in a body { } interpolation's Interp.Embedded (in-closure). The
# inner js` lowers to a gsx.RawJS value, converted to string by the hole's
# `string(...)`; the outer f` splices it into a plain string concat passed to
# wrap. In-closure position binds ctx and has a clean hoist channel, so nested
# holes lower exactly like an attribute literal.
-- wrap.go --
package demo

func wrap(s string) string {
	return "[" + s + "]"
}
-- input.gsx --
package demo

component Page(who string) {
	<p>{ wrap(f`a @{ string(js`f(@{who})`) }`) }</p>
}
-- invoke --
Page("Ada")
-- diagnostics.golden --
-- render.golden --
<p>[a f(&#34;Ada&#34;)]</p>
-- generated.x.go.golden --
