# ACCEPTED behavior (documented caveat): an f-literal used as a Go VALUE (here a
# func return) is a plain `string` (concat), so `{ markup(x) }` escapes it whole —
# unlike `{ f`...` }` directly in a body, which is a markup template (see
# bodyinterp/f_body_is_markup_template).
-- input.gsx --
package views

func markup(x string) string { return f`<b>@{x}</b>` }

component Host(x string) {
	<div>{ markup(x) }</div>
}
-- invoke --
Host(HostProps{X: "hi"})
-- diagnostics.golden --
-- render.golden --
<div>&lt;b&gt;hi&lt;/b&gt;</div>
