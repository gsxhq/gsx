# js`/css` literals are NOT supported as Go-expression VALUES (only f` is; js`/css`
# stay attr-context). A js`…` in value position is left verbatim and surfaces as a
# clean positioned error, never a silent miscompile. This pins that gating.
#
# The position is the js` backtick in the .gsx file: checkReservedDecls parses every
# top-level Go region before the skeleton is built, and reports a region that will
# not parse as an ordinary positioned parse-error diagnostic.
-- input.gsx --
package views

func Bad() string {
	return js`alert(@{x})`
}

component Host() {
	<div>{ Bad() }</div>
}
-- invoke --
Host(HostProps{})
-- diagnostics.golden --
4:11: expected ';', found `alert(@{x})`
-- render.golden --
