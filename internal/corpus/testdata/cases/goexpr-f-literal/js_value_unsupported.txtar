# js`/css` literals are NOT supported as Go-expression VALUES (only f` is; js`/css`
# stay attr-context). A js`…` in value position is left verbatim and surfaces as a
# clean positioned error, never a silent miscompile. This pins that gating.
-- input.gsx --
package views

func Bad() string {
	return js`alert(@{x})`
}

component Host() {
	<div>{ Bad() }</div>
}
-- invoke --
Host(HostProps{})
-- diagnostics.golden --
invalid Go in pass-through block: 5:11: expected ';', found `alert(@{x})` (and 1 more errors)
-- render.golden --
