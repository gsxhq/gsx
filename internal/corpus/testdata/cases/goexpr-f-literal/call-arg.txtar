# Context: an f`…@{expr}…` literal passed as a CALL ARGUMENT inside a body
# interpolation (`{ wrap(f`id-@{n}`) }`). The literal is a sub-expression of a
# larger Go expression, so it rides in Interp.Embedded (not the body
# EmbeddedInterp path) and lowers to a Go string spliced into wrap(...). `wrap`
# lives in a sibling plain .go file (same package). The hole `@{n}` is an int
# component param → strconv.FormatInt.
-- wrap.go --
package demo

func wrap(s string) string {
	return "[" + s + "]"
}
-- input.gsx --
package demo

component Item(n int) {
	<div>{ wrap(f`id-@{n}`) }</div>
}
-- invoke --
Item(ItemProps{N: 42})
-- diagnostics.golden --
-- render.golden --
<div>[id-42]</div>
-- generated.x.go.golden --
