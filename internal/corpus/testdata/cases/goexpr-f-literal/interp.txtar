# Context: an f`…@{expr}…` literal passed to a function that returns a
# gsx.Node (`{ emphasize(f`@{label}!`) }`). The literal lowers to a Go string
# argument; the interpolation's resolved type is emphasize's gsx.Node return, so
# it renders as a node. `emphasize` is a sibling plain .go helper. Confirms a
# value-position literal composes with a Node-returning call exactly like any
# other Go expression.
-- emph.go --
package demo

import "github.com/gsxhq/gsx"

func emphasize(s string) gsx.Node {
	return gsx.Raw("<em>" + s + "</em>")
}
-- input.gsx --
package demo

component Shout(label string) {
	<p>{ emphasize(f`@{label}!`) }</p>
}
-- invoke --
Shout(ShoutProps{Label: "hi"})
-- diagnostics.golden --
-- render.golden --
<p><em>hi!</em></p>
