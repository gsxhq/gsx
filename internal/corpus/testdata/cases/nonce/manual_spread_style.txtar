-- support.go --
package views

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func withTestNonce(n gsx.Node) gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		return n.Render(gsx.WithNonce(ctx, "r4nd0m"), w)
	})
}
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Page(attrs gsx.Attrs) { <style { attrs... }>.c{color:red}</style> }
-- invoke --
withTestNonce(Page(gsx.Attrs{{Key: "media", Value: "screen"}}))
-- diagnostics.golden --
-- render.golden --
<style media="screen" nonce="r4nd0m">.c{color:red}</style>
