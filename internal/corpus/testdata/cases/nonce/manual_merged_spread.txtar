# MANUAL forwarding of a MERGED bag ({ attrs.Merge(other)... }) on a script
# element (a second standalone spread alongside { attrs... } is rejected —
# fallthrough/second_spread_rejected). The nonce guard reads the hoisted
# merged bag, so a "nonce" key in EITHER source suppresses injection; here
# neither carries one and the context nonce injects.
-- support.go --
package views

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func withTestNonce(n gsx.Node) gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		return n.Render(gsx.WithNonce(ctx, "r4nd0m"), w)
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Page(other gsx.Attrs) { <script { attrs.Merge(other)... }>init()</script> }
-- invoke --
withTestNonce(Page(PageProps{Other: gsx.Attrs{{Key: "id", Value: "s"}}, Attrs: gsx.Attrs{{Key: "defer", Value: true}}}))
-- diagnostics.golden --
-- render.golden --
<script defer id="s" nonce="r4nd0m">init()</script>
