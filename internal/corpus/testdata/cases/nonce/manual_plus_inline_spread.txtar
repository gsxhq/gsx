# MANUAL bag + a second inline spread on one script element: the guard must
# check BOTH bags (multi-term && guard) and inject only when neither carries
# a "nonce" key. Pins the multi-spread guard shape.
-- support.go --
package views

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func withTestNonce(n gsx.Node) gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		return n.Render(gsx.WithNonce(ctx, "r4nd0m"), w)
	})
}
