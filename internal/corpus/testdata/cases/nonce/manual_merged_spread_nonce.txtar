# MANUAL forwarding of a MERGED bag on a script element where the merged-in
# bag carries an explicit "nonce": the guard reads the hoisted merged bag and
# suppresses the context-nonce injection (author nonce wins).
-- support.go --
package views

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func withTestNonce(n gsx.Node) gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		return n.Render(gsx.WithNonce(ctx, "r4nd0m"), w)
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Page(other gsx.Attrs, attrs gsx.Attrs) { <script { attrs.Merge(other)... }>init()</script> }
-- invoke --
withTestNonce(Page(gsx.Attrs{{Key: "nonce", Value: "mine"}}, gsx.Attrs{{Key: "defer", Value: true}}))
-- diagnostics.golden --
-- render.golden --
<script defer nonce="mine">init()</script>
