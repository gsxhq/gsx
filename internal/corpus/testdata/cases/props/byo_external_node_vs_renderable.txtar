# external byo struct: gsx.Node field is a node-field (promotes via gsx.Val/gsx.Text);
# a field whose type implements Render but is NOT gsx.Node is NOT a node-field
# (assigned directly, never wrapped in gsx.Val). Pins the == gsx.Node semantics
# of loadExternalStructFields (must mirror fieldsFromGsxStruct / isGsxNodeType).
-- props.go --
package views

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

// widget implements Render but is NOT gsx.Node — it is a concrete struct, not
// the gsx.Node interface. A field of type widget must NOT be classified as a
// node-field by loadExternalStructFields.
type widget struct{ label string }

func (w widget) Render(_ context.Context, wr io.Writer) error {
	_, err := wr.Write([]byte("<span>" + w.label + "</span>"))
	return err
}

// cardProps has both a gsx.Node field (Header) and a widget field (Icon).
// Only Header should be a node-field.
type cardProps struct {
	Header gsx.Node
	Icon   widget
	Title  string
}
-- input.gsx --
package views

component Card(p cardProps) {
	<div>{p.Header}{p.Icon}{p.Title}</div>
}

component Page(w widget) {
	<Card header="Hello" icon={w} title="World"/>
}
-- invoke --
Page(widget{label: "star"})
-- diagnostics.golden --
-- render.golden --
<div>Hello<span>star</span>World</div>
