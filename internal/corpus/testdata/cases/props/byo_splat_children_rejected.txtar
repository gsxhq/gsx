# A { x... } splat combined with children on a byo component is a clear error:
# the splat passes the WHOLE prop value; children alongside it are not allowed.
-- input.gsx --
package views

type cardData struct {
	Title string
}

component Card(d cardData) {
	<div>{ d.Title }</div>
}

component Page() {
	data := cardData{Title: "Hello"}
	<Card { data... }>child</Card>
}
-- diagnostics.golden --
13:8: { x... } splat on <Card> passes the whole prop value; remove the other attrs or children
