# author-owns-Props (external struct): the byo Props type is declared in a
# SIBLING .go file (not the .gsx). This exercises the preliminary go/packages
# type-load that enumerates the struct's fields BEFORE the skeleton is built.
-- data.go --
package views

type cardData struct {
	Title string
}
-- input.gsx --
package views

component Card(p cardData) {
	<h2>{ p.Title }</h2>
}

component Page() {
	<Card title="Hi"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<h2>Hi</h2>
-- generated.x.go.golden --
// Code generated by gsx; DO NOT EDIT.

