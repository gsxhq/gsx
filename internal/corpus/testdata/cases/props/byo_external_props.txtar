	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func Card(p cardData) gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:4:2
		_gsxgw.S("<h2>")
//line input.gsx:4:6
		_gsxgw.Text(string(p.Title))
		_gsxgw.S("</h2>")
		return _gsxgw.Err()
	})
}

func Page() gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.Node(ctx, Card(cardData{Title: "Hi"}))
		return _gsxgw.Err()
	})
}
