# An empty { ... } splat on a byo component is a clear error:
# the splat must provide a struct expression to pass as the whole prop value.
-- input.gsx --
package views

type cardData struct {
	Title string
}

component Card(d cardData) {
	<div>{ d.Title }</div>
}

component Page() {
	<Card {...}/>
}
-- diagnostics.golden --
12:8: empty { x... } splat on <Card>; provide the struct expression to splat
