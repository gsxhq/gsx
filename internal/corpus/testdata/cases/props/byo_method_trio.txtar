# byo method trio: Page/Content/Partial on the same receiver all share ONE
# author-declared pageData struct — proves a single author type shared across
# three methods.
#
# component (p home) Page(d pageData)    → func (p home) Page(d pageData) gsx.Node
# component (p home) Content(d pageData) → func (p home) Content(d pageData) gsx.Node
# component (p home) Partial(d pageData) → func (p home) Partial(d pageData) gsx.Node
#
# No homePageProps / homeContentProps / homePartialProps type is generated.
-- input.gsx --
package views

type pageData struct {
	Title   string
	Section string
}

type home struct{}

component (p home) Page(d pageData) {
	<html>
		<body>
			<h1>{ d.Title }</h1>
			<p.Content { d... }/>
		</body>
	</html>
}

component (p home) Content(d pageData) {
	<main>
		<h2>{ d.Title }</h2>
		<p.Partial { d... }/>
	</main>
}

component (p home) Partial(d pageData) {
	<section>{ d.Section }</section>
}
-- invoke --
(home{}).Content(pageData{Title: "Hi", Section: "World"})
-- diagnostics.golden --
-- render.golden --
<main><h2>Hi</h2><section>World</section></main>
