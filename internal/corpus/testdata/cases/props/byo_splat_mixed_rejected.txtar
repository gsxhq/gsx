# A { x... } splat combined with another attr on a byo component is a clear error:
# the splat passes the WHOLE prop value; field overrides are not allowed alongside it.
-- input.gsx --
package views

type cardData struct {
	Title string
}

component Card(d cardData) {
	<div>{ d.Title }</div>
}

component Page() {
	data := cardData{Title: "Hello"}
	<Card { data... } title="x"/>
}
-- diagnostics.golden --
13:8: { x... } splat on <Card> passes the whole prop value; remove the other attrs or children
