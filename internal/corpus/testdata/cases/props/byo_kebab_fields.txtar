# byo kebab→Camel field matching: kebab attr names (full-width, aria-label) bind
# to their CamelCase struct fields (FullWidth, AriaLabel); unmatched kebab attrs
# (data-id) fall through to the Attrs bag as-is.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type Props struct {
	FullWidth bool
	AriaLabel string
	Attrs     gsx.Attrs
}

component Button(p Props) {
	<div>{ p.AriaLabel }</div>
}

component Page() {
	<Button full-width aria-label="Close" data-id="7"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div>Close</div>
