# REDESIGN TARGET: method components pass their single author-struct param THROUGH
# (no per-method wrapper), so Page + Content share ONE author type — the structpages
# Props()/RenderTarget dispatch pattern. Generated: func (p home) Content(d pageData).
-- input.gsx --
package views

type pageData struct{ Title string }
type home struct{}

component (p home) Page(d pageData) {
	<html><body><h1>{ d.Title }</h1></body></html>
}

component (p home) Content(d pageData) {
	<h1>{ d.Title }</h1>
}
-- invoke --
home{}.Content(pageData{Title: "Hi"})
-- diagnostics.golden --
-- render.golden --
<h1>Hi</h1>
