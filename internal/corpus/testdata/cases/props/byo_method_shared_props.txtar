# byo method pass-through: two method components share ONE author-declared struct
# type (pageData) — gsx emits each method with the DIRECT param, no per-method
# <RecvType><Method>Props wrapper.
#
# component (p home) Page(d pageData)    → func (p home) Page(d pageData) gsx.Node
# component (p home) Content(d pageData) → func (p home) Content(d pageData) gsx.Node
#
# structpages dispatch pattern: Props() returns pageData; handler calls Page(pd)
# or Content(pd) — both accept the SAME type, so one Props() suffices.
-- input.gsx --
package views

type pageData struct {
	Title   string
	Heading string
}

type home struct{}

component (p home) Page(d pageData) {
	<html>
		<body>
			<h1>{ d.Title }</h1>
			<p.Content { d... }/>
		</body>
	</html>
}

component (p home) Content(d pageData) {
	<h1>{ d.Heading }</h1>
}
-- invoke --
(home{}).Content(pageData{Title: "Hi", Heading: "Hello"})
-- diagnostics.golden --
-- render.golden --
<h1>Hello</h1>
-- generated.x.go.golden --
