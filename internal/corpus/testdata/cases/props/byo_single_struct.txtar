# REDESIGN TARGET (author-owns-Props): a component whose sole param is an
# author-declared struct uses that struct DIRECTLY (no generated <Name>Props).
# Tag attrs map to the struct's FIELDS; {children} uses an explicit Children field.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type Props struct {
	Variant  string
	Children gsx.Node
}

component Button(p Props) {
	<button class={ "btn", p.Variant }>{ p.Children }</button>
}

component Page() {
	<Button variant="primary">Save</Button>
}
-- invoke --
Page(PageProps{})
-- diagnostics.golden --
-- render.golden --
<button class="btn primary">Save</button>
