# Context: fragment literal passed as a function CALL ARGUMENT, in a
# top-level `var` initializer — mirrors element-literals/call-arg.txtar
# exactly. `wrap` lives in a sibling plain .go file (same package, not
# parsed by the gsx parser) so its `gsx.Node` param type needs no import
# inside the .gsx file itself — only the call-arg fragment literal is under
# test here. The nested `<>…</>` must live in TOP-LEVEL Go-expression
# position (a var decl, reached via GoWithElements' embedded-element scan),
# not inside a component's `{ … }` Interp: an Interp's expression text is
# parsed as plain Go by parsePipe (no embedded-element scanning), so a
# fragment literal nested inside an Interp call argument — e.g.
# `{ wrap(<>...</>) }` directly in a component body — is NOT a supported
# position and fails with "expected operand, found '<'".
-- wrap.go --
package views

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node {
	return n
}
-- input.gsx --
package views

var wrapped = wrap(<><b>x</b></>)

component Uses() {
	<div>{ wrapped }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div><b>x</b></div>
-- generated.x.go.golden --
