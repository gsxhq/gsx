	_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:3:22
	_gsxgw.S("<b>x</b>")
	return _gsxgw.Err()
}))

//line input.gsx:5:1
func Uses() _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:6:2
		_gsxgw.S("<div>")
//line input.gsx:6:7
		_gsxgw.Node(ctx, wrapped)
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
