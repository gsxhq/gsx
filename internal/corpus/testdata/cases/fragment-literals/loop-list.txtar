# Context: fragment literal in a `return` statement whose single child is a
# `{ for … }` control-flow block — the "return a list" driver that fragments
# exist for: an element literal can only ever wrap one tag, but a fragment
# can wrap a `for` loop that emits many top-level siblings. Same
# import/leading-component layout as return.txtar, for the same reason.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Noop() {
	<span/>
}

func Items(xs []string) gsx.Node {
	return <>{ for _, s := range xs { <li>{ s }</li> } }</>
}

component Host() {
	<ul>{ Items([]string{"a", "b"}) }</ul>
}
-- invoke --
Host()
-- diagnostics.golden --
-- render.golden --
<ul><li>a</li><li>b</li></ul>
