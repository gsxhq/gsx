# Context: fragment literal as a struct-literal FIELD value, where the
# field's declared type is gsx.Node. The struct type lives in a sibling
# plain .go file (same package, not parsed by the gsx parser) so the .gsx
# file itself never spells "gsx.Node" — it just builds a slot{...} literal
# whose Body field happens to be a fragment. Mirrors
# element-literals/struct-field.txtar.
-- slot.go --
package views

import "github.com/gsxhq/gsx"

type slot struct {
	Body gsx.Node
}
-- input.gsx --
package views

var s = slot{Body: <><i>hi</i></>}

component Uses() {
	<div>{ s.Body }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div><i>hi</i></div>
-- generated.x.go.golden --
