# Context: fragment child interpolates a function PARAMETER — the
# emit≡probe scope-capture regression for fragments, mirroring
# element-literals/func-local.txtar. A naive probe that hoisted the
# fragment into a separate top-level func would not see `name` and would
# false-`undefined`. analyze.go must lower the embedded fragment to an
# inline scope-capturing IIFE (mirroring emit's inline gsx.Func closure) so
# the interpolation resolves against the surrounding lexical scope. Same
# import/leading-component layout as return.txtar.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Noop() {
	<span/>
}

func Greeting(name string) gsx.Node {
	return <><span>Hello </span><span>{ name }</span></>
}

component Host() {
	{ Greeting("world") }
}
-- invoke --
Host()
-- diagnostics.golden --
-- render.golden --
<span>Hello </span><span>world</span>
