# The intersection the alias-usage gate must PRESERVE: a GoChunk plain-imports a
# package that is ALSO a configured filter package AND the component uses a |>
# filter from it. Both import lines are required — the reserved `_gsxf<i>` alias
# (the lowered `name |> upper` calls `_gsxf0.Upper`) AND the user's own plain
# import (`filters.Label` in Go code). Go permits the same path under two names;
# gating the alias on body usage must NOT drop it here (companion to
# user_plain_import_no_filter, which asserts the alias is dropped when unused).
-- gsx.toml --
filterPackages = ["./filters"]
-- filters/filters.go --
package filters

import "strings"

// Upper is the filter `upper` (lowered as _gsxf0.Upper).
func Upper(s string) string { return strings.ToUpper(s) }

// Label is referenced directly from the GoChunk (a plain user import).
const Label = "hi"
-- input.gsx --
package views

import "corpustest/cases/filterimport_user_plain_import_and_filter/filters"

var label = filters.Label

component Tag(name string) {
	<div>{ label }: { name |> upper }</div>
}
-- invoke --
Tag(TagProps{Name: "bob"})
-- diagnostics.golden --
-- generated.x.go.golden --
