	"context"
	"corpustest/cases/filterimport_user_plain_import_and_filter/filters"
	"io"

	_gsxf0 "corpustest/cases/filterimport_user_plain_import_and_filter/filters"
	"github.com/gsxhq/gsx"
)

var label = filters.Label

type TagProps struct {
	Name string
}

//line input.gsx:7:1
func Tag(_gsxp TagProps) gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		name := _gsxp.Name
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.S("<div>")
//line input.gsx:8:7
		_gsxgw.Text(string(label))
		_gsxgw.S(": ")
//line input.gsx:8:18
		_gsxgw.Text(string(_gsxf0.Upper((name))))
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
-- render.golden --
<div>hi: BOB</div>
