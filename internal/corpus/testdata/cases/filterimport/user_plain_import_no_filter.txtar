# A GoChunk plain-imports a package that gsx.toml ALSO registers as a filter
# package (filter_packages), and the component uses NO |> filter from it. The
# reserved _gsxf<i> alias for that package must NOT be emitted — it would be an
# unused second import of the same path ("imported as _gsxf0 and not used").
# Regression for one-learning ui/once.gsx, whose GoChunk imports structpages
# (a configured filter pkg) for OnceScopeMiddleware while <Once> uses no filter.
# The alias line is only correct when a filter is actually lowered into the body.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "strings"

// Upper is harvested as the filter `upper`; it makes ./filters a filter package
// (so filterAlias has an entry for it), but the component below never uses it.
func Upper(s string) string { return strings.ToUpper(s) }

// Label is a plain exported symbol referenced directly from the GoChunk — this
// forces a user PLAIN import of the filter package, without any filter use.
const Label = "hi"
-- input.gsx --
package views

import "corpustest/cases/filterimport_user_plain_import_no_filter/filters"

var label = filters.Label

component Tag() {
	<div>{ label }</div>
}
-- invoke --
Tag()
-- diagnostics.golden --
-- generated.x.go.golden --
// Code generated by gsx; DO NOT EDIT.

package views

import (
	"corpustest/cases/filterimport_user_plain_import_no_filter/filters"

	_gsxctx "context"
	_gsxrt "github.com/gsxhq/gsx"
	_gsxio "io"
)

//line input.gsx:5:1
var label = filters.Label

//line input.gsx:7:1
func Tag() _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.S("<div>")
//line input.gsx:8:7
		_gsxgw.Text(string(label))
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
-- render.golden --
<div>hi</div>
