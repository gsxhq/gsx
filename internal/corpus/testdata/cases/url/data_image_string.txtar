# URL image sink, Form A with a string hole: unlike the []byte case
# (data_image_bytes.txtar), a string hole after `;base64,` is NOT re-encoded —
# the author already supplies base64 text, so it passes through as a plain
# string conversion before the whole value is assembled and sanitized by
# _gsxgw.URLImage.
-- input.gsx --
package p

component Avatar(b64 string) {
	<img src=f`data:image/png;base64,@{b64}` alt="a" />
}
