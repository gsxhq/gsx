# Hole-less f-literals are wholly constant too: the same always-blocked
# warning fires for a non-image data: MIME on an image sink and for a blocked
# scheme on a navigational sink (a data: literal on a nav sink is already the
# data-url-strict-sink ERROR — javascript: was previously silent).
-- input.gsx --
package p

component Bad() {
	<img src=f`data:application/pdf;base64,AAAA` alt="x"/>
	<a href=f`javascript:alert(1)`>x</a>
}
