# URL image sink, Form A with image/svg+xml and a string hole: SinkImage
# allows svg alongside raster MIMEs (browsers load an <img src> svg in
# restricted mode — no script, no external fetch); the hole is an
# already-base64-encoded string (passthrough, same as data_image_string.txtar)
# and the assembled value renders unblocked, exactly like a raster MIME.
-- input.gsx --
package p

component Icon(svgB64 string) {
	<img src=f`data:image/svg+xml;base64,@{svgB64}` alt="i" />
}
-- invoke --
Icon("PHN2Zy8+")
-- diagnostics.golden --
-- render.golden --
<img src="data:image/svg+xml;base64,PHN2Zy8+" alt="i"/>
