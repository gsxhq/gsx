# Context: element literal in a top-level func's `return` statement, here with a
# leading `component` before the embedding func. `Help`'s explicit `gsx.Node`
# return type needs a real `import "github.com/gsxhq/gsx"`. A leading `import`
# directly before the embedding func (no `component` between) is now handled —
# the parser peels leading imports into their own GoChunk so they hoist normally
# (see element-literals/import-then-embed for that arrangement). This case pins
# the component-first ordering, which stays valid and exercises the same lowering.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Noop() {
	<span/>
}

func Help() gsx.Node {
	return <div>hi</div>
}
-- invoke --
Help()
-- diagnostics.golden --
-- render.golden --
<div>hi</div>
