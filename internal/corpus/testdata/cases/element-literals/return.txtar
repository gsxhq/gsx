# Context: element literal in a top-level func's `return` statement. `Help`'s
# explicit `gsx.Node` return type means this file needs a real `import
# "github.com/gsxhq/gsx"` — which must sit in its OWN top-level Go chunk,
# ahead of a `component` boundary, rather than sharing a chunk with `Help`:
# analyze.go's GoWithElements skeleton probe writes its synthesized probe
# funcs before the chunk's own reconstructed text, so a user `import` living
# in the SAME chunk as an embedded element ends up after those probe funcs
# ("imports must appear before other declarations") — a documented, accepted
# limitation (see analyze.go's GoWithElements comment). A leading component
# forces the split, which is also how real code would be structured anyway.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Noop() {
	<span/>
}

func Help() gsx.Node {
	return <div>hi</div>
}
-- invoke --
Help()
-- diagnostics.golden --
-- render.golden --
<div>hi</div>
-- generated.x.go.golden --
