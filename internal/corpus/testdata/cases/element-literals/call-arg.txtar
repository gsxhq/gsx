# Context: element literal passed as a function CALL ARGUMENT — the
# structpages/RenderComponent shape (`RenderComponent(<Foo .../>)`). `Wrap`
# lives in a sibling plain .go file (same package, not parsed by the gsx
# parser) so its `gsx.Node` param type needs no import inside the .gsx file
# itself — only the call-arg element literal is under test here.
-- wrap.go --
package demo

import "github.com/gsxhq/gsx"

func Wrap(n gsx.Node) gsx.Node {
	return n
}
-- input.gsx --
package demo

component Foo() {
	<p>Foo body</p>
}

var wrapped = Wrap(<Foo/>)

component Uses() {
	<div>{ wrapped }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div><p>Foo body</p></div>
