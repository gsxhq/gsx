# Context: element literal as a struct-literal FIELD value, where the field's
# declared type is gsx.Node. The struct type lives in a sibling plain .go file
# (same package, not parsed by the gsx parser) so the .gsx file itself never
# spells "gsx.Node" — it just builds a NavItem{...} literal whose Icon field
# happens to be an element.
-- nav.go --
package demo

import "github.com/gsxhq/gsx"

type NavItem struct {
	Label string
	Icon  gsx.Node
}
-- input.gsx --
package demo

var item = NavItem{Label: "Home", Icon: <svg class="w-5 h-5">
	<path d="M0 0"/>
</svg>}

component Uses() {
	<div>{ item.Label }{ item.Icon }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div>Home<svg class="w-5 h-5"><path d="M0 0"/></svg></div>
