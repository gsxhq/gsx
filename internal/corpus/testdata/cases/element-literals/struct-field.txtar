	_gsxgw := gsx.W(_gsxw)
//line input.gsx:4:2
	_gsxgw.S("<svg class=\"w-5 h-5\">")
//line input.gsx:5:3
	_gsxgw.S("<path d=\"M0 0\"/></svg>")
	return _gsxgw.Err()
})}

//line input.gsx:9:1
func Uses() gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:10:2
		_gsxgw.S("<div>")
//line input.gsx:10:7
		_gsxgw.Text(string(item.Label))
//line input.gsx:10:21
		_gsxgw.Node(ctx, item.Icon)
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
