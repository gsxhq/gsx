# Context: a text child containing an apostrophe AND a sibling element
# literal in the SAME top-level Go region — exercises Task 1's prose-scanning
# fix end to end. scanGoElementMarks resumes plain go/scanner tokenization
# past each element's span; before the fix, a lone apostrophe inside an
# element's text body (`it's`) would be lexed as an unterminated rune literal
# by the RESUMED scan and run to EOF, swallowing the later `<b>` mark
# entirely. Pins that both elements still parse/generate/render correctly.
-- input.gsx --
package demo

var a = <p>it's here</p>
var b = <b>bold</b>

component Uses() {
	<div>{ a }{ b }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div><p>it's here</p><b>bold</b></div>
-- generated.x.go.golden --
