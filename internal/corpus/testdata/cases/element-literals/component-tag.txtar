# Context: a COMPONENT tag (not an HTML tag) in expression position with a
# typed prop — `<Badge count={12}/>` — confirms the element literal lowers to
# the ordinary component call-site (`Badge(BadgeProps{Count: 12})`), the same
# lowering a component body's child tags already use, not some special-cased
# path for the expression-position case.
-- input.gsx --
package demo

component Badge(count int) {
	<span class="badge">{ count }</span>
}

var badge = <Badge count={12}/>

component Uses() {
	<div>{ badge }</div>
}
