# Context: element literal whose interpolations reference OUTER (package)
# scope identifiers — an attr expr `{ cls }` and a child interp `{ label }`,
# both package-level vars declared before the element. Exercises Task 5's
# buildSkeleton walk of *ast.GoWithElements: the embedded element's
# interpolations must type-check against ordinary package scope (there is no
# component/_gsxp/attrs machinery here), and the emitted closure must
# reference the identifiers verbatim (ordinary Go closure capture), not
# rebind them through any component-scope mechanism.
-- input.gsx --
package demo

var cls = "text-lg"
var label = "Home"

var help = <span class={ cls }>{ label }</span>

component Uses() {
	<div>{ help }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div><span class="text-lg">Home</span></div>
-- generated.x.go.golden --
