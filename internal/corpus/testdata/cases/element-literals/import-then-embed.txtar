# Context: a top-level func that RETURNS an element literal sits directly after
# the file's `import`, with NO leading `component` between them. The func's
# `gsx.Node` return type needs a real `import "github.com/gsxhq/gsx"`. This is
# the case that used to fail: the imports and the embedding func form one Go
# region, so the whole thing became a single GoWithElements whose GoText parts —
# including the `import` — are spliced after the skeleton's/output's synthesized
# declarations ("imports must appear before other declarations"). The parser now
# peels a leading run of import declarations into their own GoChunk (see
# parser/goexpr.go leadingImportEnd), so the imports are hoisted into the file's
# import block by the normal GoChunk path and the func region no longer traps
# them — a leading `component` workaround (cf. return.txtar) is no longer needed.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func render() gsx.Node {
	return <div>inline JSX</div>
}

component Index() {
	<section>{ render() }</section>
}
-- invoke --
Index()
-- diagnostics.golden --
-- render.golden --
<section><div>inline JSX</div></section>
-- generated.x.go.golden --
// Code generated by gsx; DO NOT EDIT.

package demo

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func render() gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:6:9
		_gsxgw.S("<div>inline JSX</div>")
		return _gsxgw.Err()
	})
}

//line input.gsx:9:1
func Index() gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:10:2
		_gsxgw.S("<section>")
//line input.gsx:10:11
		_gsxgw.Node(ctx, render())
		_gsxgw.S("</section>")
		return _gsxgw.Err()
	})
}
