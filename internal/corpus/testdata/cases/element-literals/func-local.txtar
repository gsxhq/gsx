# Context: element literal inside a top-level func BODY that interpolates the
# func's PARAMETER (`name`) AND a LOCAL variable (`greeting`). This is the
# final-review CRITICAL repro: a naive probe that hoists the element into a
# separate top-level func would not see `name`/`greeting` and would false-
# `undefined`. analyze.go lowers the embedded element to an inline scope-
# capturing IIFE (mirroring emit's inline gsx.Func closure), so the
# interpolations resolve against the surrounding lexical scope. `Greeting`'s
# `gsx.Node` return type needs a real gsx import; the leading `component` here is
# one valid arrangement (a leading import directly before the func is also fine
# now — see element-literals/import-then-embed).
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Noop() {
	<span/>
}

func Greeting(name string) gsx.Node {
	greeting := "Hi, " + name
	return <div>{ greeting } ({ name })</div>
}
-- invoke --
Greeting("Ada")
-- diagnostics.golden --
-- render.golden --
<div>Hi, Ada (Ada)</div>
