# Context: an element literal whose prose body contains the bare word
# "component" — a gsx keyword, but here just English text. The file-level scan
# that locates top-level `component` declarations tokenizes the Go gaps with
# go/scanner; before the fix it lexed element prose as Go, matched this word as
# an IDENT at brace depth 0, and split the file mid-<p> (yielding "unexpected
# EOF, expected </p>" then "expected component name"). Pins that the word
# survives as text in BOTH a multi-line var literal and a function-local
# literal (brace depth > 0), and that the real `component` decl below is still
# found. `gsx.Node` needs a real import here, as in func-local.txtar.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

var X = (
	<div>
		<h1>Test</h1>
		<p>This is a test component.</p>
	</div>
)

func local() gsx.Node {
	n := <em>another component</em>
	return n
}

component Uses() {
	<section>{ X }{ local() }</section>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<section><div><h1>Test</h1><p>This is a test component.</p></div><em>another component</em></section>
