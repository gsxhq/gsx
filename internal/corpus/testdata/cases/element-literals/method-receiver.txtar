# Context: element literal inside a top-level METHOD body that interpolates
# the method's RECEIVER (`p.Name`). Same emit≡probe scope-capture fix as
# func-local, for a receiver: the inline IIFE captures `p` from the enclosing
# method scope, so `{ p.Name }` type-checks and renders. (This is a plain Go
# method whose body returns an embedded element — not a gsx `component` — so
# the element goes through the GoWithElements path.) The gsx import sits in
# its own chunk ahead of the `component Noop` boundary, per return.txtar.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Noop() {
	<span/>
}

type Person struct {
	Name string
}

func (p Person) Greeting() gsx.Node {
	return <div>Hello, { p.Name }!</div>
}
-- invoke --
Person{Name: "Ada"}.Greeting()
-- diagnostics.golden --
-- render.golden --
<div>Hello, Ada!</div>
-- generated.x.go.golden --
