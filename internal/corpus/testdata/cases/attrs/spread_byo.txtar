# A composite value is forwarded to an ordinary parameter by exact name.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type props struct {
  label gsx.Node
}
var items = []props{{label: <p>x</p>}}

component C(p props) { <div>{p.label}</div> }
component page() {
  { for _, item := range items {
    <C p={item} />
  } }
}

-- invoke --
page()
-- diagnostics.golden --
-- render.golden --
<div><p>x</p></div>
