# Two (T, error) attrs on a NESTED element (not the component root, so no Attrs
# fallthrough guard): both unwraps land in ONE flat block, exercising the reuse of
# the `_gsxerr` name across consecutive `:=` (legal Go — each `_gsxvN` is fresh).
-- input.gsx --
package views

func href(id string) (string, error)  { return "/u/" + id, nil }
func label(id string) (string, error) { return "user " + id, nil }

component Card(id string) {
	<div>
		<a href={ href(id) } title={ label(id) }>profile</a>
	</div>
}
-- invoke --
Card(CardProps{Id: "7"})
-- diagnostics.golden --
-- render.golden --
<div><a href="/u/7" title="user 7">profile</a></div>
