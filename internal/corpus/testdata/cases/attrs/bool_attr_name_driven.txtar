# The attribute NAME decides presence-vs-value for a bool-typed value, with no
# annotation. A boolean attribute (checked, required, disabled, hidden, download)
# toggles; anything else (aria-*, data-*, contenteditable) stringifies to
# "true"/"false", because for those the string IS the state. gsx.Toggle forces
# presence on a name the spec cannot know. A bare attribute is an explicit
# presence declaration and always toggles.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Page(on bool) {
	<input required={on} />
	<input checked={on} />
	<div hidden={on}>h</div>
	<div aria-expanded={on}>a</div>
	<div data-open={on}>d</div>
	<div contenteditable={on}>c</div>
	<my-toggle active={gsx.Toggle(on)}>t</my-toggle>
	<input required />
}
-- invoke --
Page(true)
-- diagnostics.golden --
-- render.golden --
<input required><input checked><div hidden>h</div><div aria-expanded="true">a</div><div data-open="true">d</div><div contenteditable="true">c</div><my-toggle active>t</my-toggle><input required>
