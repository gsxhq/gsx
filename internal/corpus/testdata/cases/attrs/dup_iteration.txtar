# Call-site bags concatenate; a component iterating its implicit attrs bag sees
# duplicates (within the documented duplicate-tolerant contract). The base attr
# a="1" and the { extra... } spread each contribute an "a" entry, so
# len(attrs) counts both (data-n="2"); Get resolves last-wins, returning the
# spread's "2".
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component EchoLen(attrs gsx.Attrs) {
	{{ v, _ := attrs.Get("a"); s, _ := v.(string) }}
	<div data-n={len(attrs)}>{s}</div>
}

component Page(extra gsx.Attrs) {
	<EchoLen a="1" { extra... }/>
}
-- invoke --
Page(gsx.Attrs{{Key: "a", Value: "2"}})
