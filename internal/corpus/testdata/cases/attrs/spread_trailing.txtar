# trailing-dots spread: { expr... } is the Go-convention spread syntax
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component C(extra gsx.Attrs) { <div { extra... }>x</div> }
-- invoke --
C(gsx.Attrs{{Key: "id", Value: "m"}})
-- diagnostics.golden --
-- render.golden --
<div id="m">x</div>
