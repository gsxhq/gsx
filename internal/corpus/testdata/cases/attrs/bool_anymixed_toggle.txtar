# A mixed type parameter (T string | bool) on a boolean-attribute name is correct
# at BOTH instantiations with no annotation: codegen resolves the name to a
# boolean attribute at generate time and emits AttrAnyToggle, which decides at
# runtime — a bool toggles, a string renders name="value". This is the one case
# the value's kind is genuinely unknown until runtime.
-- input.gsx --
package views

component Field[T string | bool](required T) {
	<input required={required} />
}

component Page() {
	<Field[bool] required={true} />
	<Field[bool] required={false} />
	<Field[string] required={"foo"} />
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<input required><input><input required="foo">
