# W3: a nested f`` literal inside a js`` attribute literal's @{ } hole. The
# inner f` lowers to a plain Go string concat, which the outer JS-value hole
# then JS-escapes (EscapeJSVal) exactly as any other string. Pins the js-attr
# context of nested-literal-in-hole assembly.
-- input.gsx --
package demo

component Page(who string) {
	<button onclick=js`f(@{ f`id-@{who}` })`>x</button>
}
-- invoke --
Page("Ada")
-- diagnostics.golden --
-- render.golden --
<button onclick="f(&#34;id-Ada&#34;)">x</button>
