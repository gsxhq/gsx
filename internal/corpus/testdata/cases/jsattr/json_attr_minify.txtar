# JSON-shaped js`` attribute values (htmx hx-vals, parsed via JSON.parse) stay
# valid JSON under minification — holeless AND holey — while a non-JSON
# js`` control (Alpine x-data) is unaffected. The corpus runs codegen's
# built-in safe minify pass (JSMinify: true, JSMin/JSONMin nil — see
# internal/corpus/codegen.go); at this level JSON-shaped values are left
# valid-but-unminified (looksJSON only cascades to the JSON minifier when
# m.JSON != nil, i.e. FULL level — see internal/jsmin/file.go). Full-level
# compaction is pinned separately in internal/codegen/minify_thread_test.go.
-- input.gsx --
package views

component C(selfID string) {
	<div hx-vals=js`{ "exclude": "SELF-1" }`></div>
	<div hx-vals=js`{ "exclude": @{selfID} }`></div>
	<div x-data=js`{ open: false }`></div>
}
-- invoke --
C("child-2")
