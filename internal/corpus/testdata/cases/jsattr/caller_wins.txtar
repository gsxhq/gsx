-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Panel(tab string, attrs gsx.Attrs) {
	<div x-data="{ tab: @{ tab } }" { attrs... }>slot</div>
}
-- invoke --
Panel("home", gsx.Attrs{{Key: "x-data", Value: "OVERRIDE"}})
-- diagnostics.golden --
-- render.golden --
<div x-data="OVERRIDE">slot</div>
