# explicit JS attr literal in a conditional attr branch is resolved and emitted
-- input.gsx --
package p
component Button(active bool, id string) {
	<button { if active { @click=js`save(@{id})` } }>Save</button>
}
-- input.go --
package p
import "github.com/gsxhq/gsx"
func Render() gsx.Node { return Button(true, "abc") }
-- render.golden --
<button @click="save(&#34;abc&#34;)">Save</button>
-- diagnostics.golden --
