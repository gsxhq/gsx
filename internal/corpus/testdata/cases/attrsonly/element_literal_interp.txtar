# Regression: an attrs-only tag inside an element-literal Go-expression
# (var initializer) must not mis-type the OTHER interps in the same literal. The
# bag keep-alive is alignment-neutral, so {count} (an int) inside the same <div>
# literal keeps its int type instead of being harvested as the bag's gsx.Attrs
# (which previously miscompiled it to string(count), a rune conversion).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type iconProps struct {
	Name  string
	Attrs gsx.Attrs
}

component renderIcon(p iconProps) {
	<svg { p.Attrs... }>{p.Name}</svg>
}

func icon(name string) func(gsx.Attrs) gsx.Node {
	return func(attrs gsx.Attrs) gsx.Node {
		return renderIcon(iconProps{Name: name, Attrs: attrs})
	}
}

var Home = icon("home")

func wrap(n gsx.Node) gsx.Node { return n }

var cls = "c"
var count = 3

var panel = wrap(<div><Home class={cls}/><b>{count}</b></div>)

component Page() {
	<div>{ panel }</div>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div><div><svg class="c">home</svg><b>3</b></div></div>
