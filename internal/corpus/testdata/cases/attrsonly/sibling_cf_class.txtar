# Regression for #69: two sibling component-value tags whose static callable
# signatures publish the reserved `attrs` role, each carrying a value-form
# CF class part. The positional attrs plan hoists a
# `_gsxvN` var+if into the SHARED skeleton function. A per-tag counter reset made
# both emit `_gsxv0` → `_gsxv0 redeclared in this block`. The per-skeleton-function
# counter keeps them unique.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type iconProps struct {
	Attrs gsx.Attrs
}

component renderIcon(p iconProps) {
	<svg { p.Attrs... }>i</svg>
}

component Page(on bool) {
	<div>
		<HomeIcon class={ if on { "a" } else { "b" } }/>
		<HomeIcon class={ if on { "a" } else { "b" } }/>
	</div>
}
-- icons.go --
package views

import "github.com/gsxhq/gsx"

var HomeIcon = func(attrs gsx.Attrs) gsx.Node {
	return renderIcon(iconProps{Attrs: attrs})
}
-- invoke --
Page(true)
