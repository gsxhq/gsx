# An attrs-only component value uses one source-ordered plan across ordinary
# fallthrough entries and an ordered-attrs tuple pair. Failure at the pair must
# preserve the earlier call and prevent the later call.
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

var calls []string

func mark(label, value string) string {
	calls = append(calls, label)
	return value
}

func markPair(label, value string, fail bool) (string, error) {
	calls = append(calls, label)
	if fail {
		return "", fmt.Errorf("%s failed", label)
	}
	return value, nil
}

func checkedAttrsOnlyOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		calls = nil
		if err := Page(false).Render(ctx, io.Discard); err != nil {
			return fmt.Errorf("successful render: %w", err)
		}
		if got := strings.Join(calls, ","); got != "first,pair,last" {
			return fmt.Errorf("successful evaluation order = %s, want first,pair,last", got)
		}

		calls = nil
		err := Page(true).Render(ctx, io.Discard)
		if err == nil || err.Error() != "pair failed" {
			return fmt.Errorf("failed render error = %v, want pair failed", err)
		}
		if got := strings.Join(calls, ","); got != "first,pair" {
			return fmt.Errorf("failed evaluation order = %s, want first,pair", got)
		}
		return nil
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type chipProps struct { Attrs gsx.Attrs }

component renderChip(p chipProps) { <span { p.Attrs... }>chip</span> }

func Chip(attrs ...gsx.Attr) gsx.Node {
	return renderChip(chipProps{Attrs: gsx.Attrs(attrs)})
}

component Page(fail bool) {
	<Chip
		data-first={mark("first", "A")}
		attrs={{ "data-pair": markPair("pair", "P", fail) }}
		data-last={mark("last", "Z")}
	/>
}
-- invoke --
checkedAttrsOnlyOrder()
