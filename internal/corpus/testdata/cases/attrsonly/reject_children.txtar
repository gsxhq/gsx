# A component value whose signature declares only `attrs` has no `children`
# role: passing children to Chip is a clean error.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type chipProps struct {
	Attrs gsx.Attrs
}

component renderChip(p chipProps) {
	<span { p.Attrs... }>chip</span>
}

func Chip(attrs ...gsx.Attr) gsx.Node {
	return renderChip(chipProps{Attrs: gsx.Attrs(attrs)})
}

component Page() {
	<Chip>text</Chip>
}
-- diagnostics.golden --
18:2: Chip has no children param; component body cannot be passed
