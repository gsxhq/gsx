# Regression: two attrs-only tags with INTERPOLATED attr values must not desync
# the positional interp-type harvest. The attrs-only bag rides an
# alignment-NEUTRAL keep-alive (_gsxusen), so the trailing {n} (an int) keeps its
# real type instead of being mis-harvested as the bag's gsx.Attrs. Distinct-typed
# interps around and between the two <Home class={label}/> tags pin that every
# slot stays aligned.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type iconProps struct {
	Name  string
	Attrs gsx.Attrs
}

component renderIcon(p iconProps) {
	<svg { p.Attrs... }>{p.Name}</svg>
}

func icon(name string) func(gsx.Attrs) gsx.Node {
	return func(attrs gsx.Attrs) gsx.Node {
		return renderIcon(iconProps{Name: name, Attrs: attrs})
	}
}

var Home = icon("home")

component Widget(label string, n int) {
	<div>
		<span>{label}</span>
		<Home class={label}/>
		<Home class={label}/>
		<b>{n}</b>
	</div>
}

component Page() {
	<Widget label="hi" n={7}/>
}
-- invoke --
Page()
