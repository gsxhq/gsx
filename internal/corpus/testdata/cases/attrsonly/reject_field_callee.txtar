# A dotted tag whose qualifier is not a package import — here a component
# parameter (item holder) — is not treated as a package-level component.
# Function-valued fields remain unsupported component targets.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type holder struct {
	Icon func(gsx.Attrs) gsx.Node
}

component Page(item holder) {
	<item.Icon class="x"/>
}
-- diagnostics.golden --
10:3: component target is a function-valued field; only package function variables and concrete bound methods are supported
