# An instantiated generic named func type is a valid component value when its
# static signature publishes the reserved `attrs` role:
# `type C[T any] func(attrs ...gsx.Attr) gsx.Node` + `var Y C[int]` has a static type
# whose underlying — after type-arg substitution — is exactly
# func(attrs ...gsx.Attr) gsx.Node after substitution. This
# is a concrete VALUE, not a generic API: the type params are already bound, and
# signature has no remaining type parameters. Uninstantiated generics cannot be
# expressed as values and remain rejected naturally.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type iconProps struct {
	Name  string
	Attrs gsx.Attrs
}

component renderIcon(p iconProps) {
	<svg { p.Attrs... }>{p.Name}</svg>
}

type Component[T any] func(attrs ...gsx.Attr) gsx.Node

var Y Component[int] = func(attrs ...gsx.Attr) gsx.Node {
	return renderIcon(iconProps{Name: "y", Attrs: gsx.Attrs(attrs)})
}

component Page() {
	<Y class="c"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<svg class="c">y</svg>
