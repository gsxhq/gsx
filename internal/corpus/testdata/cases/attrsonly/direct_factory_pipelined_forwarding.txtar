# A PIPELINED spread whose final stage yields methodless []gsx.Attr goes
# through lowerPipe, then the same spread-boundary conversion: the lowered
# filter call is wrapped in _gsxrt.Attrs(...) and hoisted once.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "github.com/gsxhq/gsx"

// WithoutKey is the filter `withoutKey`; it deliberately returns the
// methodless []gsx.Attr form.
func WithoutKey(attrs []gsx.Attr, key string) []gsx.Attr {
	var out []gsx.Attr
	for _, a := range attrs {
		if a.Key != key {
			out = append(out, a)
		}
	}
	return out
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func named(name string) func(...gsx.Attr) gsx.Node {
	return func(attrs ...gsx.Attr) gsx.Node {
		return <svg stroke-width="2" class="size-5" { attrs |> withoutKey("id")... }>{ name }</svg>
	}
}

var Search = named("search")

component Page() {
	<Search id="gone" stroke-width="3" class="size-4"/>
}
-- invoke --
Page()
-- diagnostics.golden --
14:10: Search has no attrs param; unexpected attribute "id"
14:20: Search has no attrs param; unexpected attribute "stroke-width"
14:37: Search has no attrs param; unexpected attribute "class"
-- generated.x.go.golden --
-- render.golden --
