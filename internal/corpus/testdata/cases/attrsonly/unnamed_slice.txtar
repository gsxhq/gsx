# attrs-only component value: package-level func with the unnamed-slice
# signature func([]gsx.Attr) gsx.Node — accepted (spec: "The unnamed-slice
# shape — initially excluded, then accepted", docs/superpowers/specs/2026-07-
# 07-attrs-only-component-values-design.md). gsx.Attrs is assignable to
# []gsx.Attr (identical underlying, one side unnamed), so this shape emits the
# same F(bag) / F(nil) convention as the named-gsx.Attrs shape. Zero-attr call
# must emit Badge(nil) — pinned in generated.x.go.golden.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type badgeProps struct {
	Attrs gsx.Attrs
}

component renderBadge(p badgeProps) {
	<span { p.Attrs... }>badge</span>
}

func Badge(attrs []gsx.Attr) gsx.Node {
	return renderBadge(badgeProps{Attrs: gsx.Attrs(attrs)})
}

component Page() {
	<div>
		<Badge class="b"/>
		<Badge/>
	</div>
}
-- invoke --
Page()
