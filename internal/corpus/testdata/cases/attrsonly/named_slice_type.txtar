# func(myAttrs) gsx.Node, where myAttrs is a user-defined named type with
# underlying []gsx.Attr, IS tag-callable (spec: docs/superpowers/specs/2026-07-
# 07-attrs-only-component-values-design.md — the named-type restriction was
# dropped once the emitter learned to wrap the call-site bag in a []gsx.Attr
# conversion). gsx.Attrs is not assignable to myAttrs directly (two distinct
# named types), so the emitter converts: Badge([]gsx.Attr(gsx.Attrs{...})) —
# []gsx.Attr assigns to any named type sharing that underlying, one side
# unnamed, the same rule Go's assignability check applies. Pins that
# conversion in generated.x.go.golden. Zero-attr call still emits Badge(nil) —
# nil assigns to any slice type with no conversion needed.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type myAttrs []gsx.Attr

type badgeProps struct {
	Attrs gsx.Attrs
}

component renderBadge(p badgeProps) {
	<span { p.Attrs... }>badge</span>
}

var Badge = func(a myAttrs) gsx.Node {
	return renderBadge(badgeProps{Attrs: gsx.Attrs(a)})
}

component Page() {
	<div>
		<Badge class="b"/>
		<Badge/>
	</div>
}
-- invoke --
Page()
-- diagnostics.golden --
21:10: Badge has no attrs param; unexpected attribute "class"
-- render.golden --
-- generated.x.go.golden --
