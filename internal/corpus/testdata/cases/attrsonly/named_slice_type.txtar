# Differently named bag-shaped parameters are ordinary exact-name props. A
# defined myAttrs value binds `a`; gsx does not reinterpret or convert it into
# the reserved fallthrough role. The sibling `someAttrs gsx.Attrs` call proves
# ordered-literal syntax remains available to an ordinary canonical-bag prop.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type myAttrs []gsx.Attr

type badgeProps struct {
	Attrs gsx.Attrs
}

component renderBadge(p badgeProps) {
	<span { p.Attrs... }>badge</span>
}

var Badge = func(a myAttrs) gsx.Node {
	return renderBadge(badgeProps{Attrs: gsx.Attrs(a)})
}

var Canonical = func(someAttrs gsx.Attrs) gsx.Node {
	return renderBadge(badgeProps{Attrs: someAttrs})
}

component Page() {
	<div>
		<Badge a={myAttrs{{Key: "class", Value: "b"}}}/>
		<Badge/>
		<Canonical someAttrs={{ "class": "c" }}/>
	</div>
}
-- invoke --
Page()
