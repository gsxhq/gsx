# A dotted tag whose package-like qualifier is shadowed by a same-named
# parameter must resolve according to Go scope. It is a function-valued field,
# not the imported package's component, and is rejected accordingly.
-- go.mod --
module example.com/app

go 1.26.1
-- ui/other.gsx --
package ui

component Other() { <i>other</i> }
-- pages/home.gsx --
package pages

import (
	"github.com/gsxhq/gsx"
	"example.com/app/ui"
)

type holder struct {
	Icon func(gsx.Attrs) gsx.Node
}

var _ = ui.Other

component Widget(ui holder) {
	<ui.Icon class="x"/>
}
-- diagnostics.golden --
15:3: component target is a function-valued field; only package function variables and concrete bound methods are supported
