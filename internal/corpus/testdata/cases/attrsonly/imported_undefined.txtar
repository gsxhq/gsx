# Cross-package attrs-only: a dotted tag <ui.NopeIcon/> whose qualifier IS a
# known gsx import but whose selector names nothing in that package. The tag is
# gated onto the _gsxcompsig(ui.NopeIcon) probe (isDepAlias("ui") holds, no
# ui.NopeIconProps type exists), and go/types reports the undefined selector at
# the TRUE source column of the selector in pages/home.gsx — pinning that the
# _gsxcompsig probe's mid-expression //line anchor maps the interior token back
# to the real .gsx position, not a generated one.
-- go.mod --
module example.com/app

go 1.26.1
-- ui/icons.gsx --
package ui

import "github.com/gsxhq/gsx"

type iconProps struct {
	Name  string
	Attrs gsx.Attrs
}

component renderIcon(p iconProps) {
	<svg { p.Attrs... }>{p.Name}</svg>
}

func namedIcon(name string) func(gsx.Attrs) gsx.Node {
	return func(attrs gsx.Attrs) gsx.Node {
		return renderIcon(iconProps{Name: name, Attrs: attrs})
	}
}

var HomeIcon = namedIcon("house")
-- pages/home.gsx --
package pages

import "example.com/app/ui"

component Home() {
	<ui.NopeIcon class="h-3 w-3"/>
}
-- diagnostics.golden --
6:6: undefined: ui.NopeIcon
