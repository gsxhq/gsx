# A named `a []myAttr` parameter is an ordinary exact-name prop. It does not
# declare the reserved `attrs` role, so the unmatched `class` input receives the
# strict missing-attrs diagnostic regardless of the slice's element shape.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type myAttr gsx.Attr

var Bad = func(a []myAttr) gsx.Node { return nil }

component Page() {
	<Bad class="x"/>
}
-- diagnostics.golden --
10:7: Bad has no attrs param; unexpected attribute "class"
