# func([]myAttr) gsx.Node, where myAttr is a user-defined named type sharing
# gsx.Attr's underlying (but NOT gsx.Attr itself), is NOT tag-callable: the
# named-type restriction dropped for the SLICE (see named_slice_type.txtar)
# never applied to the ELEMENT — slice conversions require identical element
# types, not merely identical underlying element types, so a []gsx.Attr(bag)
# conversion against a []myAttr parameter would not compile. Pins the updated
# structural diagnostic wording.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type myAttr gsx.Attr

var Bad = func(a []myAttr) gsx.Node { return nil }

component Page() {
	<Bad class="x"/>
}
-- diagnostics.golden --
10:2: <Bad> is not tag-callable: its type is func(a []myAttr) gsx.Node, not a component-value signature (one parameter with underlying type []gsx.Attr, result gsx.Node), and no BadProps struct was found
