# Uniform scope: a gsx.RawJS hole is admitted in ANY binding position, not only
# an assignment target — here a member name (obj.@{…}) and a declaration name
# (let @{…}). Both defer to JSCtxBinding and splice verbatim because the holes
# are gsx.RawJS.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Page(prop string, name string) {
	{{
		a := gsx.Attrs{
			{Key: "@click", Value: js`obj.@{gsx.RawJS(prop)} = 1; let @{gsx.RawJS(name)} = 2;`},
		}
	}}
	<button {a...}>x</button>
}
-- invoke --
Page(PageProps{Prop: "bar", Name: "y"})
-- diagnostics.golden --
-- render.golden --
<button @click="obj.bar = 1; let y = 2;">x</button>
