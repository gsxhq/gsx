# A function whose body returns a js`…` literal typed gsx.RawJS. The func lives
# in the .gsx file (js`…` is gsx syntax, not Go), so it rides in a top-level
# GoWithElements region; jsx.ResolveScripts classifies the @{id} hole there.
# The signature references gsx.RawJS, so the SOURCE file imports gsx while the
# GENERATED escaper calls use the reserved _gsxrt alias for the SAME path — both
# import lines coexist (PR #52 alias need-tracking). Contrast var.txtar, whose
# source has NO gsx reference and only the generated _gsxrt import.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mk(id string) gsx.RawJS {
	return js`open(@{id})`
}

component Page(id string) {
	<button @click={mk(id)}>Open</button>
}
-- invoke --
Page(PageProps{Id: "abc"})
-- diagnostics.golden --
-- render.golden --
<button @click="open(&#34;abc&#34;)">Open</button>
