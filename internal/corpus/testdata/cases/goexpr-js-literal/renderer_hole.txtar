# Expression-position js`…`/css`…` literals (a Go-expression literal used in a
# func-return position — see func_return.txtar — NOT the attr-local
# EmbeddedAttr form pinned by renderers/js_attr_hole.txtar and
# renderers/css_attr_hole.txtar) whose hole's type has a registered
# [renderers] entry. embeddedHoleExpr's applyRenderer call (already wired for
# exprPos, see diag_error_renderer.txtar's third-rejection-shape comment)
# fires BEFORE the JS-string/CSS-value filter: the renderer's plain string
# result is the thing that gets EscapeJSStr'd / FilterCSS'd, exactly as any
# hand-written string would be — pinned by _gsxf<i>.PgJS((val)) inside
# EscapeJSStr(...) and _gsxf<j>.PgColor((val)) inside FilterCSS(...) in the
# generated golden. The CSS hole is invoked with the same hostile value
# renderers/css_attr_hole.txtar uses (@import url(...)), so its ZgotmplZ
# failsafe fires through the renderer here too. The CSS-side error-returning
# renderer diagnostic (the third rejection shape, JS side already pinned by
# diag_error_renderer.txtar) is pinned separately in
# goexpr-css-literal/diag_error_renderer.txtar — a diagnostic aborts the
# whole package's codegen, so it cannot share this renderable case.
-- gsx.toml --
[renderers]
"./pg.JSVal" = "./rend.PgJS"
"./pg.CSSVal" = "./rend.PgColor"
-- pg/pg.go --
package pg

type JSVal struct {
	String string
	Valid  bool
}

type CSSVal struct {
	String string
	Valid  bool
}
-- rend/rend.go --
package rend

import "corpustest/cases/goexpr-js-literal_renderer_hole/pg"

func PgJS(t pg.JSVal) string {
	if !t.Valid {
		return ""
	}
	return t.String
}

func PgColor(t pg.CSSVal) string {
	if !t.Valid {
		return ""
	}
	return t.String
}
-- input.gsx --
package views

import (
	"corpustest/cases/goexpr-js-literal_renderer_hole/pg"
	"github.com/gsxhq/gsx"
)

func mkJSVal(s string, valid bool) pg.JSVal   { return pg.JSVal{String: s, Valid: valid} }
func mkCSSVal(s string, valid bool) pg.CSSVal { return pg.CSSVal{String: s, Valid: valid} }

func mkClick(val pg.JSVal) gsx.RawJS {
	return js`save('@{ val }')`
}

func mkColor(val pg.CSSVal) gsx.RawCSS {
	return css`color:@{ val }`
}

component Tag(j pg.JSVal, c pg.CSSVal) {
	<button @click={mkClick(j)}>x</button>
	<div style={mkColor(c)}>y</div>
}
-- invoke --
Tag(TagProps{J: mkJSVal("</script>", true), C: mkCSSVal("@import url(evil.css)", true)})
-- diagnostics.golden --
