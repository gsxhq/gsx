# W2 differential-equivalence pin: the SAME error-carrying js`save('@{id |>
# parse}')` literal (a JSCtxString hole, hostile id) lowered TWO different
# ways must render the byte-identical `onclick` attribute value —
# correctness-first's "two lowerings, one pinned behavior":
#   (1) attribute-local EmbeddedAttr (onclick=js`…`) — the fold path an
#       attribute-local literal has always used; error holes here already
#       worked before this change.
#   (2) the braced component-prop binding (Handler={ js`…` }, canHoist=true)
#       — THIS change's hoist path — forwarded through a plain `{Handler}`
#       ExprAttr reference into a real onclick attribute in the child.
# (An in-closure Go-expression FORM of this literal — e.g. `onclick={
# send(js`…`) }`, a call wrapping the literal directly in an attribute value
# — is not reachable at all: parseSingleAttr's braced-embedded-literal sniff
# only recognizes a BARE f`/js`/css` literal as the immediate first token
# after `{`; wrapped in a call, the value falls through to the ordinary
# ExprAttr/Go-expression parse, which does not split embedded literals out of
# arbitrary Go code — a pre-existing, orthogonal gap unrelated to this
# change. The braced-prop form (2) is the only canHoist=true site that can be
# observed as a rendered attribute value.)
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

// Parse fails on empty input.
func Parse(s string) (string, error) {
	if s == "" {
		return "", errors.New("parse: empty input")
	}
	return s, nil
}
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Wide(Handler gsx.RawJS) {
	<button onclick={Handler}>b</button>
}

component Page(id string) {
	<button onclick=js`save('@{id |> parse}')`>a</button>
	<Wide Handler={ js`save('@{id |> parse}')` }/>
}
-- invoke --
Page("x') ; steal('")
-- diagnostics.golden --
