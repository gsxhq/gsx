# Over-rejection guard: a PURE filter (no ctx, no error — `Shout`) piped in a
# js`…@{…}…` literal at a top-level func return (the same Go-expression
# position diag_ctx_filter/diag_error_pipe reject a ctx-taking/error-returning
# filter at) has neither hazard, so it must keep rendering: rejectCtx and
# rejectErr both key off the SPECIFIC filter's capability flags
# (pipelineWantsCtx/pipelineHasErr), not off the Go-expression position alone.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

// Shout is a pure filter: no ctx, no error.
func Shout(s string) string {
	return s + "!"
}
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mk(v string) gsx.RawJS { return js`f(@{v |> shout})` }

component Page(v string) {
	<button @click={mk(v)}>x</button>
}
-- invoke --
Page("a")
-- diagnostics.golden --
-- generated.x.go.golden --
// Code generated by gsx; DO NOT EDIT.

package demo

import (
	_gsxctx "context"
	_gsxf0 "corpustest/cases/goexpr-js-literal_pure_filter_toplevel/filters"
	"github.com/gsxhq/gsx"
	_gsxrt "github.com/gsxhq/gsx"
	_gsxio "io"
)

func mk(v string) gsx.RawJS { return _gsxrt.RawJS("f(" + _gsxrt.EscapeJSVal(_gsxf0.Shout((v))) + ")") }

//line input.gsx:7:1
func Page(v string) _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:8:2
		_gsxgw.S("<button @click=\"")
		_gsxgw.AttrValue(string(mk(v)))
		_gsxgw.S("\">x</button>")
		return _gsxgw.Err()
	})
}
-- render.golden --
<button @click="f(&#34;a!&#34;)">x</button>
