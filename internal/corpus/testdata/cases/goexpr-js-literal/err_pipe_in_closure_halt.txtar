# W2 failure path (halt-on-error twin of err_pipe_in_closure.txtar): the
# filter errors at render (empty Csv), so the hoisted
# `_gsxv0, _gsxerr := _gsxf0.Parse((csv)); if _gsxerr != nil { return _gsxerr }`
# fires before `take` is ever called — pinned via the corpus render-error
# capture facet (same shape as pipeerr/halt_on_error.txtar).
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

// Parse fails on empty input.
func Parse(s string) (string, error) {
	if s == "" {
		return "", errors.New("parse: empty input")
	}
	return s, nil
}
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func take(j gsx.RawJS) gsx.Node { return gsx.Raw(string(j)) }

component Page(csv string) {
	<div>{ take(js`load(@{csv |> parse})`) }</div>
}
-- invoke --
Page("")
-- diagnostics.golden --
