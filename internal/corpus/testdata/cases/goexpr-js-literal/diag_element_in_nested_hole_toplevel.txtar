# W3: an element literal inside a nested @{ } hole of a TOP-LEVEL js`` literal
# (`var h = js`f(@{ <b>y</b> })``). A hole in a Go-expression-position literal
# must reassemble to a string seed, but an element value is a gsx.Node closure —
# so this is a single positioned "unsupported-node" diagnostic. The fix keeps
# the probe skeleton VALID (holeProbeSeed lowers the element part to a
# nil-returning _gsxrt.Node placeholder) so emit's assembleHoleSeed rejection is
# the one message the user sees, instead of a cryptic parser cascade from the
# raw `<b>y</b>` splicing into the skeleton.
-- input.gsx --
package demo

var h = js`f(@{ <b>y</b> })`

component Page() {
	<button @click={h}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
3:15: element literals are not supported inside this interpolation position; bind the element to a variable in a {{ }} block or use a { } child position
-- render.golden --
