# W2 source-order pin: ONE js`` literal at an in-closure site carrying BOTH a
# pure hole (@{a}) and an error-carrying hole (@{b |> parse}). The fold path
# materializes EVERY dynamic hole to a temp at its source position — the pure
# hole's `_gsxv0 := …` must precede the error hole's `_gsxv1, _gsxerr := …`
# hoist, so the later hole's error-handling statements cannot reorder the
# earlier hole's evaluation. Success path.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

// Parse fails on empty input.
func Parse(s string) (string, error) {
	if s == "" {
		return "", errors.New("parse: empty input")
	}
	return s, nil
}
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func take(j gsx.RawJS) gsx.Node { return gsx.Raw(string(j)) }

component Page(a string, b string) {
	<p>{ take(js`f(@{a}, @{b |> parse})`) }</p>
}
-- invoke --
Page("x", "y")
-- diagnostics.golden --
