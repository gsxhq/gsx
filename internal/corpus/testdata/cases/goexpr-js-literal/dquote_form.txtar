# The `"`-delimited escape-hatch form (js"…") in a var initializer, chosen so
# the literal JS source can use a bare backtick without escaping it. The
# backtick is free/literal inside the `"` delimiter (only `\"` escapes the
# outer delimiter) — @{x} sits between two literal backticks in the JS text,
# so it still classifies as JSCtxTemplate (EscapeJSTmpl), exactly as it would
# in the backtick-delimited form. x contains a backtick to prove this: a
# misclassification as JSCtxValue would leave it unescaped inside quotes
# instead of JS-template-escaped, a visibly different (and unsafe) result.
-- input.gsx --
package demo

var x = "a`b"

var handler = js"save(`@{x}`)"

component Page() {
	<button @click={handler}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button @click="save(`a\u0060b`)">x</button>
-- generated.x.go.golden --
