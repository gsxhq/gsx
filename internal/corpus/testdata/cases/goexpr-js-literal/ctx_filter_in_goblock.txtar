# A ctx-taking filter in a js`…@{…}…` literal inside a `{{ }}` GoBlock WORKS: a
# GoBlock is emitted inside the render closure, so `ctx` binds and `up(ctx, v)` is
# valid. Pins that the no-render-context rejection is scoped by CTX AVAILABILITY
# (hasCtx), so a GoBlock — which HAS ctx — keeps ctx filters even though it cannot
# safely hoist an error (see goexpr-f-literal/diag_error_pipe_goblock).
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "context"

func Up(ctx context.Context, s string) string {
	if ctx == nil {
		return "NOCTX"
	}
	return s + "!"
}
-- input.gsx --
package demo

component Page(v string) {
	{{ j := js`f(@{v |> up})` }}
	<button @click={j}>x</button>
}
-- invoke --
Page(PageProps{V: "a"})
-- diagnostics.golden --
-- generated.x.go.golden --
