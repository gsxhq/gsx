# The SAME gsx.RawJS type in a STRING position (@{h} between '…', JSCtxString)
# does NOT pass through: static lexical classification only looks at where the
# hole sits in the JS source, never at the hole's Go type, so it is stringified
# and JS-string-escaped as content (EscapeJSStr(string(h))) like any other
# value. h is hostile — a quote-close-paren-semicolon breakout attempt — proving
# passthrough is value-position-only: RawJS is not a blanket escaping bypass.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

var h = gsx.RawJS("x') ; steal('")

var handler = js`f('@{h}')`

component Page() {
	<button @click={handler}>x</button>
}
-- invoke --
Page()
