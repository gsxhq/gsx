# Two holes in one js`…` literal, each a call with a side effect (a package
# counter). The generated concat evaluates left to right, exactly once per
# hole (Go's spec-guaranteed left-to-right operand evaluation), so the render
# pins "1" then "2" — not "1, 1" (re-evaluation) or "2, 1" (reordering). Each
# hole is a bare int in a JSCtxValue position: EscapeJSVal pads a numeral with
# surrounding spaces (json.Marshal(1) == "1", an identifier-part boundary rune,
# so the value escaper brackets it in spaces to keep it from fusing with
# adjacent JS tokens) — the render golden pins that padding too.
-- input.gsx --
package demo

var n int

func next() int {
	n++
	return n
}

var handler = js`f(@{next()}, @{next()})`

component Page() {
	<button @click={handler}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button @click="f( 1 ,  2 )">x</button>
-- generated.x.go.golden --
