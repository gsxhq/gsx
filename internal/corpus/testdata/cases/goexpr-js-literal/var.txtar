# An expression-valued js`…@{x}…` literal in a top-level var initializer.
# Lowers to _gsxrt.RawJS("…" + _gsxrt.EscapeJSVal(x) + "…"): static text
# verbatim, the hole JS-value-encoded (strings get JSON quotes). The var's
# static type is gsx.RawJS; through an { expr } attr it emits as JS source via
# the normal HTML-attribute escape (never JSON-quoted whole), mirroring
# jsattr/click_rawjs.txtar. (Task 7 adds the {{ }} block variant.)
-- input.gsx --
package demo

var id = "abc"

var handler = js`save(@{id})`

component Page() {
	<button @click={handler}>Save</button>
}
-- invoke --
Page()
