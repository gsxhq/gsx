# W2: an error-returning pipe stage in a js`` hole bound to a declared
# component prop via the BRACED prop-binding form (childPropsLiteral,
# canHoist=true) — the hoist lands in componentValueEntry.stmts and replays
# BEFORE the Wide(...) call, in source order relative to other attr values.
# Success path.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

// Parse fails on empty input.
func Parse(s string) (string, error) {
	if s == "" {
		return "", errors.New("parse: empty input")
	}
	return s, nil
}
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Wide(Handler gsx.RawJS) {
	<button onclick={Handler}>x</button>
}

component Page(id string) {
	<Wide Handler={ js`go(@{id |> parse})` }/>
}
-- invoke --
Page(PageProps{Id: "a,b"})
