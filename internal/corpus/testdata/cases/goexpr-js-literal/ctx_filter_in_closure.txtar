# The SAME ctx-taking filter (`up`) in a js`…@{…}…` literal WORKS when the literal
# sits in a render-context position: an Interp.Embedded hole `{ take(js`…`) }`
# inside a component body lowers inside the render closure, where the ambient
# `ctx` IS in scope, so `up(ctx, v)` is a valid expression. Pins that the
# ctx-filter rejection (diag_ctx_filter) is scoped to Go-EXPRESSION position, not
# to js` literals with ctx filters generally. The rendered "!" proves ctx is real.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "context"

func Up(ctx context.Context, s string) string {
	if ctx == nil {
		return "NOCTX"
	}
	return s + "!"
}
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func take(j gsx.RawJS) gsx.Node { return gsx.Raw(string(j)) }

component Page(v string) {
	<div>{ take(js`f(@{v |> up})`) }</div>
}
-- invoke --
Page(PageProps{V: "a"})
-- diagnostics.golden --
