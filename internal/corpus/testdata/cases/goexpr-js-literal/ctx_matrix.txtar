# One js`…` literal, four holes in four lexical positions (value / string /
# template / regexp), pinning the escaper each JSCtx selects: EscapeJSVal,
# EscapeJSStr, EscapeJSTmpl, EscapeJSRegexp. The render pins the encoded output
# for a benign value; the generated golden pins which escaper each hole got.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mk(v string) gsx.RawJS {
	return js`f(@{v}, '@{v}', \`@{v}\`, /@{v}/)`
}

component Page() {
	<button @click={mk("a")}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button @click="f(&#34;a&#34;, &#39;a&#39;, `a`, /a/)">x</button>
