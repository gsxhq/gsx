# js`…` literals as gsx.Attrs (an ordered []gsx.Attr) values, built by a
# top-level func and spread onto an element. Each literal lowers to
# _gsxrt.RawJS(...) (an Attr.Value), and the element spread emits each RawJS as
# JS source through the ONE surrounding HTML-attribute escape — never
# JSON-quoting the whole value — in slice order. The func rides in a
# GoWithElements region (two js` parts); both @{id} holes are classified by
# ResolveScripts.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mkAttrs(id string) gsx.Attrs {
	return gsx.Attrs{
		{Key: "@click", Value: js`select(@{id})`},
		{Key: "x-data", Value: js`dialog(@{id})`},
	}
}

component Panel(id string) {
	<button {mkAttrs(id)...}>Pick</button>
}
-- invoke --
Panel("abc")
-- diagnostics.golden --
-- render.golden --
<button @click="select(&#34;abc&#34;)" x-data="dialog(&#34;abc&#34;)">Pick</button>
