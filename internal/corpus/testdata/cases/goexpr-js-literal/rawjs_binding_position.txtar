# A gsx.RawJS hole in a JS binding/lvalue position (assignment target) inside an
# expression-valued js`` literal in a Go block. This is the pattern js`` in Go
# blocks exists for: an Alpine @change handler that writes to a dynamic model
# path, previously only expressible as gsx.RawJS(fmt.Sprintf("%s = …", path)).
# The RawJS-typed hole splices verbatim; the classifier defers the binding
# position to JSCtxBinding and emit admits it because the type is gsx.RawJS.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Page(xModelPath string) {
	{{
		syncAttrs := gsx.Attrs{
			{Key: "@change", Value: js`const foundId = lookup($event);
@{gsx.RawJS(xModelPath)} = foundId;`},
		}
	}}
	<input {syncAttrs...}/>
}
-- invoke --
Page(PageProps{XModelPath: "form.email"})
-- diagnostics.golden --
-- render.golden --
<input @change="const foundId = lookup($event);
form.email = foundId;"/>
