func Page() _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:4:2
		_gsxgw.S("<div>")
//line input.gsx:4:7
		_gsxgw.Text(string(h))
		_gsxgw.S("</div>")
		return _gsxgw.Err()
	})
}
