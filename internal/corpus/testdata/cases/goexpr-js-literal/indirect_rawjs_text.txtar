# EXISTING behavior, pinned so nobody "fixes" it into raw HTML: a gsx.RawJS
# value reached INDIRECTLY (via a package var declared in a sibling plain .go
# file, not a js`…` literal at all) and interpolated bare in a body position
# (`{ h }`) renders as ordinary HTML-escaped text. RawJS/RawCSS are trusted
# ONLY by the JS/CSS escapers (EscapeJSVal's runtime type switch, an attribute
# AttrValue sink, etc.) — never by the plain-text body sink, which has no
# concept of "this string is pre-vetted script source" and correctly escapes
# it like any other string-kind value (same path as
# goexpr-f-literal/f_value_is_escaped_string.txtar).
-- helper.go --
package demo

import "github.com/gsxhq/gsx"

var h = gsx.RawJS("<script>alert(1)</script>")
-- input.gsx --
package demo

component Page() {
	<div>{ h }</div>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div>&lt;script&gt;alert(1)&lt;/script&gt;</div>
-- generated.x.go.golden --
