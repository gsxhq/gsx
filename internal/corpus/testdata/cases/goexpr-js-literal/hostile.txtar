# Same four-context js`…` literal as ctx_matrix.txtar, invoked with a value
# hostile to all four contexts at once: a quote, a double quote, a
# script-closing tag, a bare `<x>` tag, a template `${`, a free backtick, and a
# newline. Every context must neutralize all of it — no quote/backtick/`${`
# breakout, no literal `</script>`, no raw newline reaching the JS source — and
# the whole composed RawJS is then HTML-attribute-escaped at the @click sink,
# so the render golden proves both escaping layers compose safely.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mk(v string) gsx.RawJS {
	return js`f(@{v}, '@{v}', \`@{v}\`, /@{v}/)`
}

component Page() {
	<button @click={mk("'\"</script><x>${`}\nend")}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button @click="f(&#34;&#39;\&#34;\u003c/script\u003e\u003cx\u003e${`}\nend&#34;, &#39;\u0027\u0022\u003c\/script\u003e\u003cx\u003e${\u0060}\nend&#39;, `\u0027\u0022\u003c\/script\u003e\u003cx\u003e\u0024\u007b\u0060\u007d\nend`, /\u0027\u0022\u003c\/script\u003e\u003cx\u003e\$\{`\}\nend/)">x</button>
