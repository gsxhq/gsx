# THE differential-equivalence pin: the SAME js`save('@{id}')` literal text
# (a JSCtxString hole — `'@{id}'` sits inside single quotes, closing the
# corpus's one remaining genuine attribute-local JSCtxString gap) lowered FOUR
# different ways must render the exact same `@click` attribute value —
# correctness-first's "two lowerings, one pinned behavior" proved by bytes,
# not by reading codegen:
#   (1) unbraced attr-local EmbeddedAttr:      @click=js`save('@{id}')`
#   (2) braced attr-local EmbeddedAttr:        @click={ js`save('@{id}')` }
#   (3) expression form (Go-expr literal) via a {{ }}-block var, then a plain
#       ExprAttr reference:                    {{ h := js`save('@{id}')` }} ...
#                                               @click={h}
#   (4) spread from a {{ }}-block gsx.Attrs literal built the same way:
#       {{ clickAttrs := gsx.Attrs{{Key: "@click", Value: js`save('@{id}')`}} }}
#       ... { clickAttrs... }
# (clickAttrs, not attrs: "attrs" is the reserved implicit-attrs-forwarding
# identifier — any component referencing it gets an auto-bound
# `attrs := _gsxp.Attrs` preamble, so a user `{{ attrs := ... }}` would
# collide with that binding ("no new variables on left side of :="), a
# genuine gotcha but orthogonal to this differential.)
# (1)/(2) both compile through emitJSAttrInterp/JSStrAttr (JS-string-escape +
# HTML-attr-escape combined in one runtime call); (3)/(4) both compile through
# embeddedJSValueExpr's exprPos lowering (EscapeJSStr into a RawJS value), then
# hit the ordinary whole-value HTML-attr escape at their respective sinks
# (ExprAttr's AttrValue / the element spread's Attr-value writer) — a
# DIFFERENT pair of runtime entry points computing the identical composition
# (htmlReplacer . jsStrEscaper) by construction (JSStrAttr's own doc comment:
# "applies JS-string escaping first, then HTML-attribute escaping"). The id is
# hostile (breaks out of the JS string AND carries an HTML-sensitive quote) so
# the equivalence exercises both escaper layers, not just plain text.
#
# The css twin: css`color:@{c}` direct-attr-literal vs the same {{ }}-block
# gsx.Attrs-literal spread form, with a hostile `c` that trips the CSS-value
# filter's ZgotmplZ failsafe (a semicolon is in cssValueFilter's fail-closed
# set) — both `style` values must render identically too.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Page(id string, c string) {
	<button @click=js`save('@{id}')`>a</button>
	<button @click={ js`save('@{id}')` }>b</button>
	{{ h := js`save('@{id}')` }}
	<button @click={h}>c</button>
	{{ clickAttrs := gsx.Attrs{{Key: "@click", Value: js`save('@{id}')`}} }}
	<button {clickAttrs...}>d</button>
	<div style=css`color:@{c}`>e</div>
	{{ sAttrs := gsx.Attrs{{Key: "style", Value: css`color:@{c}`}} }}
	<div {sAttrs...}>f</div>
}
-- invoke --
Page(PageProps{Id: "x') ; steal('", C: "red; background:blue"})
-- diagnostics.golden --
