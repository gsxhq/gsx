# A gsx.RawJS hole in a VALUE position (@{h} unquoted, JSCtxValue) passes
# through verbatim: EscapeJSVal's runtime type switch recognizes RawJS and
# emits it unescaped, exactly as gsx.RawJS is meant to be used — pre-vetted JS
# source, not a value to be JSON-quoted. Contrast rawjs_escaped_in_string.txtar,
# where the SAME RawJS hole in a STRING position is escaped as content instead.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

var h = gsx.RawJS("inner()")

var handler = js`wrap(@{h})`

component Page() {
	<button @click={handler}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button @click="wrap(inner())">x</button>
