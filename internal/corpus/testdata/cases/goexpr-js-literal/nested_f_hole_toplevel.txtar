# W3: a nested f`` literal inside a TOP-LEVEL js`` literal's @{ } hole. The
# outer literal is a Go-expression position (a var initializer), so it wraps the
# JS-escaped concat in gsx.RawJS; the inner f` lowers to a plain string concat
# that the JS-value hole escapes. The inner literal's holes stay pure (no
# error/ctx), which top-level position requires. Needs Task 3's hole-aware
# boundary scan to parse the nested backticks.
-- input.gsx --
package demo

var h = js`f(@{ f`x` })`

component Page() {
	<button @click={h}>x</button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button @click="f(&#34;x&#34;)">x</button>
