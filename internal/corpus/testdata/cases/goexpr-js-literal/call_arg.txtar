# A js`…` literal passed as a CALL ARGUMENT inside a body interpolation
# ({ consume(js`submit(@{formID})`) }). The literal is a sub-expression of a
# larger Go expression, so it rides in Interp.Embedded (split by
# SplitGoExprElements at analyze time) — its @{formID} hole is classified by the
# analyze-time wiring, NOT ResolveScripts. It lowers to _gsxrt.RawJS(...) spliced
# into consume(...); consume (a sibling .go helper, gsx.RawJS -> gsx.Node) renders
# its result. Pins the emit≡probe typing of the Interp.Embedded IIFE as RawJS.
-- helpers.go --
package demo

import "github.com/gsxhq/gsx"

func consume(h gsx.RawJS) gsx.Node {
	return gsx.Text(string(h))
}
-- input.gsx --
package demo

component Host(formID string) {
	<div>{ consume(js`submit(@{formID})`) }</div>
}
-- invoke --
Host("f1")
-- diagnostics.golden --
-- render.golden --
<div>submit(&#34;f1&#34;)</div>
-- generated.x.go.golden --
