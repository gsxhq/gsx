# Regression lock: a hand-written arity-1 func keeps the XxxProps convention, so a
# bad attribute is caught at GENERATE time (not deferred to go build).
-- badge.go --
package views

import "github.com/gsxhq/gsx"

type BadgeProps struct{ Count int }

func Badge(p BadgeProps) gsx.Node { return gsx.Raw("x") }
-- input.gsx --
package views

component Page(s string) { <Badge count={s}/> }
-- diagnostics.golden --
3:35: Badge has no attrs param; unexpected attribute "count"
