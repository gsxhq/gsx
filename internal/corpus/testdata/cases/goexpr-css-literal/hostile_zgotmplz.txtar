# A css`…@{x}…` literal's hole is CSS-value-filtered at construction time
# (embeddedCSSValueExpr, not the style={ … } merge site): a hostile value
# containing a ';' break-out attempt bakes the ZgotmplZ failsafe into the
# gsx.RawCSS itself. Mirrors style/explicit_css_attr_hostile.txtar's hostile
# value, through the expression form + a composed style={ expr } attr.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mk(color string) gsx.RawCSS {
	return css`color:@{color}`
}

component Box(color string) {
	<div style={ mk(color) }>x</div>
}
-- invoke --
Box("red;background:url(javascript:alert(1))")
-- diagnostics.golden --
-- render.golden --
<div style="color:ZgotmplZ">x</div>
