# W2 (css twin of goexpr-js-literal/err_pipe_in_closure.txtar, tuple-seed
# shape instead of a pipe stage): a hole whose seed is a (T, error)-returning
# call directly (no |> pipeline) in a css`` literal INSIDE a component's { }
# interp — the render closure has a hoist channel (genInterp's Interp.Embedded
# split, canHoist=true), so the tuple auto-unwraps via
# `_gsxvN, _gsxerr := pick(c); if _gsxerr != nil { return _gsxerr }` exactly
# like the identical f`` hole does. Success path.
-- input.gsx --
package demo

import (
	"errors"

	"github.com/gsxhq/gsx"
)

func pick(c string) (string, error) {
	if c == "" {
		return "", errors.New("pick: empty input")
	}
	return c, nil
}

func show(s gsx.RawCSS) gsx.Node { return gsx.Raw(string(s)) }

component Page(c string) {
	<div>{ show(css`color:@{pick(c)}`) }</div>
}
-- invoke --
Page("red")
