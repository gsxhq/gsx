# An expression-valued css`…@{x}…` literal typed gsx.RawCSS, stored under a
# "style" key in gsx.Attrs and spread: composes with the class/style merge
# (StyleMerged aggregates the bag's "style" pairs verbatim via toStr, then
# merges with the root's static style; the literal's holes were already
# CSS-value-filtered at construction, not re-filtered at merge time).
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func mk(w int, color string) gsx.Attrs {
	return gsx.Attrs{{Key: "style", Value: css`width:@{w}px;color:@{color}`}}
}

component Page() {
	<div {mk(12, "teal")...} style="margin:0">x</div>
}
-- invoke --
Page()
