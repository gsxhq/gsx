# []string renders joined with single spaces — the token-list reading class/style
# always had for a bag value, now available statically too. The JSON reading is
# reached explicitly via a js`@{v}` literal, so the plain form is free to be the
# friendly HTML one.
#
# The ELEMENT must be exactly `string`: the emit lowers to strings.Join, whose
# parameter is []string. A named SLICE (type Tags []string) works — its element is
# still string. A slice of a NAMED string ([]Slug) does not, and classify rejects
# it rather than emitting code that cannot compile.
-- input.gsx --
package views

type Tags []string

component Page(tags []string, named Tags) {
	<div>{tags}</div>
	<div data-tags={tags}>x</div>
	<div>{named}</div>
}
-- invoke --
Page([]string{"a", "b"}, Tags{"c", "d"})
-- diagnostics.golden --
-- render.golden --
<div>a b</div><div data-tags="a b">x</div><div>c d</div>
