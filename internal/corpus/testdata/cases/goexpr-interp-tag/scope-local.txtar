# Context: an interp-embedded element whose OWN interpolation references a
# component parameter — `{ wrap(<b>{ name }</b>) }`. Proves emit ≡ probe scope
# capture: the embedded element's `{ name }` hole is probed INSIDE its IIFE and
# emitted INSIDE its gsx.Func closure, so it resolves by ordinary Go closure
# capture against the enclosing component's param — exactly like a hand-written
# gsx.Func referencing `name`. The case MUST generate with EMPTY diagnostics
# (no "undefined: name") and a non-empty generated golden.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node { return n }

component Uses(name string) {
	<div>{ wrap(<b>{ name }</b>) }</div>
}
-- invoke --
Uses("world")
-- diagnostics.golden --
-- render.golden --
<div><b>world</b></div>
