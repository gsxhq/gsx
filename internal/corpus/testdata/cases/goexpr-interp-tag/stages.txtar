# Context: a tag-carrying interp with a WHOLE-LITERAL pipeline —
# `{ wrap(<b>hi</b>) |> toHTML }`. genInterp lowers the pipeline over the
# already-spliced seed (the gsx.Node value from wrap(...)), so the emitted type
# is the pipeline's RESULT type (string), NOT the seed's gsx.Node type. The
# probe MUST apply the same t.Stages via probeExpr/lowerPipe, or resolved[node]
# stays gsx.Node and the emitter renders a string through the Node path — a raw
# .x.go compile error. `toHTML` renders a node back to its HTML string, so the
# result is a `string` (distinct from the seed's gsx.Node) and, as a text-context
# hole, is HTML-escaped on the way out — proving both the wiring and the type.
-- gsx.toml --
filterPackages = ["./filters"]
-- filters/filters.go --
package filters

import (
	"bytes"
	"context"

	"github.com/gsxhq/gsx"
)

// ToHTML renders a node to its HTML string: a node->string filter, so the
// pipeline's result type differs from the seed's gsx.Node type.
func ToHTML(n gsx.Node) string {
	var buf bytes.Buffer
	_ = n.Render(context.Background(), &buf)
	return buf.String()
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node { return n }

component Uses() {
	<div>{ wrap(<b>hi</b>) |> toHTML }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div>&lt;b&gt;hi&lt;/b&gt;</div>
