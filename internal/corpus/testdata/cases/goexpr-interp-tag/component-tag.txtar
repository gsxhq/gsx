# Context: a COMPONENT tag (not an HTML tag) embedded in an interp with a typed
# prop bound to a param — `{ wrap(<Badge count={n}/>) }`. Exercises harvest of
# the embedded element's props: the literal lowers to the ordinary component
# call-site (`Badge(BadgeProps{Count: n})`) inside the spliced gsx.Func value,
# the same lowering a component body's child tags use — confirming the embedded
# element's own prop binding resolves against the enclosing component scope.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node { return n }

component Badge(count int) {
	<span>{ count }</span>
}

component Uses(n int) {
	<div>{ wrap(<Badge count={n}/>) }</div>
}
-- invoke --
Uses(UsesProps{N: 7})
-- diagnostics.golden --
-- render.golden --
<div><span>7</span></div>
-- generated.x.go.golden --
