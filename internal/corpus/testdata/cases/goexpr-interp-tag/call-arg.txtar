# Context: a <tag>/<> element literal embedded in operand position INSIDE a
# body `{ }` interpolation — `{ wrap(<><b>hi</b></>) }`. The fragment literal
# lowers to an inline gsx.Func(...) value spliced into the call, and the whole
# interpolation renders by wrap's resolved return type (gsx.Node). This is the
# interp-embedded counterpart to the top-level GoWithElements element literal:
# the emit and probe passes share the SAME split parts (Interp.Embedded) so the
# resolved type keys on one set of node pointers (emit ≡ probe).
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node { return n }

component Uses() {
	<div>{ wrap(<><b>hi</b></>) }</div>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<div><b>hi</b></div>
