# Context: a tag-carrying interp `{ wrap(<b>{ name }</b>) }` (name string)
# IMMEDIATELY followed by a DIFFERENTLY-typed sibling interp `{ other }` (int)
# in the SAME body. This is the regression test for the harvestBody k-ordering
# drift: the first interp's probe splices an embedded-element IIFE that carries
# its OWN _gsxuse(name) call. collectExprs does NOT recurse into
# Interp.Embedded, so that inner probe has no slot in the k-ordered node list —
# harvestBody MUST skip the embedded probe IIFE's subtree, or the inner
# _gsxuse(name) over-runs k and `{ other }` (int) is mis-harvested as `name`'s
# string type, generating `_gsxgw.Text(string(other))` (a rune conversion of an
# int) and silently rendering the wrong output. Both values MUST appear
# correctly: <div><b>world</b>7</div>.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node { return n }

component Uses(name string, other int) {
	<div>{ wrap(<b>{ name }</b>) }{ other }</div>
}
-- invoke --
Uses(UsesProps{Name: "world", Other: 7})
-- diagnostics.golden --
-- render.golden --
<div><b>world</b>7</div>
-- generated.x.go.golden --
