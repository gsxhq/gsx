# retained and never rendered.
-- input.gsx --
package views

component C(on bool) {
	<input
		{ if on {
			// enabled path
			checked
		} }
	/>
}
-- invoke --
C(CProps{On: true})
-- diagnostics.golden --
-- render.golden --
<input checked/>
