# the std `printf` filter: fmt.Sprintf with the piped value as the first verb
# (it flips fmt.Sprintf's spec-first order so it works seed-first). Covered in
# text + attribute contexts, single value and the variadic multi-arg form.
-- input.gsx --
package views

component C(count int, price float64, total int) {
	<p>{ count |> printf("%d comments") }</p>
	<span title={ price |> printf("$%.2f") }>{ price |> printf("$%.2f") }</span>
	<b>{ count |> printf("%d/%d", total) }</b>
}
-- invoke --
C(5, 9.5, 12)
-- diagnostics.golden --
-- render.golden --
<p>5 comments</p><span title="$9.50">$9.50</span><b>5/12</b>
