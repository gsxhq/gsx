# The error-handling escape hatch: to HANDLE a (T, error) instead of auto-unwrapping
# (which propagates), use an `if` with a Go init statement. This is what the removed
# `?` try-marker's diagnostic points authors to.
-- input.gsx --
package views

func load(id string) (string, error) { return "loaded:" + id, nil }

component Profile(id string) {
	<div>{ if v, err := load(id); err != nil { <span class="err">{ err.Error() }</span> } else { <span>{ v }</span> } }</div>
}
-- invoke --
Profile(ProfileProps{Id: "7"})
-- diagnostics.golden --
-- render.golden --
<div><span>loaded:7</span></div>
