# Component f-literals remain built-in strings across generic inference and
# whole/per-hole pipelines, including a fallible whole-literal final stage.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

func Check(s string) (string, error) {
	if s == "" {
		return "", errors.New("check: empty input")
	}
	return s + "!", nil
}
-- input.gsx --
package views

import "fmt"

component Generic[T any](value T) {
	<p>{ fmt.Sprint(value) }</p>
}

component Header(subtitle string) {
	<h1>{ subtitle }</h1>
}

component Page(n int, label string) {
	<Generic value=f`item-@{n}`/>
	<Header subtitle={f`item-@{n}` |> upper}/>
	<Header subtitle=f`label-@{label |> upper}`/>
	<Header subtitle={f`checked-@{n}` |> check}/>
}
-- invoke --
Page(7, "ada")
-- diagnostics.golden --
