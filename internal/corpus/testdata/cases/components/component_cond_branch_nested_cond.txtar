# A nested cond-attr inside a component conditional-attr branch composes as a
# nested AttrsCond thunk hoisted with the two-value `return nil, _gsxerr`
# matching the enclosing branch thunk's (Attrs, error) signature.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div class="card" { attrs... }>{title}</div> }

component Page(outer bool, inner bool) {
	<Card title="Hi" { if outer { data-o="1" { if inner { data-i="1" } } } } />
}
-- invoke --
Page(true, true)
