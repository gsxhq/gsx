# A nested component tag's prop value referencing `attrs` binds the enclosing
# component's implicit bag (uniform binding, 2026-07-13). This case previously
# pinned the pre-forwarding `undefined: attrs` rejection.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Child(attrs gsx.Attrs) {
	<div { attrs... }>child</div>
}

component Wrapper(attrs gsx.Attrs) {
	<Child class={attrs.Class()}/>
}
-- invoke --
Wrapper(gsx.Attrs{{Key: "class", Value: "forwarded"}})
-- diagnostics.golden --
-- render.golden --
<div class="forwarded">child</div>
