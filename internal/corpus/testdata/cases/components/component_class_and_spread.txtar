# COVERAGE (gap #2): a composable class={…} entry AND a spread { extra... } on the
# SAME invocation — exercises the base bag class entry plus the .Merge(extra) chain
# ordering (base built first, spread merged after).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div class="card" { attrs... }>{title}</div> }

component Page(extra gsx.Attrs) {
	<Card title="Hi" class={ "a" } { extra... } />
}
-- invoke --
Page(gsx.Attrs{{Key: "id", Value: "main"}})
