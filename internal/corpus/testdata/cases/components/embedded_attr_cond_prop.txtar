# A hole-free embedded-language literal inside a conditional attribute
# { if cond { x-model=js`…` } } on a component forwards to the conditional Attrs
# bag as raw text — same lowering as the plain component-prop position.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Field(label string, attrs gsx.Attrs) { <input aria-label={label} { attrs... }/> }

component Page(edit bool) {
	<Field label="Category" { if edit { x-model=js`pdcaCategory` } } />
}
-- invoke --
Page(true)
-- diagnostics.golden --
