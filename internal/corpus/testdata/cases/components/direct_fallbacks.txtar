# Imported, method, package-variable, plain-Go, and dynamic targets retain the
# ordinary Node boundary while the containing local component may render directly.
-- dep/dep.go --
package dep

import "github.com/gsxhq/gsx"

func Imported(value string) gsx.Node { return gsx.Raw("<i>" + value + "</i>") }
-- helpers.go --
package views

import "github.com/gsxhq/gsx"

type Cards struct{}

func Plain(value string) gsx.Node { return gsx.Raw("<b>" + value + "</b>") }
var Variable = Plain
func Dynamic(value string) gsx.Node { return gsx.Raw("<u>" + value + "</u>") }
-- input.gsx --
package views

import (
	"github.com/gsxhq/gsx"
	"corpustest/cases/components_direct_fallbacks/dep"
)

component (cards Cards) Method(value string) { <mark>{ value }</mark> }

component Fallbacks(cards Cards, render func(string) gsx.Node) {
	<dep.Imported value="imported"/>
	<cards.Method value="method"/>
	<Variable value="variable"/>
	<Plain value="plain"/>
	{ render("dynamic") }
}

component Page() { <Fallbacks cards={ Cards{} } render={ Dynamic }/> }
-- invoke --
Page()
