# Component values evaluate in authored attribute order even when an f-literal
# hole needs statement lowering. A failed formatted hole short-circuits every
# later attribute value while preserving the earlier call.
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

var calls []string

func mark(label, value string) string {
	calls = append(calls, label)
	return value
}

func markInt(label string, value int, fail bool) (int, error) {
	calls = append(calls, label)
	if fail {
		return 0, fmt.Errorf("%s failed", label)
	}
	return value, nil
}

func checkedComponentFLiteralAttributeOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		calls = nil
		if err := Page(PageProps{Fail: false}).Render(ctx, io.Discard); err != nil {
			return fmt.Errorf("successful render: %w", err)
		}
		if got := strings.Join(calls, ","); got != "first,hole,pair,bag,last" {
			return fmt.Errorf("successful evaluation order = %s, want first,hole,pair,bag,last", got)
		}

		calls = nil
		err := Page(PageProps{Fail: true}).Render(ctx, io.Discard)
		if err == nil || err.Error() != "hole failed" {
			return fmt.Errorf("failed render error = %v, want hole failed", err)
		}
		if got := strings.Join(calls, ","); got != "first,hole" {
			return fmt.Errorf("failed evaluation order = %s, want first,hole", got)
		}
		return nil
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Target(first string, formatted string, ordered gsx.Attrs, last string) {
	<div { ordered... } { attrs... }>{first}{formatted}{last}</div>
}

component Page(fail bool) {
	<Target
		first={mark("first", "A")}
		formatted=f`value-@{markInt("hole", 7, fail)}`
		ordered={{ "data-pair": mark("pair", "P") }}
		data-bag={mark("bag", "B")}
		last={mark("last", "Z")}
	/>
}
-- invoke --
checkedComponentFLiteralAttributeOrder()
