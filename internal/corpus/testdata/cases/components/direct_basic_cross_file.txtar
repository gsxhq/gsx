-- child.gsx --
package views

import "github.com/gsxhq/gsx"

component Child(value string, children gsx.Node, attrs gsx.Attrs) {
	<section { attrs... }><strong>{ value }</strong>{ children }</section>
}
-- page.gsx --
package views

component Page() {
	<Child value="local" data-id="7"><em>child</em></Child>
}
-- invoke --
Page()
