# A BRACED js`…`/css`…` embedded literal whose name is NOT a declared prop falls
# through to the child's Attrs bag as a trusted _gsxrt.RawJS/_gsxrt.RawCSS value
# (never a plain string) — proving that braced binds ONLY a declared name; an
# undeclared braced literal routes to the bag exactly like the bare form
# (embedded_attr_prop.txtar). The provenance survives the re-interpolation the
# child performs on { attrs... } spread; rendered output is unchanged vs the
# plain-string era because toStr prints RawJS/RawCSS as source through AttrValue.
# Hole-bearing forwarding is pinned by embedded_attr_hole_forwarding.
-- input.gsx --
package demo


import "github.com/gsxhq/gsx"
component Field(label string, attrs gsx.Attrs) { <button aria-label={label} { attrs... }>x</button> }

component Page() {
	<Field
		label="Go"
		@click={ js`toggle()` }
		data-style={ css`color:red` }
	/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button aria-label="Go" @click="toggle()" data-style="color:red">x</button>
