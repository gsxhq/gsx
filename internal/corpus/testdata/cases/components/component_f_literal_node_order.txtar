# Ordered component f-literal materialization preserves Node prop promotion as
# Text, not Val, so markup-looking string content remains escaped text.
-- helpers.go --
package views

import "fmt"

func nodeCount(value int) (int, error) {
	if value < 0 {
		return 0, fmt.Errorf("negative count")
	}
	return value, nil
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Slot(body gsx.Node) { <section>{body}</section> }

component Page(n int) {
	<Slot body=f`<b>@{nodeCount(n)}</b>`/>
}
-- invoke --
Page(7)
