# TARGET (gap #2): a composable class={ … } on a component merges into the child
# root's class via the fallthrough bag (static class="x" already works; this is the
# comma-list/conditional form).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div class="card" { attrs... }>{title}</div> }

component Page(flag bool) {
	<Card title="Hi" class={ "featured", "active": flag } />
}
-- invoke --
Page(true)
