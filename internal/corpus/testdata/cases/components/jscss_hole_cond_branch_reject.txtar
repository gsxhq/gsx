# A hole-bearing js/css embedded literal inside a conditional attribute
# branch on a COMPONENT is rejected like its direct-prop sibling
# (embedded_attr_rejected): the branch folds into the child's prop bag, and
# contextual literals are element sinks. The element-fold sibling
# (multispread/jscss_hole_cond_branch_fold) folds instead — this pins that
# the component surface still gets the component-prop diagnostic.
-- input.gsx --
package views

component Card(title string) {
	<div>{title}</div>
}

component Page(u string, c bool) {
	<Card title="Hi" { if c { onclick=js"do(@{u})" } } />
}
-- diagnostics.golden --
8:28: embedded js attribute literal "onclick" with @{ } interpolation cannot be used as a component prop on <Card> yet; pass an ordinary prop value or move the literal to an element inside the component
