# Within one component f-literal, hole calls evaluate in segment order. A
# fallible hole stops only the holes after it; earlier calls have already run.
-- helpers.go --
package views

import (
	"context"
	"errors"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

var sentinel = errors.New("component f-literal sentinel")
var calls []string

func value(mark string) string {
	calls = append(calls, mark)
	return mark
}

func fallible(fail bool) (string, error) {
	calls = append(calls, "second")
	if fail {
		return "", sentinel
	}
	return "second", nil
}

func checkedComponentFLiteralOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		calls = nil
		if err := Page(false).Render(ctx, io.Discard); err != nil {
			return fmt.Errorf("successful render: %w", err)
		}
		if got := strings.Join(calls, ","); got != "first,second,third" {
			return fmt.Errorf("successful evaluation order = %s, want first,second,third", got)
		}

		calls = nil
		err := Page(true).Render(ctx, io.Discard)
		if !errors.Is(err, sentinel) {
			return fmt.Errorf("failed render error = %v, want component f-literal sentinel", err)
		}
		if got := strings.Join(calls, ","); got != "first,second" {
			return fmt.Errorf("failed evaluation order = %s, want first,second", got)
		}
		return nil
	})
}
-- input.gsx --
package views

component Label(text string) {
	<span>{text}</span>
}

component Page(fail bool) {
	<Label text=f`@{value("first")} @{fallible(fail)} @{value("third")}`/>
}
-- invoke --
checkedComponentFLiteralOrder()
