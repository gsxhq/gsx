# Pure call-bearing component values preserve authored order when an unmatched
# f-literal contributes to the explicit attrs argument.
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

var calls []string

func mark(label, value string) string {
	calls = append(calls, label)
	return value
}

func checkedPlainComponentValueOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		calls = nil
		if err := Page().Render(ctx, io.Discard); err != nil {
			return fmt.Errorf("render: %w", err)
		}
		if got := strings.Join(calls, ","); got != "plain-first,plain-mid,plain-last" {
			return fmt.Errorf("evaluation order = %s, want plain-first,plain-mid,plain-last", got)
		}
		return nil
	})
}
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Target(first string, last string, attrs gsx.Attrs) {
	<div { attrs... }>{first}{last}</div>
}

component Page() {
	<Target first={mark("plain-first", "A")} data-mid=f`@{mark("plain-mid", "M")}` last={mark("plain-last", "Z")}/>
}
-- invoke --
checkedPlainComponentValueOrder()
