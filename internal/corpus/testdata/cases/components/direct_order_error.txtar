# Direct calls preserve authored argument evaluation order and stop before later
# arguments after a selected (T, error) value fails.
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

var directTrace []string

func directMark(label string) string {
	directTrace = append(directTrace, label)
	return label
}

func directPair(label string, fail bool) (string, error) {
	directTrace = append(directTrace, label)
	if fail {
		return "", fmt.Errorf("direct pair failed")
	}
	return label, nil
}

func checkedDirectOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		directTrace = nil
		if err := OrderPage(false).Render(ctx, io.Discard); err != nil {
			return fmt.Errorf("success render: %w", err)
		}
		if got := strings.Join(directTrace, ","); got != "first,pair,last" {
			return fmt.Errorf("success order = %q", got)
		}

		directTrace = nil
		err := OrderPage(true).Render(ctx, io.Discard)
		if err == nil || err.Error() != "direct pair failed" {
			return fmt.Errorf("failure error = %v", err)
		}
		if got := strings.Join(directTrace, ","); got != "first,pair" {
			return fmt.Errorf("failure order = %q", got)
		}
		return nil
	})
}
-- input.gsx --
package views

component Ordered(first, second, last string) {
	<p>{ first }/{ second }/{ last }</p>
}

component OrderPage(fail bool) {
	<Ordered
		first={ directMark("first") }
		second={ directPair("pair", fail) }
		last={ directMark("last") }
	/>
}
-- invoke --
checkedDirectOrder()
-- diagnostics.golden --
