-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Wrap(children gsx.Node) {
	<div>{children}</div>
}

component Page(before string, mid int, after bool) {
	<span>{before}</span>
	<Wrap><em>{mid}</em></Wrap>
	<span>{after}</span>
}
-- invoke --
Page("B", 7, true)
-- diagnostics.golden --
-- render.golden --
<span>B</span><div><em>7</em></div><span>true</span>
