# A BRACED js`…`/css`…` embedded literal on a component whose name matches a
# declared prop BINDS that prop with the trusted type (gsx.RawJS / gsx.RawCSS).
# The braced form is the { expr } prop-binding form: js`…`/css`…` are Go
# expressions (Tasks 1-7), so { js`…` } assigns the RawJS value to the field.
#
# BEFORE this task: `Handler={ js`open(@{id})` }` (spaced braces) fell back to a
# plain Go-expression ExprAttr carrying the raw literal text and was emitted
# verbatim into the props composite literal — a Go syntax error
# ("missing ',' in composite literal"). The tight form `{js`…`}` parsed as an
# EmbeddedAttr but was rejected ("… with @{ } interpolation cannot be used as a
# component prop yet"). Now both braced forms bind the declared prop.
#
# Contrast embedded_attr_prop.txtar (UNBRACED literals always fall through to the
# Attrs bag) and embedded_attr_rawjs_bag.txtar (braced-but-undeclared → bag).
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Widget(Handler gsx.RawJS, Rule gsx.RawCSS) {
	<button @click={Handler} data-style={Rule}>Go</button>
}

component Page(id string, w string) {
	<Widget Handler={ js`open(@{id})` } Rule={ css`width:@{w}px` }/>
}
-- invoke --
Page("abc", "10")
-- diagnostics.golden --
-- render.golden --
<button @click="open(&#34;abc&#34;)" data-style="width:10px">Go</button>
