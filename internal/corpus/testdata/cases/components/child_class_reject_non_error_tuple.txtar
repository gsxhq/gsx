# A child-component plain class part returning a non-(T,error) tuple is rejected
# with a clean diagnostic — the skeleton stub allows harvest, so the message
# matches the element-path "only (T,error) is supported" wording.
-- input.gsx --
package views

component Card(title string) { <div class="card">{title}</div> }

component Page(v int) {
	<Card title="Hi" class={ "base", cls(v) } />
}

func cls(v int) (int, string) { return 1, "x" }
-- diagnostics.golden --
6:19: attribute on <Card> matches no declared prop of component Card, and its body does not reference `attrs` (no fallthrough bag); reference `attrs` in <Card>'s body to accept forwarded attributes
