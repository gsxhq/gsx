-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title string, children gsx.Node) {
	<section><h2>{title}</h2>{children}</section>
}

component Page() {
	<Card title="Hi"><p>body</p></Card>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<section><h2>Hi</h2><p>body</p></section>
