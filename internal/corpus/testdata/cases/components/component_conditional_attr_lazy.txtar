# COVERAGE / REGRESSION-PIN (gap #2): a conditional attribute branch is emitted as
# a THUNK, so its expressions are evaluated ONLY when the branch is taken. Here the
# branch derefs `u.Name`; invoked with u == nil, the untaken thunk must NOT run, so
# there is no panic and no data-name attribute. Pins the lazy-eval fix.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type User struct {
	Name string
}

component Card(title gsx.Node) { <div class="card" { attrs... }>{title}</div> }

component Page(u *User) {
	<Card title="Hi" { if u != nil { data-name={ u.Name } } } />
}
-- invoke --
Page(PageProps{U: nil})
-- diagnostics.golden --
-- render.golden --
<div class="card">Hi</div>
