# COVERAGE (gap #2): a conditional attribute with an ELSE branch on a component —
# the else branch's attrs reach the bag when the condition is false (gsx.AttrsCond
# selects the else literal).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div class="card" { attrs... }>{title}</div> }

component Page(hot bool) {
	<Card title="Hi" { if hot { class="hot" } else { class="cold" } } />
}
