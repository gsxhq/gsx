# COVERAGE (gap #2): a spread { attrs... } whose bag INCLUDES a class merges that
# class INTO the child root's class via gsx.Attrs.Merge (class concatenation), not
# caller-wins replacement — proving the child root's class-merge sees the spread.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div class="card" { attrs... }>{title}</div> }

component Page(extra gsx.Attrs) {
	<Card title="Hi" { extra... } />
}
-- invoke --
Page(gsx.Attrs{{Key: "class", Value: "extra"}, {Key: "id", Value: "main"}})
