# A non-final fallible pipeline stage emits an eager unwrap statement. Earlier
# component values must be captured before that statement even when signature
# order does not otherwise force a crossing.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

func Check(value string) (string, error) { return value, nil }
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

var pipelineCalls []string

func markPipeline(label, value string) string {
	pipelineCalls = append(pipelineCalls, label)
	return value
}

func checkedComponentPipelineOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		pipelineCalls = nil
		if err := Page().Render(ctx, io.Discard); err != nil {
			return err
		}
		if got := strings.Join(pipelineCalls, ","); got != "pipe-first,pipe-after,pipe" {
			return fmt.Errorf("evaluation order = %s, want pipe-first,pipe-after,pipe", got)
		}
		return nil
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component PipelineTarget(first string, after string, attrs gsx.Attrs) {
	<div { attrs... }>{first}{after}</div>
}

component Page() {
	<PipelineTarget
		first={markPipeline("pipe-first", "A")}
		after={markPipeline("pipe-after", "Z")}
		data-mid={markPipeline("pipe", "x") |> check |> upper}
	/>
}
-- invoke --
checkedComponentPipelineOrder()
-- diagnostics.golden --
