# TARGET (gap #2): a spread { attrs... } on a component merges the runtime gsx.Attrs
# into the child root (caller-wins fallthrough), like element spread.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div class="card" { attrs... }>{title}</div> }

component Page(extra gsx.Attrs) {
	<Card title="Hi" { extra... } />
}
-- invoke --
Page(gsx.Attrs{{Key: "id", Value: "main"}, {Key: "data-x", Value: "1"}})
