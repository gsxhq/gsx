# A child component with class={ "base", cls(v) } where cls returns (string, error):
# the plain-part tuple is auto-unwrapped exactly as on a regular element.
-- input.gsx --
package views

component Card(title string) { <div class="card">{title}</div> }

component Page(v int) {
	<Card title="Hi" class={ "base", cls(v) } />
}

func cls(v int) (string, error) { return "green", nil }
