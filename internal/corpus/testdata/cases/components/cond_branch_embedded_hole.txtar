# A hole-bearing embedded text literal (title=f"Hi @{who}") inside a conditional
# attribute { if edit { … } } on a component lowers into the conditional Attrs
# bag as {Key, Value: <assembled string>} — the branch thunk routes through
# composeBag, which assembles the static + @{ } segments exactly like the inline
# path. A hole-free embedded literal here would forward as raw text
# (embedded_attr_cond_prop); this pins the interpolating variant.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Field(label string, attrs gsx.Attrs) { <input aria-label={label} { attrs... }/> }

component Page(edit bool, who string) {
	<Field label="Category" { if edit { title=f"Hi @{who}" } } />
}
-- invoke --
Page(true, "World")
-- diagnostics.golden --
-- render.golden --
<input aria-label="Category" title="Hi World"/>
