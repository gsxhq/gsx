# A hand-written Go component retains its authored single composite parameter.
# With no supplied inputs, <Badge/> calls Badge with the parameter's zero value.
-- badge.go --
package views

import "github.com/gsxhq/gsx"

type BadgeProps struct{ Label string }

func Badge(p BadgeProps) gsx.Node {
	return gsx.Raw("<span>" + p.Label + "</span>")
}
-- input.gsx --
package views

component Page() {
	<div><Badge/></div>
}
-- invoke --
Page()
-- render.golden --
<div><span></span></div>
-- diagnostics.golden --
