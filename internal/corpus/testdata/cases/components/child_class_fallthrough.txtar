# A composable class={…} on a component (whose root carries no own class) falls
# through to the child root's Attrs bag and renders the merged class string.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Card(title string, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(on bool) { <Card class={ "a", "b": on }/> }
-- invoke --
Page(true)
-- diagnostics.golden --
-- render.golden --
<div class="a b"></div>
