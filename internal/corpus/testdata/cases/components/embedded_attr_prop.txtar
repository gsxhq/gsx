# Hole-free js`…`/css`…`/`…` embedded-language literals forward to a component's
# Attrs bag as raw text — JSX-style directive forwarding (e.g. x-model=js`…`).
# The lowering is identical to a plain string attribute; the child spreads the
# bag with { attrs... }. Embedded literals always fall through to the bag; to set
# a declared prop use a string or { expr }.
-- input.gsx --
package views

component Field(label string) { <input aria-label={label} { attrs... }/> }

component Page() {
	<Field
		label="Category"
		x-model=js`pdcaCategory`
		data-tip=`plain text`
		x-init=css`color:red`
	/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<input aria-label="Category" x-model="pdcaCategory" data-tip="plain text" x-init="color:red"/>
