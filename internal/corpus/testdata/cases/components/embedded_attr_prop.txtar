# BARE (unbraced) js`…`/css`…` embedded-language literals forward to a
# component's Attrs bag — JSX-style directive forwarding (e.g. x-model=js`…`).
# The bag value is a trusted _gsxrt.RawJS/_gsxrt.RawCSS (not a plain string), so
# provenance survives the child's re-interpolation on { attrs... } spread; the
# rendered output is unchanged because toStr prints RawJS/RawCSS as source. A
# bare `…` value stays a plain Go raw string (data-tip here). Bare literals
# ALWAYS fall through to the bag regardless of name; to bind a declared prop use
# the braced { js`…` }/{ css`…` } form (embedded_prop_binding.txtar), a string,
# or an f-literal.
-- input.gsx --
package views

component Field(label string) { <input aria-label={label} { attrs... }/> }

component Page() {
	<Field
		label="Category"
		x-model=js`pdcaCategory`
		data-tip=`plain text`
		x-init=css`color:red`
	/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<input aria-label="Category" x-model="pdcaCategory" data-tip="plain text" x-init="color:red"/>
