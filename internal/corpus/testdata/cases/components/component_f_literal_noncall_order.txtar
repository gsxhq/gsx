# Component values preserve authored order for Go-ordered operations that are
# not calls. The unmatched f-literal is authored first but moves into the
# synthesized Attrs field after the declared Label prop; both channel receives
# must still consume their values in source order.
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

func checkedComponentFLiteralNonCallOrder() gsx.Node {
	return gsx.Func(func(ctx context.Context, _ io.Writer) error {
		ch := make(chan string, 2)
		ch <- "first"
		ch <- "second"

		var out strings.Builder
		if err := Page(PageProps{Ch: ch}).Render(ctx, &out); err != nil {
			return fmt.Errorf("render: %w", err)
		}
		const want = `<div data-label="second" data-x="first"></div>`
		if got := out.String(); got != want {
			return fmt.Errorf("component values evaluated out of authored order: got %q, want %q", got, want)
		}
		return nil
	})
}
-- input.gsx --
package views

component Field(label string) {
	<div data-label={label} { attrs... }></div>
}

component Page(ch <-chan string) {
	<Field data-x=f`@{<-ch}` label={<-ch}/>
}
-- invoke --
checkedComponentFLiteralNonCallOrder()
