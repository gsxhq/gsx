# Two attribute bags routed to two different elements.
#
# Mirrors the ubiquitous React form-field idiom where `...rest` is forwarded
# to the inner control while a separately named prop targets the outer wrapper:
#
#   function Field({ label, containerProps, ...rest }) {
#     return (
#       <div className="field" {...containerProps}>
#         <label>{label}</label>
#         <input className="field-input" {...rest} />
#       </div>
#     );
#   }
#   <Field label="Email" containerProps={{ "data-testid": "email-field" }}
#          type="email" placeholder="you@co" required />
#
# In gsx the implicit `attrs` bag carries every unmatched call-site attribute
# (type/placeholder/required) and is placed by hand on the <input>; the declared
# `containerAttrs gsx.Attrs` param is a normal prop spread onto the wrapper <div>.
# Call-site `containerAttrs` binds to the param by its verbatim (camelCase) name,
# so it targets the wrapper instead of falling through into the implicit bag.
# (A kebab `container-attrs` is not an identifier, so it would fall through.)
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Field(label string, containerAttrs gsx.Attrs, attrs gsx.Attrs) {
	<div class="field" { containerAttrs... }>
		<label>{label}</label>
		<input class="field-input" { attrs... }/>
	</div>
}

component Page() {
	<Field
		label="Email"
		containerAttrs={gsx.Attrs{{Key: "data-testid", Value: "email-field"}}}
		type="email"
		placeholder="you@co"
		required
	/>
}
-- invoke --
Page()
-- diagnostics.golden --
