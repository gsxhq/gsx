# A spread inside a cond-attr branch, combined with a top-level forwarding
# spread, is a second spread on the element (the at-most-one-spread count
# descends into cond-attr branches, issue #78): rejected as a precedence
# ambiguity between the two spreads, same as two top-level spreads.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Box(active bool, extra gsx.Attrs) {
	<div { if active { { extra... } } } { attrs... }>x</div>
}
-- diagnostics.golden --
6:38: element with a spread { extra... } cannot carry another spread { attrs... }; merge them into one spread ({ extra.Merge(attrs)... } or { attrs.Merge(extra)... }) so precedence is explicit
