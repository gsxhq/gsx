# A spread nested in a cond-attr branch plus a top-level forwarding spread fold
# by source order (issue #78): the cond spread { if active { extra } } comes
# first, then { attrs... }. With active=true, extra contributes data-k, but the
# trailing attrs spread wins the collision (last writer wins).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Box(active bool, extra gsx.Attrs) {
	<div { if active { { extra... } } } { attrs... }>x</div>
}
-- invoke --
Box(BoxProps{
	Active: true,
	Extra:  gsx.Attrs{{Key: "data-k", Value: "e"}},
	Attrs:  gsx.Attrs{{Key: "data-k", Value: "a"}},
})
-- diagnostics.golden --
-- render.golden --
<div data-k="a">x</div>
