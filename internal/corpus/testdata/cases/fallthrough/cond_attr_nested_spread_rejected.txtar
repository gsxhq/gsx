# A spread inside a cond-attr branch on a forwarding element is rejected: its
# keys are statically unknown, so neither the caller-wins guards nor the
# spread's drop set can reconcile it. Compose it into the forwarding spread
# expression instead.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Box(active bool, extra gsx.Attrs) {
	<div { if active { { extra... } } } { attrs... }>x</div>
}
-- diagnostics.golden --
6:21: spread inside { if } on an element with attribute forwarding has statically unknown keys; hoist it with a GoBlock instead (e.g. {{ a, err := gsx.AttrsCond(active, func() (gsx.Attrs, error) { return extra, nil }, nil); if err != nil { return err } }} then { attrs.Merge(a)... })
