# A LOCAL gsx.Attrs variable (not the component's declared/forwarding bag) keeps
# today's inline behavior: `{ b... }` emits a bare gw.Spread with NO caller-wins
# guards and NO class merge, so a static attr before it and a same-key entry in
# the local bag BOTH render (a duplicate-attr artifact). Only the component's
# own forwarding bag (`attrs` / a byo `p.Attrs` field) gets the precedence
# machinery; local bag composition is the author's responsibility (Merge/Concat).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Page() {
	{{ b := gsx.Attrs{{Key: "a", Value: "c"}} }}
	<span a="b" { b... }>x</span>
}
-- invoke --
Page()
-- diagnostics.golden --
