# A LOCAL gsx.Attrs variable is a forwarding spread exactly like the component's
# declared bag: `{ b... }` hoists once (`_gsxv0 := b`) and routes through the
# caller-wins guards + class/style merge + leaf URL sink. A static attr before
# the spread is now overridable, so a same-key entry in the local bag WINS (no
# duplicate-attr artifact) — here `a="b"` is replaced by the bag's `a="c"`.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Page() {
	{{ b := gsx.Attrs{{Key: "a", Value: "c"}} }}
	<span a="b" { b... }>x</span>
}
-- invoke --
Page()
