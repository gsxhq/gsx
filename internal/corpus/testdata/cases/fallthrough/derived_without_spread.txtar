# A SpreadAttr whose expression is DERIVED from the bag (attrs.Without(...))
# is the forwarding position, exactly like a bare { attrs... }: the root's
# class merges the derived bag's class, pre-spread scalars are
# caller-overridable, and the derived expression is evaluated ONCE (hoisted),
# so guards/class/spread agree.  Before this pinning, a derived spread fell
# back to a plain inline gw.Spread: no class merge (duplicate class attr!) and
# no caller-wins.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Panel(title string, attrs gsx.Attrs) {
	<section class="panel" data-role="box" { attrs.Without("data-skip")... }>{title}</section>
}

component Page() {
	<Panel title="Hi" class="hl" data-role="caller" data-skip="x" id="p1"/>
}
-- invoke --
Page()
