# A component's declared attrs role forwards with position-aware precedence: a
# static scalar AFTER { attrs... } is FORCED — it wins over the caller's bag
# value (the bag's copy is dropped from the residual spread), exactly like the
# generated `attrs` bag. A pre-spread scalar with no post-spread twin stays
# caller-overridable.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Chip(attrs gsx.Attrs) {
	<span data-k="v" { attrs... } a="forced">x</span>
}

component Page() {
	<Chip a="c" data-k="caller" title="t"/>
}
-- invoke --
Page()
