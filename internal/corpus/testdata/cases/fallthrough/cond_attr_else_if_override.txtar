# An else-if chain before the forwarding spread: the caller override applies
# to whichever branch is taken (guards live inside each branch, conditions
# still evaluate with if/else-if short-circuit semantics).
-- input.gsx --
package views

component Badge(n int) {
	<div { if n == 1 { data-a="one" } else if n == 2 { data-a="two" } else { data-a="many" } } { attrs... }>x</div>
}

component Page() {
	<Badge n={2} data-a="caller"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-a="caller">x</div>
