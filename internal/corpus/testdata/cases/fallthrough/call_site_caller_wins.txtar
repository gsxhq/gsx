-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Button(children gsx.Node, attrs gsx.Attrs) {
	<button type="button" { attrs... }>{children}</button>
}

component Page() {
	<Button type="reset">Go</Button>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button type="reset">Go</button>
