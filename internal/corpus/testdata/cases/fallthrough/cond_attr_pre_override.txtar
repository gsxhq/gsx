# A cond-attr BEFORE the forwarding spread is caller-overridable like any
# other pre-spread attr: each branch attr emits under a !attrs.Has(name)
# guard, so a caller value for the same key shadows it (no duplicate
# attribute) while non-colliding branch attrs still emit.
-- input.gsx --
package views

component Box(active bool) {
	<button { if active { id="mine" data-k="v" } } { attrs... }>x</button>
}

component Page() {
	<Box active={true} id="caller"/>
}
-- invoke --
Page()
