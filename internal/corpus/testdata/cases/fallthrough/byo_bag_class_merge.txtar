# A byo component's declared bag participates in class merging: the root's
# static class and the caller's class (carried through p.Attrs) compose into
# ONE merged class attribute — not a duplicate class attr — exactly like the
# generated `attrs` bag.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type props struct {
	Attrs gsx.Attrs
}

component Card(p props) {
	<section class="card" { p.Attrs... }>x</section>
}

component Page() {
	<Card class="hl" id="c1"/>
}
-- invoke --
Page()
