# Fallthrough bag renders in SOURCE order (not alphabetical).
# type, placeholder, name are deliberately non-alphabetical; alphabetical
# order would be name < placeholder < type.  The rendered output must match
# the call-site declaration order, not any sorted permutation.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Field(label string, attrs gsx.Attrs) {
	<input { attrs... }/>
}

component Page() {
	<Field label="Email" type="email" placeholder="you@co" name="email"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<input type="email" placeholder="you@co" name="email">
