# A post-spread cond-attr that forces a URL-classified name (formaction) must
# suppress the bag's own extraction of that name when its branch is TAKEN: the
# forced value owns the attribute, so no duplicate renders and the forced value
# wins. When the branch is NOT taken, the bag's copy renders SANITIZED (the
# forced attr is absent, so the caller's value is the only one — a dangerous
# scheme becomes about:invalid#gsx).
-- input.gsx --
package views

component Btn(active bool) {
	<button { attrs... } { if active { formaction="/forced" } }>x</button>
}

component Page() {
	<Btn active={true} formaction="javascript:alert(1)"/>
	<Btn active={false} formaction="javascript:alert(1)"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<button formaction="/forced">x</button><button formaction="about:invalid#gsx">x</button>
