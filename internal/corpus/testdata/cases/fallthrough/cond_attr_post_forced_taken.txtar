# A cond-attr AFTER the forwarding spread is component-forced when its branch
# is taken: the branch is selected ONCE before the spread, the taken branch's
# names join the spread's drop set at runtime, and the branch attrs emit after
# the spread — so the caller's colliding key never renders.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Box(active bool, attrs gsx.Attrs) {
	<button { attrs... } { if active { id="mine" } }>x</button>
}

component Page() {
	<Box active={true} id="caller" data-x="1"/>
}
-- invoke --
Page()
