-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Link(children gsx.Node, attrs gsx.Attrs) {
	<a href="/x" { attrs... }>{children}</a>
}
-- invoke --
Link(nil, gsx.Attrs{{Key: "href", Value: "/evil"}, {Key: "data-y", Value: "1"}})
-- diagnostics.golden --
-- render.golden --
<a href="/evil" data-y="1"></a>
