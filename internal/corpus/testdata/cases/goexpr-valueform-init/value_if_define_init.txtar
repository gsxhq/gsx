# Task 2 (unified go-expression scanner reroute) pins a latent-bug fix:
# composedDelims (legacy byte scanner) can't distinguish the ':' of a Go ':='
# short-var-decl init from a real `: cond` guard colon, so a value-form `if`
# with a `;`-separated init inside class= used to be spuriously rejected with
# "a value-form if in class/style takes no `: cond` guard" — the byte scanner
# recorded the ':=' colon as if it were a guard. scanGoExpr (token-based,
# `:=` lexes as a single DEFINE token) correctly does not record a colon
# there. Rerouting composedDelims's callers onto scanGoExpr (Task 2) makes
# this construct parse and render instead of erroring at the delimiter.
-- input.gsx --
package views

component Label() {
	<span class={ "base", if x := ready(); x { "on" } }>y</span>
}

func ready() bool { return true }
-- invoke --
Label()
-- diagnostics.golden --
-- generated.x.go.golden --
