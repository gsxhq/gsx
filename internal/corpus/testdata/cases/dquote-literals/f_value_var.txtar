# The `"`-delimited plain-text literal used as a first-class Go VALUE in a
# top-level `var` initializer (`var g = f"id-@{n}"`). Like the f`…` value form
# it lowers to a plain Go string concat (embeddedValueExpr); the `"` delimiter
# is used so the content can hold a literal backtick.
-- input.gsx --
package demo

var n = "x1"

var g = f"id-`@{n}`"

component Uses() {
	<p>{ g }</p>
}
-- invoke --
Uses()
-- diagnostics.golden --
-- render.golden --
<p>id-`x1`</p>
-- generated.x.go.golden --
