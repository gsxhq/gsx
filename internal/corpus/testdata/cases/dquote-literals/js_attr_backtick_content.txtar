# The `"`-delimited js literal (js"…") is the escape-hatch for JS whose content
# contains a backtick — here a JS template literal `hi ${…}`. Semantically it is
# identical to js`…`: the backtick is free/literal inside a `"` literal, `@{x}`
# is still the gsx interpolation hole, and the whole value is JS-escaped for the
# @click sink. Only the delimiter differs.
-- input.gsx --
package p

component Button(x string) {
	<button @click=js"const t = `hi @{x}`; send(t)">Save</button>
}
-- invoke --
Button(ButtonProps{X: "abc"})
