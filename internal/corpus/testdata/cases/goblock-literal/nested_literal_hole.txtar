# W3: a nested f`` literal inside an f`` literal's @{ } hole, the outer literal
# assigned in a {{ }} Go block. A GoBlock has no clean pre-statement hoist
# channel (its reconstruction interleaves GoText into the hoist buffer), so
# canHoist=false there; the inner literal stays pure (a static string), which
# that position allows, and lowers to a plain string concat.
-- input.gsx --
package demo

component Page() {
	{{ h := f`a @{ f`b` }` }}
	<p>{h}</p>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<p>a b</p>
-- generated.x.go.golden --
