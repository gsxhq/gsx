# An f`…@{x}…` (EmbeddedText) literal assigned in a {{ }} Go block, then
# rendered as ordinary text. Closes the pre-existing f-in-{{ }} gap: before
# GoBlock.Embedded, ANY prefixed literal inside a {{ }} block was invalid Go at
# skeleton parse. In Go-expression position f` lowers to a plain Go string
# concat (no RawJS/RawCSS wrap, no per-hole escaping — `"hello " + string(name)`);
# escaping happens where the resulting string is consumed, here the
# HTML-text-escaping _gsxgw.Text sink of `<p>{greeting}</p>`.
-- input.gsx --
package demo

component Page(name string) {
	{{ greeting := f`hello @{name}` }}
	<p>{greeting}</p>
}
-- invoke --
Page(PageProps{Name: "World"})
-- diagnostics.golden --
-- render.golden --
<p>hello World</p>
-- generated.x.go.golden --
