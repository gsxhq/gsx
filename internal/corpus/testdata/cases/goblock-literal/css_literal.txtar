# A css`…@{x}…` literal as a gsx.Attrs "style" value built in a {{ }} Go block,
# then spread onto an element. The literal lowers to _gsxrt.RawCSS(...) (holes
# CSS-value-filtered at assembly); the element spread composes it through the
# style merge (StyleValue passes RawCSS verbatim). Pins css` (EmbeddedCSS) lang
# support inside {{ }}. Kept single-line so the (not-yet-literal-aware)
# formatter round-trips it.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Page(color string) {
	{{ s := gsx.Attrs{{Key: "style", Value: css`color:@{color}`}} }}
	<div {s...} style="margin:0">x</div>
}
-- invoke --
Page("teal")
-- diagnostics.golden --
-- render.golden --
<div style="margin:0; color:teal">x</div>
-- generated.x.go.golden --
