# A gsx.RawJS hole in a JS binding position inside a <script> block: the
# assignment target splices verbatim (emitJSValue's JSCtxBinding case). Contrast
# interp_identifier_rejected.txtar, the non-RawJS rejection on the same path.
-- input.gsx --
package demo

import "github.com/gsxhq/gsx"

component Page(path string) {
	<script>@{gsx.RawJS(path)} = 1;</script>
}
-- invoke --
Page(PageProps{Path: "window.foo"})
-- diagnostics.golden --
-- render.golden --
<script>window.foo = 1;</script>
