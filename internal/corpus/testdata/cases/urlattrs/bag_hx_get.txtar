# Bag hardening Part A: a URL attribute carrying a safe relative value survives
# unchanged. hx-get is no longer a built-in URL sink, so this case opts into the
# "htmx" preset; hx-get="/path" forwarded through a bag is then extracted and
# written through URLVal, which passes the relative path as-is (it renders at the
# guard block, before the residual spread).
-- gsx.toml --
url_presets = ["htmx"]
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type ctrlProps struct {
	Attrs gsx.Attrs
}

component Ctrl(p ctrlProps) {
	<button { p.Attrs... }>go</button>
}

component Page() {
	<Ctrl hx-get={"/path"} data-role={"tab"}/>
}
-- invoke --
Page()
-- diagnostics.golden --
14:8: Ctrl has no attrs param; unexpected attribute "hx-get"
14:25: Ctrl has no attrs param; unexpected attribute "data-role"
-- render.golden --
-- generated.x.go.golden --
