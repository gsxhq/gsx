# Proves DirOptions.Classifier plumbing: a case-local gsx.toml declares
# data-x as a URL-context attribute via [[url_attrs]]; a PLAIN ELEMENT (not a
# bag-forwarding spread) already routes CtxURL attrs through the sanitizing
# writer at emit time, so this pins the per-case classifier reaching codegen
# without needing the bag-forwarding extraction work (a later task).
-- gsx.toml --
[[url_attrs]]
name = "data-x"
-- input.gsx --
package views

component Bad(u string) { <div data-x={u}>x</div> }
-- invoke --
Bad("javascript:alert(1)")
-- diagnostics.golden --
-- render.golden --
<div data-x="about:invalid#gsx">x</div>
-- generated.x.go.golden --
// Code generated by gsx; DO NOT EDIT.

package views

import (
	_gsxctx "context"
	_gsxrt "github.com/gsxhq/gsx"
	_gsxio "io"
)

//line input.gsx:3:1
func Bad(u string) _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:3:27
		_gsxgw.S("<div data-x=\"")
		_gsxgw.URL(string(u))
		_gsxgw.S("\">x</div>")
		return _gsxgw.Err()
	})
}
