# W3: a nested f`` literal inside a URL-context attribute f`` literal's @{ }
# hole (href). The inner literal lowers to a string concat that the outer hole
# consumes; the whole assembled attribute value is then URL-sanitized ONCE by
# _gsxgw.URL, unaffected by the nesting — render pins that whole-value
# sanitization still applies.
-- input.gsx --
package demo

component Page(id string) {
	<a href=f`/u/@{ f`@{id}` }`>x</a>
}
-- invoke --
Page(PageProps{Id: "abc"})
-- diagnostics.golden --
-- render.golden --
<a href="/u/abc">x</a>
