# Benign duplicate: static href + case-variant HREF in bag. A forwarding element
# writes `href={p.Link}` before `{ p.Attrs... }`, where p.Attrs carries uppercase
# HREF. Both are extracted, sanitized independently, and both render as href attributes.
# This exercises the "pre-spread static + case-insensitive bag key" edge from
# hardening Part A. The static value wins on collision (ordered-first rule), but both
# attributes must be present and sanitized.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(link string, cardAttrs gsx.Attrs) {
	<a href={link} { cardAttrs... }>click</a>
}

component Page() {
	<Card link="/safe" card-attrs={{ "HREF": "javascript:alert(1)" }}/>
}
-- invoke --
Page()
