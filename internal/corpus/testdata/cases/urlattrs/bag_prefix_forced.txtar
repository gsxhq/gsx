# A project [[urlAttrs]] PREFIX rule whose forwarding element ALSO force-owns a
# prefix-matched name (a static attr after the bag spread) must let the forced
# attr win: SpreadURLPrefixed skips the force-owned key so no duplicate renders
# and the caller cannot smuggle a value past the forced one. data-url-go is
# forced to /forced (the caller's javascript: copy is dropped, not sanitized-and-
# duplicated); an unrelated prefix key data-url-keep still writes sanitized.
-- gsx.toml --
[[urlAttrs]]
prefix = "data-url-"
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type navProps struct {
	Attrs gsx.Attrs
}

component Nav(p navProps) {
	<a { p.Attrs... } data-url-go="/forced">x</a>
}

component Page() {
	<Nav data-url-go={"javascript:alert(1)"} data-url-keep={"/safe"}/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<a data-url-keep="/safe" data-url-go="/forced">x</a>
-- generated.x.go.golden --
