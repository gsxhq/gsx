# Bag hardening Part A: a project [[urlAttrs]] PREFIX rule (data-url-) cannot be
# enumerated into Get blocks, so the leaf walks the bag with SpreadURLPrefixed
# and writes every prefix-matched key through the strict URL sink. data-url-next
# is sanitized; an unrelated data-x is untouched and keeps its bag order.
-- gsx.toml --
[[urlAttrs]]
prefix = "data-url-"
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type navProps struct {
	Attrs gsx.Attrs
}

component Nav(p navProps) {
	<div { p.Attrs... }>x</div>
}

component Page() {
	<Nav data-url-next={"javascript:alert(1)"} data-x={"keep"}/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-url-next="about:invalid#gsx" data-x="keep">x</div>
-- generated.x.go.golden --
