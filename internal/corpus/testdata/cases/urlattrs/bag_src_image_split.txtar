# Bag hardening Part A: the tag-aware sink split applies to extracted bag
# attributes. The SAME data:image/png value passes through when forwarded to an
# <img src> (an image-resource sink, URLImageVal) but is rejected on an <a href>
# (a navigational sink, URLVal) → about:invalid#gsx.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type imgProps struct {
	Attrs gsx.Attrs
}

type anchorProps struct {
	Attrs gsx.Attrs
}

component Img(p imgProps) {
	<img { p.Attrs... }/>
}

component Anchor(p anchorProps) {
	<a { p.Attrs... }>x</a>
}

component Page() {
	<div>
		<Img src={"data:image/png;base64,iVBORw0KGgo="}/>
		<Anchor href={"data:image/png;base64,iVBORw0KGgo="}/>
	</div>
}
-- invoke --
Page()
