# Bag hardening Part A, adversarial: a case-variant key (HREF) must NOT smuggle
# an unsanitized URL past the leaf. Bag keys are author data preserved verbatim,
# but the leaf matches URL names case-insensitively (GetFold / WithoutFold), so
# the payload is extracted, sanitized to about:invalid#gsx, and normalized to the
# lowercase name on output — never spread raw. Uses a named gsx.Attrs param with
# an ordered-attrs literal so the uppercase key reaches the bag unchanged.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Link(linkAttrs gsx.Attrs) {
	<a { linkAttrs... }>go</a>
}

component Page() {
	<Link link-attrs={{ "HREF": "javascript:alert(1)" }}/>
}
-- invoke --
Page()
-- diagnostics.golden --
10:8: Link has no attrs param; unexpected attribute "link-attrs"
-- render.golden --
-- generated.x.go.golden --
