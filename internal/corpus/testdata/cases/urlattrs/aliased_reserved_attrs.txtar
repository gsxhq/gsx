# The reserved attrs role is recognized when its type is spelled through an
# aliased gsx import. A caller-supplied URL still reaches the leaf URL sink and
# the dangerous scheme sanitizes to about:invalid#gsx.
-- input.gsx --
package views

import g "github.com/gsxhq/gsx"

component Chip(attrs g.Attrs) {
	<a { attrs... }>x</a>
}

component Page() {
	<Chip href="javascript:alert(1)"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<a href="about:invalid#gsx">x</a>
