# Bag hardening Part A: gsx.RawURL is the author's vouch — a value wrapped in it
# passes through the leaf's URLVal extraction verbatim (still attribute-escaped),
# so an exotic but intended scheme (app://) survives instead of collapsing to
# about:invalid#gsx.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type linkProps struct {
	Attrs gsx.Attrs
}

component Link(p linkProps) {
	<a { p.Attrs... }>go</a>
}

component Page() {
	<Link href={gsx.RawURL("app://z")}/>
}
-- invoke --
Page()
-- diagnostics.golden --
14:8: Link has no attrs param; unexpected attribute "href"
