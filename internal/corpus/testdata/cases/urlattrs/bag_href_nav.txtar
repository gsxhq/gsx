# Bag hardening Part A: a URL-classified attribute (href) smuggled through a
# byo component's fallthrough bag is sanitized at the forwarding <a>. A
# javascript: value collapses to about:invalid#gsx; a safe relative href passes
# through unchanged (extracted to the guard block, so it renders before the
# residual spread).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type linkProps struct {
	Attrs gsx.Attrs
}

component Link(p linkProps) {
	<a { p.Attrs... }>go</a>
}

component Page() {
	<div>
		<Link href={"javascript:alert(1)"}/>
		<Link href={"/ok"}/>
	</div>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div><a href="about:invalid#gsx">go</a><a href="/ok">go</a></div>
