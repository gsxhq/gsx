# The NEW default: without the "htmx" preset, hx-get is a plain attribute, NOT a
# URL sink. A javascript: value is written RAW (only HTML-attribute-escaped),
# never sanitized to about:invalid#gsx. This pins the default-behavior change:
# htmx method attrs are opt-in (see htmx_preset.txtar), off by default.
-- input.gsx --
package views

component Nav(u string) { <a hx-get={u}>x</a> }
-- invoke --
Nav("javascript:alert(1)")
-- diagnostics.golden --
-- render.golden --
<a hx-get="javascript:alert(1)">x</a>
