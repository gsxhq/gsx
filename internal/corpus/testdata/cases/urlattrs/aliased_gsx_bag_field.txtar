# import (`Attrs g.Attrs`) must classify as a forwarding bag exactly like
# `gsx.Attrs` does. Otherwise `{ p.Attrs... }` in the body takes the raw inline
# spread and a caller-supplied URL renders UNSANITIZED — reachable from pure
# template source (`<Chip href="javascript:...">` fills the field name-based).
# The bag field is now classified against the struct's DECLARING-file import
# qualifiers, so the dangerous scheme sanitizes to about:invalid#gsx at the leaf.
-- input.gsx --
package views

import g "github.com/gsxhq/gsx"

type props struct {
	Attrs g.Attrs
}

component Chip(p props) {
	<a { p.Attrs... }>x</a>
}

component Page() {
	<Chip href="javascript:alert(1)"/>
}
-- invoke --
Page()
