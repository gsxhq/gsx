# Bag hardening Part A: a URL-classified attribute (href) collected by the
# explicit attrs role is sanitized at the forwarding <a>. A javascript: value
# collapses to about:invalid#gsx; a safe relative href passes through unchanged.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Link(attrs gsx.Attrs) {
	<a { attrs... }>go</a>
}

component Page() {
	<div>
		<Link href={"javascript:alert(1)"}/>
		<Link href={"/ok"}/>
	</div>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div><a href="about:invalid#gsx">go</a><a href="/ok">go</a></div>
