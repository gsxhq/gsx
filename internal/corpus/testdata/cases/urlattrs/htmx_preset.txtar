	U string
}

//line input.gsx:3:1
func Nav(_gsxp NavProps) _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		u := _gsxp.U
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:3:27
		_gsxgw.S("<a hx-get=\"")
		_gsxgw.URL(string(u))
		_gsxgw.S("\">x</a>")
		return _gsxgw.Err()
	})
}
