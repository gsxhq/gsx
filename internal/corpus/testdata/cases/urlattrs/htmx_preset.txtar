# The opt-in "htmx" preset re-enables the five htmx method attributes as URL
# sinks. With url_presets = ["htmx"] a javascript: value on hx-get is sanitized
# to about:invalid#gsx at emit time, exactly as href would be. This proves the
# preset flows through the per-case Classifier into codegen.
-- gsx.toml --
url_presets = ["htmx"]
-- input.gsx --
package views

component Nav(u string) { <a hx-get={u}>x</a> }
-- invoke --
Nav(NavProps{U: "javascript:alert(1)"})
-- diagnostics.golden --
-- render.golden --
<a hx-get="about:invalid#gsx">x</a>
-- generated.x.go.golden --
