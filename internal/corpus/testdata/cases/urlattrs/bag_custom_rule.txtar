# Bag hardening Part A: a project [[urlAttrs]] exact-name rule (data-href) makes
# that name URL-classified, so a value smuggled through a fallthrough bag is
# extracted and sanitized at the leaf just like a built-in URL attribute.
-- gsx.toml --
[[urlAttrs]]
name = "data-href"
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type widgetProps struct {
	Attrs gsx.Attrs
}

component Widget(p widgetProps) {
	<div { p.Attrs... }>x</div>
}

component Page() {
	<Widget data-href={"javascript:alert(1)"}/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-href="about:invalid#gsx">x</div>
-- generated.x.go.golden --
