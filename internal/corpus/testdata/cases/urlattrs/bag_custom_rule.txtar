# Bag hardening Part A: a project [[url_attrs]] exact-name rule (data-href) makes
# that name URL-classified, so a value carried by an ordinary struct prop is
# extracted and sanitized at the leaf just like a built-in URL attribute.
-- gsx.toml --
[[url_attrs]]
name = "data-href"
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type widgetProps struct {
	Attrs gsx.Attrs
}

component Widget(p widgetProps) {
	<div { p.Attrs... }>x</div>
}

component Page() {
	<Widget p={widgetProps{Attrs: gsx.Attrs{{Key: "data-href", Value: "javascript:alert(1)"}}}}/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-href="about:invalid#gsx">x</div>
-- generated.x.go.golden --
