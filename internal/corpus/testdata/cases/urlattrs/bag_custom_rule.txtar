# Bag hardening Part A: a project [[url_attrs]] exact-name rule (data-href) makes
# that name URL-classified, so a value smuggled through a fallthrough bag is
# extracted and sanitized at the leaf just like a built-in URL attribute.
-- gsx.toml --
[[url_attrs]]
name = "data-href"
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type widgetProps struct {
	Attrs gsx.Attrs
}

component Widget(p widgetProps) {
	<div { p.Attrs... }>x</div>
}

component Page() {
	<Widget data-href={"javascript:alert(1)"}/>
}
-- invoke --
Page()
-- diagnostics.golden --
14:10: Widget has no attrs param; unexpected attribute "data-href"
-- render.golden --
-- generated.x.go.golden --
