-- model.go --
package views

type tag struct{ name string }

func (t tag) String() string { return "#" + t.name }

-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Label(text gsx.Node) {
	<span>{text}</span>
}

component Page(t tag) {
	<Label text={t}/>
}
-- invoke --
Page(tag{name: "go"})
-- diagnostics.golden --
-- render.golden --
