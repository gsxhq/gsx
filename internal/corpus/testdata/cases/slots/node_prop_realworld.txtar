-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, body gsx.Node) {
	<article><h2>{title}</h2><section>{body}</section></article>
}

component Page(count int) {
	<Card title="My Card" body={count}/>
	<Card title={ <strong>Bold Title</strong> } body={ gsx.Raw("<em>raw</em>") }/>
}
-- invoke --
Page(PageProps{Count: 42})
-- diagnostics.golden --
-- render.golden --
<article><h2>My Card</h2><section>42</section></article><article><h2><strong>Bold Title</strong></h2><section><em>raw</em></section></article>
