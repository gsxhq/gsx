# A composable/conditional style={ … } beside a LONE cond-nested spread. The
# conditional style IS a root style, so hasRootClassStyle fires and the element
# folds (a bare inline `if c { Spread }` would emit a SECOND style attribute
# whenever the bag carries one — the same duplicate-attr bug O1 fixes for
# class). composeBag lowers the composable style as the VALUE form
# gsx.StyleString(…) into the bag's "style" entry, and the leaf aggregates it
# with the bag's own style via Attrs.Style(). Before Part B, composeBag rejected
# any non-class ClassAttr ("style attribute in a conditional branch … not
# supported yet") and this hard-errored though the inline path compiled it.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component StyleCondLoneSpread(on bool, c bool, x gsx.Attrs) {
	<div style={ "color:red": on } { if c { { x... } } }>hi</div>
}
-- invoke --
StyleCondLoneSpread(StyleCondLoneSpreadProps{On: true, C: true, X: gsx.Attrs{{Key: "style", Value: "margin:0"}}})
-- diagnostics.golden --
-- render.golden --
<div style="color:red; margin:0">hi</div>
