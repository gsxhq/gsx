# An interposed embedded-hole attr (title=f"Hi @{who}") sits between two spreads
# on an element. Because >=2 top-level spreads force the full fold, the embedded
# text attr must be lowered into the ConcatAttrs bag as {Key, Value: <assembled
# string>} rather than rejected as a "component prop". The hole interpolates at
# render time exactly as it would on the inline (0/1-spread) path.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component InterposedEmbeddedHole(a gsx.Attrs, who string, b gsx.Attrs) {
	<div title=f"Hi @{who}" { a... } { b... }>x</div>
}
-- invoke --
InterposedEmbeddedHole(InterposedEmbeddedHoleProps{
	A: gsx.Attrs{{Key: "data-a", Value: "1"}},
	Who: "World",
	B: gsx.Attrs{{Key: "data-b", Value: "2"}},
})
-- diagnostics.golden --
-- render.golden --
<div title="Hi World" data-a="1" data-b="2">x</div>
-- generated.x.go.golden --
