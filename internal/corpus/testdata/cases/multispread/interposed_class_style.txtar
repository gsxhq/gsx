# An interposed static class + style sits between two spreads. class tokens
# AGGREGATE across every bag/static in source order (space-joined, no dedup —
# ClassMerged's job, not tested here). style AGGREGATES too, but StyleMerged
# then dedupes by CSS PROPERTY, last occurrence wins: p's "margin:0" is a
# distinct property from the static's/q's "color" so it survives; the static's
# "color:red" and q's "color:blue" collide on "color" and q (later in source
# order) wins.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component InterposedClassStyle(p gsx.Attrs, q gsx.Attrs) {
	<div { p... } class="x" style="color:red" { q... }>y</div>
}
-- invoke --
InterposedClassStyle(gsx.Attrs{{Key: "class", Value: "p"}, {Key: "style", Value: "margin:0"}}, gsx.Attrs{{Key: "class", Value: "q"}, {Key: "style", Value: "color:blue"}})
-- diagnostics.golden --
-- render.golden --
<div class="p x q" style="margin:0; color:blue">y</div>
-- generated.x.go.golden --
