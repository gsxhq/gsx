# Probe and emit folds keep an expression/call attribute before a conditional
# bag in the same source position.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func label(v string) string { return v }

component Page(on bool, extra gsx.Attrs) {
	<div data-a={ label("a") } { if on { { extra... } } } { gsx.Attrs{{Key: "data-z", Value: "z"}}... }>x</div>
}
-- invoke --
Page(true, gsx.Attrs{{Key: "data-b", Value: "b"}})
-- diagnostics.golden --
-- render.golden --
<div data-a="a" data-b="b" data-z="z">x</div>
