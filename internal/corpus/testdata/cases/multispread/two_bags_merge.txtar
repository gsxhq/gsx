# Two local bags spread on one element merge by source order (issue #75): every
# spread is a forwarding sink, and ≥2 fold into one ConcatAttrs — b1 then b2, so
# a colliding key would take b2's value. Here the keys are disjoint (href, id).
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Link() {
	{{ b1 := gsx.Attrs{{Key: "href", Value: "/a"}} }}
	{{ b2 := gsx.Attrs{{Key: "id", Value: "x"}} }}
	<a { b1... } { b2... }>click</a>
}
-- invoke --
Link()
-- diagnostics.golden --
-- render.golden --
<a href="/a" id="x">click</a>
