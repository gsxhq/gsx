# An interposed pipe-hole attr (href={ u |> trim }, using the built-in `trim`
# filter — mirrors pipelines/attr_url's config-free setup) sits between two
# spreads; neither bag touches href, so the piped value alone determines it,
# folded and sanitized at the same leaf as everything else.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component InterposedPipeHole(p gsx.Attrs, u string, q gsx.Attrs) {
	<a { p... } href={ u |> trim } { q... }>x</a>
}
-- invoke --
InterposedPipeHole(InterposedPipeHoleProps{
	P: gsx.Attrs{{Key: "data-a", Value: "1"}},
	U: "  /clean  ",
	Q: gsx.Attrs{{Key: "data-b", Value: "2"}},
})
-- diagnostics.golden --
-- render.golden --
<a data-a="1" href="/clean" data-b="2">x</a>
