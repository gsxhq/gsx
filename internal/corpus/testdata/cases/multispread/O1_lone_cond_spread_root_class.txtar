# O1 probe (issue #75): a LONE cond-nested spread (exactly one spread total)
# alongside a ROOT static class. Before the fix, this bypassed the ≥2-spread
# fold and routed through the inline emitAttr `if cond { Spread(bag,
# excluded=nil) }` path, which doesn't know about the sibling root class and
# emitted a SECOND raw `class="extra"` attribute (duplicate class, invalid
# HTML) instead of aggregating with "root". Fixed by extending the fold
# trigger to also fire for a single spread that is cond-nested — it now
# renders through the same ConcatAttrs + class/style-merge site as every
# other spread shape, so root and bag class merge to one attribute.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component O1(on bool, extra gsx.Attrs) {
	<div class="root" { if on { { extra... } } }>x</div>
}
-- invoke --
O1(O1Props{On: true, Extra: gsx.Attrs{{Key: "class", Value: "extra"}}})
-- diagnostics.golden --
-- render.golden --
<div class="root extra">x</div>
-- generated.x.go.golden --
