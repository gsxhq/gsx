# A multi-spread element whose second spread is a methodless []gsx.Attr
# (variadic param captured by direct factory markup) folds through
# ConcatAttrs, whose ...Attrs parameter accepts []gsx.Attr by assignability —
# no per-operand conversion needed. Pins the fold path's exemption from the
# spread-boundary gsx.Attrs normalization.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func named(name string) func(...gsx.Attr) gsx.Node {
	return func(attrs ...gsx.Attr) gsx.Node {
		return <svg class="size-5" { gsx.Attrs{{Key: "data-x", Value: "1"}}... } { attrs... }>{ name }</svg>
	}
}

var Search = named("search")

component Page() {
	<Search class="size-4" data-x="2"/>
}
-- invoke --
Page()
