# A JS embedded hole between two spreads folds through the shared attribute bag.
# Its JS-context escaping happens before Spread performs the single HTML escape.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component JSCssHoleTwoSpreads(u string, p gsx.Attrs, q gsx.Attrs) {
	<button { p... } onclick=js"do(@{u})" { q... }>go</button>
}
-- diagnostics.golden --
