package views

import "github.com/gsxhq/gsx"

component CondInterposedStatic(c bool, p gsx.Attrs, q gsx.Attrs) {
	<div { p... } { if c { title="t" } } { q... }>z</div>
}
-- invoke --
CondInterposedStatic(CondInterposedStaticProps{
	C: true,
	P: gsx.Attrs{{Key: "data-a", Value: "1"}},
	Q: gsx.Attrs{{Key: "data-b", Value: "2"}},
})
-- diagnostics.golden --
