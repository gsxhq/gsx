# A js`…@{}…` embedded-hole attribute beside a LONE cond-nested spread, with NO
# root class/style. hasRootClassStyle is false, so the element does NOT fold —
# it takes the inline path, which supports js/css embedded holes natively
# (onclick="do(" + JSValAttr(u) + ")") and emits the lone cond-nested spread as
# a guarded `if c { Spread(x, …) }`. Before Part A this folded (the O1 change
# made every lone cond-nested spread fold) and composeBag rejected the js hole
# ("cannot be used as a component prop … yet") — a regression, since the inline
# path compiled it before. Narrowing the fold trigger restores the inline path.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component JSCssHoleLoneSpread(c bool, u string, x gsx.Attrs) {
	<button onclick=js"do(@{u})" { if c { { x... } } }>go</button>
}
-- invoke --
JSCssHoleLoneSpread(true, "x", gsx.Attrs{{Key: "id", Value: "b"}})
-- diagnostics.golden --
-- render.golden --
<button onclick="do(&#34;x&#34;)" id="b">go</button>
