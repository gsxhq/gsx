# Folded element attributes preserve source evaluation order and conditional
# branches remain lazy.
-- helpers.go --
package views

import (
	"context"
	"fmt"
	"io"
	"strings"

	"github.com/gsxhq/gsx"
)

func checkedPage() gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		calls = nil
		if err := Page(true).Render(ctx, w); err != nil {
			return err
		}
		if got := strings.Join(calls, ","); got != "a,b,c" {
			return fmt.Errorf("taken evaluation order = %s, want a,b,c", got)
		}
		calls = nil
		if err := Page(false).Render(ctx, io.Discard); err != nil {
			return err
		}
		if got := strings.Join(calls, ","); got != "a,c" {
			return fmt.Errorf("untaken evaluation order = %s, want a,c", got)
		}
		return nil
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

var calls []string

func bag(mark string) gsx.Attrs {
	calls = append(calls, mark)
	return gsx.Attrs{{Key: "data-k", Value: mark}}
}

component Page(on bool) {
	<div { bag("a")... } { if on { { bag("b")... } } } { bag("c")... }>x</div>
}
-- invoke --
checkedPage()
-- diagnostics.golden --
-- render.golden --
<div data-k="c">x</div>
