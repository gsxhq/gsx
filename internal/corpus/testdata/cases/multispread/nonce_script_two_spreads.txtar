# Two spreads on <script>: nonce injection still applies to the folded bag
# (neither spread carries "nonce", so the guard injects it), mirroring the
# nonce package's withTestNonce wrapper convention.
-- support.go --
package views

import (
	"context"
	"io"

	"github.com/gsxhq/gsx"
)

func withTestNonce(n gsx.Node) gsx.Node {
	return gsx.Func(func(ctx context.Context, w io.Writer) error {
		return n.Render(gsx.WithNonce(ctx, "r4nd0m"), w)
	})
}
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component NonceTwoSpreads(p gsx.Attrs, q gsx.Attrs) {
	<script { p... } { q... }>init()</script>
}
-- invoke --
withTestNonce(NonceTwoSpreads(NonceTwoSpreadsProps{
	P: gsx.Attrs{{Key: "id", Value: "s"}},
	Q: gsx.Attrs{{Key: "data-x", Value: "1"}},
}))
-- diagnostics.golden --
-- render.golden --
<script id="s" data-x="1" nonce="r4nd0m">init()</script>
