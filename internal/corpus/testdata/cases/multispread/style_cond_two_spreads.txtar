package views

import "github.com/gsxhq/gsx"

component StyleCondTwoSpreads(on bool, p gsx.Attrs, q gsx.Attrs) {
	<div { p... } style={ "color:red": on } { q... }>hi</div>
}
-- invoke --
StyleCondTwoSpreads(StyleCondTwoSpreadsProps{
	On: true,
	P:  gsx.Attrs{{Key: "style", Value: "margin:0"}},
	Q:  gsx.Attrs{{Key: "style", Value: "color:blue"}},
})
-- diagnostics.golden --
-- render.golden --
