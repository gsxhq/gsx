	_gsxctx "context"
	_gsxrt "github.com/gsxhq/gsx"
	_gsxio "io"
)

//line input.gsx:3:1
type widget struct {
	Label string
	Count int
}

//line input.gsx:8:1
func (gsx widget) Show() _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
//line input.gsx:9:2
		_gsxgw.S("<b>")
//line input.gsx:9:5
		_gsxgw.Text(string(gsx.Label))
		_gsxgw.S("</b>")
		return _gsxgw.Err()
	})
}

//line input.gsx:12:1
func (strconv widget) Tally() _gsxrt.Node {
	return _gsxrt.Func(func(ctx _gsxctx.Context, _gsxw _gsxio.Writer) error {
		_gsxgw := _gsxrt.W(_gsxw)
		var _gsxnum [32]byte
//line input.gsx:13:2
		_gsxgw.S("<i>")
//line input.gsx:13:5
		_gsxgw.IntInto(_gsxnum[:], int64(strconv.Count))
		_gsxgw.S("</i>")
		return _gsxgw.Err()
	})
}
