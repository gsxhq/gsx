# checkReservedRecvVar used to reject a method-component receiver var named
# `gsx` (or `strconv`) as a stopgap for the emitter naming the runtime package
# `gsx` inside method bodies. Generator references are now _gsx-aliased
# (_gsxrt, _gsxctx, _gsxio, ...), so nothing in the emitted method body can be
# shadowed by a receiver var named `gsx` or `strconv` — the reservation is
# gone (see param_named_gsx.txtar for the sibling param-name case). This case
# pins that both receiver var names are legal, generate compiling code, and
# render correctly; the golden below is checked to literally contain
# `func (gsx ...)` / `func (strconv ...)` and `_gsxrt.` so a regression that
# reintroduces the old rejection — or renames the runtime import back to a
# collidable `gsx` — would be caught here.
-- input.gsx --
package demo

type widget struct {
	Label string
	Count int
}

component (gsx widget) Show() {
	<b>{ gsx.Label }</b>
}

component (strconv widget) Tally() {
	<i>{ strconv.Count }</i>
}
-- invoke --
(widget{Label: "ok", Count: 3}).Show()
-- diagnostics.golden --
-- render.golden --
<b>ok</b>
-- generated.x.go.golden --
