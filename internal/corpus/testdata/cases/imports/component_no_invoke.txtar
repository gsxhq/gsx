	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:4:2
		_gsxgw.S("<b>hi</b>")
		return _gsxgw.Err()
	})
}
