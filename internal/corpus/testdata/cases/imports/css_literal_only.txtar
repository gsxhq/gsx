# Context: `css"…"` is a gsx feature that lowers to a call to gsx.RawCSS() with
# interpolated values passed through gsx.FilterCSS(). Unlike f"…" which needs
# no import, css"…" literals require the _gsxrt import for RawCSS and FilterCSS.
# Pins that css-literal lowering creates import need-tracking for the runtime.
-- input.gsx --
package demo

var c = "red"

var S = css`color:@{c}`
-- diagnostics.golden --
-- generated.x.go.golden --
// Code generated by gsx; DO NOT EDIT.

package demo

import (
	_gsxrt "github.com/gsxhq/gsx"
)

/*line input.gsx:1:13*/

var c = "red"

var S = _gsxrt.RawCSS("color:" + _gsxrt.FilterCSS(string(c))) /*line input.gsx:5:24*/
