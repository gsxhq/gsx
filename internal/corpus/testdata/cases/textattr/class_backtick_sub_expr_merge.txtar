# a class value that STARTS with a backtick raw string but is a Go sub-expression
# (`box-` + variant) must remain a composed ClassAttr so it MERGES with a
# forwarded bag class (regression: it was becoming ExprAttr and dropping its own).
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Box(variant string, attrs gsx.Attrs) {
	<div class={`box-` + variant} { attrs... }>x</div>
}
-- invoke --
Box("big", gsx.Attrs{{Key: "class", Value: "w-full"}, {Key: "id", Value: "b"}})
