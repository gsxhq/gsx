# URL context: the whole value ("/u/" + id + "/edit") is assembled and sanitized
# by _gsxgw.URL. A rooted relative path passes through unchanged.
-- input.gsx --
package p

component Link(id string) {
	<a href=`/u/@{id}/edit`>go</a>
}
-- invoke --
Link(LinkProps{Id: "7"})
-- diagnostics.golden --
-- render.golden --
<a href="/u/7/edit">go</a>
