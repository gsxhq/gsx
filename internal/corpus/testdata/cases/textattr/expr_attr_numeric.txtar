# plain expr attribute (attr={n}) with int/uint/float values: each renders via the
# per-render numeric scratch buffer (IntInto/UintInto/FloatInto) — no strconv, no
# attr-escaping — since a decimal number is byte-identical and safe in attr context.
-- input.gsx --
package views

component Metrics(i int, u uint, f float64) {
	<div data-i={i} data-u={u} data-f={f}>x</div>
}
-- invoke --
Metrics(MetricsProps{I: -7, U: 42, F: 3.5})
-- diagnostics.golden --
-- render.golden --
<div data-i="-7" data-u="42" data-f="3.5">x</div>
