# URL context: the whole value (base + "/edit") is assembled and sanitized by
# _gsxgw.URL. A safe https origin from the hole passes through.
-- input.gsx --
package p

component Link(base string) {
	<a href=`@{base}/edit`>go</a>
}
-- invoke --
Link(LinkProps{Base: "https://ex.com/u"})
-- diagnostics.golden --
