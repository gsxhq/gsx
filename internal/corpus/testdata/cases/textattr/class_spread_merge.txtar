# scope A (class): a class backtick literal is a first-class merge target — a spread
# bag's class merges caller-last into the interpolated class value; no duplicate
# attribute. Mirrors fallthrough/static_class_merge but with an interpolated own-class.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Badge(variant string, attrs gsx.Attrs) {
	<span class=f`badge-@{variant}` { attrs... }>Hi</span>
}
-- invoke --
Badge("x", gsx.Attrs{{Key: "class", Value: "hl"}, {Key: "id", Value: "a"}})
