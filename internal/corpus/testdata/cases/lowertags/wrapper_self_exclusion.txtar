# THE wrapper pattern: inside component div's own body, <div> is the leaf
# element (self-exclusion) — no infinite recursion, no extra syntax.
-- input.gsx --
package views

component div() {
	<div class="wrapped">{children}</div>
}

component Page() {
	<div>hi</div>
}
