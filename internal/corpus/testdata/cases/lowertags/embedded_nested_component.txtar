# Regression: components NESTED inside an embedded element literal in a Go
# hole must still be recognized. splitInterpEmbedded materializes the WHOLE
# subtree (`<Outer><Inner/><card/></Outer>`) after the file-level
# resolveComponentTags pass, so the stamp has to be applied at every depth of
# the materialized literal — not just its top-level part. A bug here is
# silent (emit≡probe agree): <Inner/> and <card/> would render as literal
# tag bytes instead of invoking their components. Pins BOTH a capitalized
# nested component (Inner) and a lowercase one (card) so the new lowercase
# resolution rule is exercised on this path too.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func wrap(n gsx.Node) gsx.Node { return n }

component Inner() {
	<i>in</i>
}

component card() {
	<em>c</em>
}

component Outer(children gsx.Node) {
	<b>{children}</b>
}

component Page() {
	<div>{ wrap(<Outer><Inner/><card/></Outer>) }</div>
}
-- invoke --
Page()
-- diagnostics.golden --
