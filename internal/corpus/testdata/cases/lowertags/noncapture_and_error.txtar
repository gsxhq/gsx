# (1) An import name must NOT capture a tag (<time> stays a leaf despite
# `import "time"` in a sibling). (2) A _test.go-only declaration must not
# capture (<gadget> stays a leaf). (3) A lowercase package symbol with a
# definitively non-component shape (var data int + <data>) is also a leaf.
-- model.go --
package views

import "time"

var _ = time.Now
var data int
-- helpers_test.go --
package views

func gadget() {}
-- input.gsx --
package views

component Page() {
	<time>t</time>
	<gadget>g</gadget>
	<data>d</data>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<time>t</time><gadget>g</gadget><data>d</data>
