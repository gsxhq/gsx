# A lowercase tag resolves to a package-level VAR holding a component value
# (element-literal var), not just funcs — "any decl counts".
-- input.gsx --
package views

var chip = <em class="chip">c</em>

component Page() {
	<chip/>
}
-- invoke --
Page()
-- diagnostics.golden --
6:3: component target package variable is not callable
-- render.golden --
