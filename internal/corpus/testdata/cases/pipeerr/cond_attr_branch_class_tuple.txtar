# A plain tuple-returning call (no pipeline) as a composed class part inside a
# component conditional-attr branch. Before this task, condBranchAttrs always
# called classEntryExpr with resolved=nil, so the emit-time "does this call
# return (T, error)?" check never fired here and a bare `cls(csv)` call would
# have leaked a raw go/types error (too many return values in single-value
# context) instead of hoisting cleanly. Now classEntryExpr receives the real
# thunk-local b/interpTemp/resolved from condBranchAttrs, so the tuple hoists
# `_gsxvN, _gsxerr := cls(csv); if _gsxerr != nil { return nil, _gsxerr }`
# inside the thunk exactly like the element-level case.
-- helpers.go --
package views

func cls(v string) (string, error) { return "c-" + v, nil }
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node) { <div { attrs... }>{title}</div> }

component Page(hot bool, csv string) {
	<Card title="Hi" { if hot { class={ cls(csv) } } } />
}
-- invoke --
Page(PageProps{Hot: true, Csv: "a,b"})
-- diagnostics.golden --
-- generated.x.go.golden --
