func Page(_gsxp PageProps) gsx.Node {
	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		hot := _gsxp.Hot
		csv := _gsxp.Csv
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:8:2
		_gsxv1, _gsxerr := gsx.AttrsCond(hot, func() (gsx.Attrs, error) {
			_gsxv0, _gsxerr := cls(csv)
			if _gsxerr != nil {
