# A generic (R, error) filter (First[T any]) as the FINAL pipeline stage: the
# existing per-context tuple auto-unwrap handles the instantiated result the
# same as any concrete-type filter.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import (
	"errors"
	"strings"
)

// First returns the first element; fails on an empty slice.
func First[T any](s []T) (T, error) {
	var zero T
	if len(s) == 0 {
		return zero, errors.New("first: empty")
	}
	return s[0], nil
}

// Parse splits a comma-separated list; fails on empty input.
func Parse(s string) ([]string, error) {
	if s == "" {
		return nil, errors.New("parse: empty input")
	}
	return strings.Split(s, ","), nil
}
-- input.gsx --
package views

component Tags(csv string) {
	<p>{ csv |> parse |> first }</p>
}
-- invoke --
Tags("a,b")
-- diagnostics.golden --
