# Two child-component expr-attr props, pinning the interleaving of TWO hoist
# passes: parse's mid-stage hoist happens INSIDE childPropsLiteral (attr source
# order) while the props literal is being built; pick's final-stage (T, error)
# tuple AND label's plain call are hoisted afterward by genChildComponent's
# unified "hoist-all-when-any" pass over ordered props (emit.go, the pass right
# after childPropsLiteral returns), which preserves left-to-right evaluation
# order once ANY prop value is a tuple.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import (
	"errors"
	"fmt"
	"strings"
)

// Parse splits a comma-separated list; fails on empty input.
func Parse(s string) ([]string, error) {
	if s == "" {
		return nil, errors.New("parse: empty input")
	}
	return strings.Split(s, ","), nil
}

// Pick returns element i; fails when out of range.
func Pick(s []string, i int) (string, error) {
	if i < 0 || i >= len(s) {
		return "", fmt.Errorf("pick: index %d out of range", i)
	}
	return s[i], nil
}
-- input.gsx --
package views

component Label(a string, b string) { <span>{a}{b}</span> }

component Page(csv string) {
	<Label a={ csv |> parse |> pick(0) } b={ shout() }/>
}

func shout() string { return "hi" }
-- invoke --
Page(PageProps{Csv: "ada,bob"})
-- diagnostics.golden --
