# A filter that both wants the ambient ctx AND returns (R, error): the ctx arg
# is injected before the subject, and the resulting tuple auto-unwraps through
# the existing per-context machinery — pins wantsCtx + hasErr together.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import (
	"context"
	"errors"
)

// Who appends "!" to s, taking the ambient ctx; fails on empty input.
func Who(ctx context.Context, s string) (string, error) {
	if s == "" {
		return "", errors.New("who: empty input")
	}
	return s + "!", nil
}
-- input.gsx --
package views

component Hi(name string) {
	<p>{ name |> who }</p>
}
-- invoke --
Hi(HiProps{Name: "ada"})
-- diagnostics.golden --
