# A plain tuple-returning call (no pipeline) as an ExprAttr value inside a
# component conditional-attr branch — the sub-case flagged during Task 2's
# review: condBranchAttrs' ExprAttr path only consulted resolved/hoisted for
# pipeline stages (via lowerPipe's wrap), never for a plain (T, error) call
# with no `|>` stages at all. It now checks resolved directly (mirroring
# childPropsLiteral's element-level ExprAttr handling) and hoists through the
# same thunk-local wrap as any other branch hoist.
-- helpers.go --
package views

func cls(v string) (string, error) { return "c-" + v, nil }
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node, attrs gsx.Attrs) { <div { attrs... }>{title}</div> }

component Page(hot bool, csv string) {
	<Card title="Hi" { if hot { data-x={ cls(csv) } } } />
}
-- invoke --
Page(true, "a,b")
-- diagnostics.golden --
