# A no-error-returning pipeline (`std.upper`, no fallible stage) as a composed
# class part inside a component conditional-attr branch. This did not depend
# on the tuple-hoist machinery (no stage in the pipeline can fail, so wrap is
# never invoked), but pins that a plain filter pipeline in this position keeps
# working identically to element-level class pipelines now that classEntryExpr
# gets the real thunk-local b/interpTemp/resolved instead of nils.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(title gsx.Node) { <div { attrs... }>{title}</div> }

component Page(hot bool, csv string) {
	<Card title="Hi" { if hot { class={ csv |> upper } } } />
}
-- invoke --
Page(PageProps{Hot: true, Csv: "ab"})
-- diagnostics.golden --
