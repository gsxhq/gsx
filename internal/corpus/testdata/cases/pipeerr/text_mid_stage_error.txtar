	return gsx.Func(func(ctx context.Context, _gsxw io.Writer) error {
		csv := _gsxp.Csv
		_gsxgw := gsx.W(_gsxw)
//line input.gsx:4:2
		_gsxgw.S("<p>")
//line input.gsx:4:5
		_gsxv0, _gsxerr := _gsxf0.Parse((csv))
		if _gsxerr != nil {
			return _gsxerr
		}
		_gsxgw.Text(string(_gsxstd.Join(_gsxv0, " ")))
		_gsxgw.S("</p>")
		return _gsxgw.Err()
	})
}
-- render.golden --
<p>
[render error] parse: empty input
