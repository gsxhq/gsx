# A (T, error) final-stage filter used as a CONDITIONAL class part on a plain
# element (class={ v |> upper: on }) — the renderer-less counterpart of
# renderers/elem_class_cond.txtar (#88): before the element-branch harvest
# widened to cover conditional plain parts, resolved[p] stayed nil for this
# part, so composedParts never detected the (string, error) tuple and emitted
# the filter's two-value call directly into ClassIf's single string argument
# — a broken skeleton. The harvest now populates resolved[p] regardless of
# Cond, so the tuple hoists exactly like the unconditional sibling in
# class_part_mid_stage.txtar.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import (
	"errors"
	"strings"
)

// Upper uppercases s; fails on empty input.
func Upper(s string) (string, error) {
	if s == "" {
		return "", errors.New("upper: empty input")
	}
	return strings.ToUpper(s), nil
}
-- input.gsx --
package views

component Tag(v string, on bool) {
	<div class={ v |> upper: on }>x</div>
}
-- invoke --
Tag(TagProps{V: "btn", On: true})
-- diagnostics.golden --
