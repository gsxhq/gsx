# Same JS-context attribute (onclick) shape as pipelines/attr_js_rejected.txtar,
# with a REAL error-returning filter swapped in. onclick has no special
# JS-context routing for a plain expr attr (only the explicit js`…` literal
# form does) — it lowers through the same emitPipeWrap-backed ExprAttr path as
# any other attribute, so the error stage hoists and renders cleanly, same as
# attr_mid_stage.txtar.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

// Shout upcases-ish by appending "!"; fails on empty input.
func Shout(s string) (string, error) {
	if s == "" {
		return "", errors.New("shout: empty input")
	}
	return s + "!", nil
}
-- input.gsx --
package views

component C(x string) { <div onclick={ x |> shout }>y</div> }
-- invoke --
C("ada")
-- diagnostics.golden --
