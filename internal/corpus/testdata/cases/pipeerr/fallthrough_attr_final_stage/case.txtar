# A FINAL-stage (R, error) filter used as a COMPONENT FALLTHROUGH attr — the one
# attr context that lacked final-stage unwrap. `hx-get` is undeclared on <Child>,
# so it lands in the caller-built Attrs bag; the pipeline's terminal (string,
# error) tuple must be hoisted (v, err := call; if err != nil { return err })
# BEFORE the bag literal, exactly like a declared prop or a direct element attr.
# (A MID-stage error already worked via emitPipeWrap; this pins the final stage.)
-- gsx.toml --
filterPackages = ["./filters"]
-- filters/filters.go --
package filters

import (
	"context"
	"errors"
)

// Url prefixes "/" and takes the ambient ctx; fails on empty input.
func Url(ctx context.Context, s string) (string, error) {
	if s == "" {
		return "", errors.New("url: empty input")
	}
	return "/" + s, nil
}
-- input.gsx --
package views

component Child(variant string) {
	<a class={ "a", variant } { attrs... }>{children}</a>
}

component Page(target string) {
	<Child variant="x" hx-get={ target |> url }>Go</Child>
}
-- invoke --
Page(PageProps{Target: "home"})
-- diagnostics.golden --
