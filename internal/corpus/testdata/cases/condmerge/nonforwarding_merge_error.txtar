# A tuple-returning composable style part inside a taken conditional fold
# propagates from the branch thunk with its required two-value return. The
# untaken invalid call is lazy; the later taken call proves error propagation.
-- input.gsx --
package views

import "errors"

func maybeDecl(ok bool) (string, error) {
	if !ok { return "", errors.New("decl failed") }
	return "margin:0", nil
}

component Box(on bool, ok bool) {
	<div style="color:red" { if on { style={ maybeDecl(ok) } } }>x</div>
}
-- invoke --
gsx.Fragment(
	Box(false, false),
	Box(true, false),
)
