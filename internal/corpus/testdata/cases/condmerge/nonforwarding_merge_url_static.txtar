# PINS A TRADE-OFF: once same-name class contributors make a no-spread element
# fold, ALL its attributes travel through the shared bag, and gw.Spread
# sanitizes URL-classified keys regardless of provenance (#79) — so an
# author-written literal javascript: href renders as about:invalid#gsx (x),
# while the identical literal on a non-folding element is trusted template
# text and emits verbatim (y). A codegen-time warning for a static URL-sink
# value the fold would rewrite is a tracked follow-up; this case pins the
# current divergence so any change to it is a conscious decision.
-- input.gsx --
package views

component Link(on bool) {
	<a href="javascript:void(0)" class="base" { if on { class="on" } }>x</a>
	<a href="javascript:void(0)" class="base">y</a>
}
-- invoke --
gsx.Fragment(
	Link(LinkProps{On: true}),
	Link(LinkProps{On: false}),
)
-- diagnostics.golden --
-- render.golden --
<a class="base on" href="about:invalid#gsx">x</a><a href="javascript:void(0)" class="base">y</a><a class="base" href="about:invalid#gsx">x</a><a href="javascript:void(0)" class="base">y</a>
