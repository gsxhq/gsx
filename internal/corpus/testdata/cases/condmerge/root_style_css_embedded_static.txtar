# O1 analog: a top-level style=css"…" (no hole) + a LONE cond-nested spread.
# hasRootClassStyle is Lang-agnostic (mirrors hasCondClassStyle), so the css-lang
# root style gates the lone-cond fold — without it the inline path emitted the
# root style as a SEPARATE attribute alongside the folded spread's, a silent
# duplicate. Folded, the no-hole literal forwards as static text into the shared
# bag and MERGES property-level.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Box(active bool, extra gsx.Attrs) {
	<div style=css"margin:0" { if active { { extra... } } }>x</div>
}
-- invoke --
Box(BoxProps{
	Active: true,
	Extra:  gsx.Attrs{{Key: "style", Value: "padding:1px"}},
})
-- diagnostics.golden --
-- render.golden --
<div style="margin:0; padding:1px">x</div>
