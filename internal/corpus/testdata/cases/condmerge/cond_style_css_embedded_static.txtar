# A css`…` embedded STYLE with NO hole inside a cond-attr branch on a forwarding
# element. hasCondClassStyle is Lang-agnostic, so this folds too (the old
# EmbeddedText-only gate missed it and the inline path emitted a duplicate style
# attribute). With no hole the literal is static text, so composeBag forwards it
# into the shared bag as a plain style value and it MERGES property-level with
# the root + spread styles — no duplicate, no fail-close.
-- input.gsx --
package views


import "github.com/gsxhq/gsx"
component Box(active bool, attrs gsx.Attrs) {
	<div style="color:red" { attrs... } { if active { style=css"margin:0" } }>x</div>
}
-- invoke --
gsx.Fragment(
	Box(true, gsx.Attrs{{Key: "style", Value: "padding:1px"}}),
)
-- diagnostics.golden --
-- render.golden --
<div style="color:red; padding:1px; margin:0">x</div>
