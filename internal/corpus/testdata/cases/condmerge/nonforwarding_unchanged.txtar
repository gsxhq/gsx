# NEGATIVE CONTROL: a cond-attr class with NO spread on the element (no
# forwarding at all) must NOT trigger elementFolds (first == nil in
# firstTwoSpreadAttrs) — it stays on the plain per-branch static emission path,
# not the fold/ConcatAttrs/AttrsCond machinery. Pins the generated shape so a
# future over-eager trigger extension is caught here. The if/else pair (z) is
# the mutually-exclusive shape: its branches can never co-contribute, so the
# contributor count max-combines them and the element stays inline too.
-- input.gsx --
package views

component Box(a bool) {
	<div { if a { class="on" } }>x</div>
	<div class="base" { if a { style="color:red" } }>y</div>
	<div { if a { class="on" } else { class="off" } }>z</div>
}
-- invoke --
gsx.Fragment(
	Box(BoxProps{A: true}),
	Box(BoxProps{A: false}),
)
-- diagnostics.golden --
-- render.golden --
<div class="on">x</div><div class="base" style="color:red">y</div><div class="on">z</div><div>x</div><div class="base">y</div><div class="off">z</div>
