# A registered error-returning renderer used by a conditional composable style
# part inherits the branch thunk's two-value error return. The invalid value in
# the untaken first render proves renderer laziness; the taken valid value pins
# successful rendering.
-- gsx.toml --
[renderers]
"./pg.Text" = "./rend.PgText"
-- pg/pg.go --
package pg

type Text struct { String string; Valid bool }
-- rend/rend.go --
package rend

import (
	"errors"
	"corpustest/cases/condmerge_nonforwarding_merge_renderer/pg"
)

func PgText(v pg.Text) (string, error) {
	if !v.Valid { return "", errors.New("invalid text") }
	return v.String, nil
}
-- input.gsx --
package views

import "corpustest/cases/condmerge_nonforwarding_merge_renderer/pg"

func text(s string, valid bool) pg.Text { return pg.Text{String: s, Valid: valid} }

component Box(on bool, value pg.Text) {
	<div style="color:red" { if on { style={ value } } }>x</div>
}
-- invoke --
gsx.Fragment(
	Box(BoxProps{On: false, Value: text("bad", false)}),
	Box(BoxProps{On: true, Value: text("margin:0", true)}),
)
-- diagnostics.golden --
