# An actual GSX pipeline in a conditional composable style contribution uses
# the branch thunk's error return. Untaken empty input is lazy, valid input
# succeeds, and the final taken empty input propagates the filter error.
-- gsx.toml --
filter_packages = ["./filters"]
-- filters/filters.go --
package filters

import "errors"

func Decl(s string) (string, error) {
	if s == "" { return "", errors.New("decl: empty input") }
	return "margin:" + s, nil
}
-- input.gsx --
package views

component Box(on bool, gap string) {
	<div style="color:red" { if on { style={ gap |> decl } } }>x</div>
}
-- invoke --
gsx.Fragment(
	Box(false, ""),
	Box(true, "5px"),
	Box(true, ""),
)
-- diagnostics.golden --
