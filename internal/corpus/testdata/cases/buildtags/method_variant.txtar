-- field.gsx --
//go:build !never

package views

type Form struct{}

component (f Form) Field(name string) {
	<span class="active">{ name }</span>
}
-- field_never.gsx --
//go:build never

package views

component (f Form) Field(name string) {
	<span class="never">{ name }</span>
}
-- invoke --
(Form{}).Field("x")
