# A spread onto an element sanitizes URL keys regardless of provenance (issue
# #75): a byo struct's second gsx.Attrs field (not named Attrs) spread onto <a>
# routes through the leaf URL sink, so a javascript: href becomes about:invalid#gsx.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

type props struct {
	Extra gsx.Attrs
}

component Link(p props) {
	<a { p.Extra... }>click</a>
}
-- invoke --
Link(props{Extra: gsx.Attrs{{Key: "href", Value: "javascript:alert(1)"}}})
-- diagnostics.golden --
-- render.golden --
<a href="about:invalid#gsx">click</a>
