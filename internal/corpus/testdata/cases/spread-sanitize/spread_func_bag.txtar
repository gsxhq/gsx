# A spread onto an element sanitizes URL keys regardless of provenance (issue
# #75): a bag returned from a function spread onto <a> routes through the leaf
# URL sink, so a javascript: href becomes about:invalid#gsx.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

func mkBag(h string) gsx.Attrs { return gsx.Attrs{{Key: "href", Value: h}} }

component Link(userHref string) {
	<a { mkBag(userHref)... }>click</a>
}
-- invoke --
Link("javascript:alert(1)")
-- diagnostics.golden --
-- render.golden --
<a href="about:invalid#gsx">click</a>
