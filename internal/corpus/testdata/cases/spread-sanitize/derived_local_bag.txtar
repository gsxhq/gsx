# A derived local bag hoists once and sanitizes (issue #75): `{ b.Without("id")... }`
# evaluates b.Without("id") into a single temp (`_gsxv0 := b.Without("id")`) that
# feeds the caller-wins guards + leaf URL sink, so a javascript: href becomes
# about:invalid#gsx and the "id" entry is dropped.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Link(userHref string) {
	{{ b := gsx.Attrs{{Key: "id", Value: "drop"}, {Key: "href", Value: userHref}} }}
	<a { b.Without("id")... }>click</a>
}
-- invoke --
Link("javascript:alert(1)")
