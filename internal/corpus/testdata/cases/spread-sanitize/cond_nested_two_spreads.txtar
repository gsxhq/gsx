# Two spreads on one element, each nested in a separate cond-attr, fold by
# source order (the count descends into cond branches). With both conditions
# true, { if c { x } } precedes { if d { y } }, so y wins a colliding key.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Bad(c bool, d bool, x gsx.Attrs, y gsx.Attrs) {
	<a { if c { { x... } } } { if d { { y... } } }>hi</a>
}
-- invoke --
Bad(true, true, gsx.Attrs{{Key: "data-n", Value: "x"}}, gsx.Attrs{{Key: "data-n", Value: "y"}})
-- diagnostics.golden --
-- render.golden --
<a data-n="y">hi</a>
