# A spread NESTED in a conditional attr is a leaf URL sink too (issue #75): a
# `{ if on { { extra... } } }` spread routes through Spread, so a
# javascript: href sanitizes to about:invalid#gsx when the branch is taken, and
# the not-taken branch (`!on`) emits nothing.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component CondSpread(on bool, extra gsx.Attrs) {
	<div>
		<a { if on { { extra... } } }>on</a>
		<a { if !on { { extra... } } }>off</a>
	</div>
}
-- invoke --
CondSpread(CondSpreadProps{On: true, Extra: gsx.Attrs{{Key: "href", Value: "javascript:alert(1)"}}})
-- diagnostics.golden --
