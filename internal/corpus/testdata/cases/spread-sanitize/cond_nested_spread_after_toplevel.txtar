# Top-level forwarding spread first, then a cond-nested spread: they fold by
# source order (the count descends into cond branches). Mirror of
# cond_attr_nested_spread_rejected — here { attrs... } precedes { if active {
# extra } }, so with active=true the conditional extra wins the collision.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Box(active bool, extra gsx.Attrs) {
	<div { attrs... } { if active { { extra... } } }>x</div>
}
-- invoke --
Box(BoxProps{
	Active: true,
	Extra:  gsx.Attrs{{Key: "data-k", Value: "e"}},
	Attrs:  gsx.Attrs{{Key: "data-k", Value: "a"}},
})
-- diagnostics.golden --
-- render.golden --
<div data-k="e">x</div>
