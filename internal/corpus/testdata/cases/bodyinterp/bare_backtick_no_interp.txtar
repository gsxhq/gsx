# The "one rule": interpolation is opt-in behind an f`/js`/css` prefix. A bare
# (unprefixed) backtick is a plain Go raw string in BOTH attribute-value and
# body positions — a `@{ }` inside is ordinary literal text, never a hole. So
# the attr value is emitted as the Go raw string `plain @{x} text` (an ExprAttr)
# and the body literal as the Go raw string `body @{y}` (a plain *ast.Interp),
# each rendered verbatim (HTML-escaped) with no per-hole processing.
-- input.gsx --
package p

component C() {
	<div data-x=`plain @{x} text`>{`body @{y}`}</div>
}
-- invoke --
C()
-- diagnostics.golden --
-- render.golden --
<div data-x="plain @{x} text">body @{y}</div>
