# DISAMBIGUATION: a body backtick literal only interpolates when it is the LONE
# child of the braces. `{`a` + x}` has a trailing `+ x`, so the backtick is an
# ordinary Go raw string and the whole brace is one Go expression — rendered as
# a single Text(), NOT split into per-segment holes.
-- input.gsx --
package p

component Row(x string) {
	<p>{`a` + x}</p>
}
-- invoke --
Row(RowProps{X: "<b>"})
-- diagnostics.golden --
-- render.golden --
<p>a&lt;b&gt;</p>
