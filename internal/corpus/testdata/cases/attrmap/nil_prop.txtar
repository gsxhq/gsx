# A bare `nil` bound to an Attrs bag prop binds directly (nil assigns fine to a
# slice gsx.Attrs). It is exempt from BOTH the emit-time AttrsFromMap wrap
# (isStringAnyMap(nil) is false) AND the skeleton _gsxbag wrap (Go cannot infer
# the generic T from untyped nil, which would also leak the helper name). No
# _gsxbag / _gsxshared text appears anywhere in the output.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(bag gsx.Attrs) {
	<div { bag... }>x</div>
}

component Page() {
	<Card bag={nil}/>
}
-- invoke --
Page()
