# Props declared as gsx.Attrs accept only gsx.Attrs. A map[string]string is
# rejected by ordinary Go type checking and is not implicitly converted.
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(bag gsx.Attrs) {
	<div { bag... }>x</div>
}

component Page() {
	<Card bag={map[string]string{"id": "x"}}/>
}
-- invoke --
Page()
