-- input.gsx --
package views

type User struct {
	Email string
}

type RowProps struct {
	User User
}

type UsersPage struct {
	Users []User
}

component (p UsersPage) Page() {
	<ul>{ for _, u := range p.Users { <p.Row user={u}/> } }</ul>
}

component (p UsersPage) Row(rp RowProps) {
	<li>{rp.User.Email}</li>
}
-- invoke --
(UsersPage{Users: []User{{Email: "x@y"}}}).Page()
-- diagnostics.golden --
-- render.golden --
<ul><li>x@y</li></ul>
