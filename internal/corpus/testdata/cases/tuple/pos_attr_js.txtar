# (T, error) auto-unwrap in a plain expression attribute value: onclick={ f() } where f
# returns (string, error). The codegen hoists and feeds the value to JSValAttr.
-- input.gsx --
package views

func handler(action string) (string, error) { return "doThing('" + action + "')", nil }

component Button(action string) {
	<button onclick={ handler(action) }>click</button>
}
-- invoke --
Button("save")
-- diagnostics.golden --
-- render.golden --
<button onclick="doThing(&#39;save&#39;)">click</button>
