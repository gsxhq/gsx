# (T, error) auto-unwrap: the emit hoist-all-when-any pass WITH a non-call value
# present. A (string, error) tuple sibling forces hoisting, but the untyped
# literal `100` (→ float64 field) must stay INLINE in the literal (`Value: 100`)
# while only the tuple call hoists (`Title: _gsxv0`). Hoisting the literal as
# `_gsxv := 100` would fix it to int and fail the .x.go build.
-- input.gsx --
package views

func lookup(key string) (string, error) { return "title-" + key, nil }

component Card(value float64, title string) { <div>{title} {value}</div> }

component Page(t string) { <Card value={100} title={lookup(t)}/> }
-- invoke --
Page("x")
