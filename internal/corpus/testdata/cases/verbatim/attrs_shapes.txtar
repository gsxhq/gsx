# A NON-reserved ordinary bag-valued prop (`inputAttrs gsx.Attrs`) is filled by
# exact name and may be spread onto SEVERAL chosen inner elements (design
# §Reserved-input population, the inputAttrs rows). It is distinct from the
# reserved `attrs` fallthrough role. Field is invoked twice: once with a literal
# inputAttrs={{ ... }} (an ordinary gsx.Attrs-valued attribute), once with a
# computed inputAttrs={computedBag()} expression. Both descendants receive the
# bag.
#
# Expected render:
#   <label><input id="x"/><span id="x"></span></label>
#   <label><input data-k="v"/><span data-k="v"></span></label>
#   <main id="shell" class="wide"></main>
#   <main data-k="v" id="conditional"></main>
#   <aside id="defined"></aside>
#   <nav id="variadic"></nav>
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Field(inputAttrs gsx.Attrs) {
	<label><input {inputAttrs...}/><span {inputAttrs...}></span></label>
}

component Shell(attrs gsx.Attrs) {
	<main {attrs...}></main>
}

type LocalAttrs []gsx.Attr

component Defined(attrs LocalAttrs) {
	<aside {gsx.Attrs(attrs)...}></aside>
}

component Variadic(attrs ...gsx.Attr) {
	<nav {gsx.Attrs(attrs)...}></nav>
}

func computedBag() gsx.Attrs {
	return gsx.Attrs{{Key: "data-k", Value: "v"}}
}

component Page() {
	<Field inputAttrs={{ "id": "x" }}/>
	<Field inputAttrs={computedBag()}/>
	<Shell attrs={{ "id": "shell" }} class="wide"/>
	<Shell { if true { attrs={computedBag()} } } id="conditional"/>
	<Defined id="defined"/>
	<Variadic id="variadic"/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<label><input id="x"/><span id="x"></span></label><label><input data-k="v"/><span data-k="v"></span></label><main class="wide" id="shell"></main><main data-k="v" id="conditional"></main><aside id="defined"></aside><nav id="variadic"></nav>
