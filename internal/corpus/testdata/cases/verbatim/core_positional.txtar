# Verbatim ABI positional-call implementation checkpoint (design §Evaluation
# order): authored attribute order differs from signature/param order, an untyped
# `min(1, 2)` constant is bound to a DEFINED numeric parameter and an untyped
# rune is bound directly to a defined rune parameter (contextual typing, never
# materialized to a typed temp), and a `(string, error)` prop is auto-unwrapped
# before positional assembly. Once-only lexical evaluation is proven by the
# side-effecting tick(): the authored-first `second={tick()}` runs first (seq→1),
# the authored-third `first={tick()}` runs next (seq→2), and the call is assembled
# as Row(Level(1), "2", "1").
#
# Braced embedded literals are ordinary exact-name operands too: js produces
# gsx.RawJS and f produces string at the component boundary.
#
# Expected render: <div data-level="1"><i>2</i><b>1</b></div><script>alert(1)</script><p>go</p><span>x</span>
-- input.gsx --
package views

import (
	"strconv"

	"github.com/gsxhq/gsx"
)

type Level int
type Letter rune

var seq int

func tick() (string, error) {
	seq++
	return strconv.Itoa(seq), nil
}

component Row(level Level, first string, second string) {
	<div data-level={level}><i>{first}</i><b>{second}</b></div>
}

component Action(script gsx.RawJS, label string) {
	<script>@{script}</script><p>{label}</p>
}

component RuneTarget(letter Letter) {
	<span>{string(letter)}</span>
}

component Page() {
	<Row second={tick()} level={min(1, 2)} first={tick()} />
	<Action script={js`alert(1)`} label={f`go`}/>
	<RuneTarget letter={'x'}/>
}
-- invoke --
Page()
-- diagnostics.golden --
-- render.golden --
<div data-level="1"><i>2</i><b>1</b></div><script>alert(1)</script><p>go</p><span>x</span>
