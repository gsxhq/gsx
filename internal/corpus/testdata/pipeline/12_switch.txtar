gsx pipeline: { switch … } with case and default arms.

-- input.gsx --
package examples

component Badge(kind string) {
	<span>
		{ switch kind {
		case "warn":
			<b>warn</b>
		default:
			<b>info</b>
		} }
	</span>
}

