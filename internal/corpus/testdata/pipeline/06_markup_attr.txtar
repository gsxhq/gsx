# markup-valued attribute (MarkupAttr); Panel component accepts header as gsx.Node type
-- input.gsx --
package p

component Panel(header interface{}) { <div>{header}</div> }

component Demo() { <Panel header={<h1>Hi</h1>}></Panel> }
