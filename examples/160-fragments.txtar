-- doc --
name: Fragments
summary: A component can return multiple roots with no wrapper element using <>…</>.
category: Interactive & whole-page
order: 160
page: fragments
pageOrder: 10
-- input.gsx --
package views

component Pair(a string, b string) {
	<><span>{a}</span><span>{b}</span></>
}
-- invoke --
Pair("x", "y")
-- render.golden --
<span>x</span><span>y</span>
