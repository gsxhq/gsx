-- doc --
name: Interpolating attribute literals
summary: A backtick attribute literal mixes static text with typed, auto-escaped `@{ }` holes, including per-hole pipelines.
category: Basics
page: attributes
pageOrder: 70
-- input.gsx --
package views

component Row(id string, n int) {
	<div data-key=`row-@{id}-@{n}` title=`Item @{ id |> upper }`>Row</div>
}
-- invoke --
Row(RowProps{Id: "a&b", N: 5})
-- render.golden --
<div data-key="row-a&amp;b-5" title="Item A&amp;B">Row</div>
