-- doc --
name: Style blocks
summary: A <style> block interpolates values with @{ … }; interpolated values are CSS-sanitized.
category: Styling
order: 140
page: styling
pageOrder: 40
-- input.gsx --
package views

component Card(w int, userColor string) {
	<style>
		.card {
			width: @{ w }px;
			color: @{ userColor };
		}
	</style>
}
-- invoke --
Card(CardProps{W: 12, UserColor: "teal"})
-- render.golden --
<style>.card{width: 12px;color: teal}</style>
