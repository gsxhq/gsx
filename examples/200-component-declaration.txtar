-- doc --
name: Component declaration
summary: A component declaration: typed params + a markup body, no `return`.
category: Basics
page: basic-syntax
pageOrder: 10
-- input.gsx --
package views

component Greeting(name string, count int) {
	<p>Hello, {name}! You have {count} messages.</p>
}
-- invoke --
Greeting(GreetingProps{Name: "World", Count: 3})
-- render.golden --
<p>Hello, World! You have 3 messages.</p>
