-- doc --
name: Attribute-local JS handler
summary: Use js`…` for JavaScript-valued attributes; @{ … } holes inside the literal are escaped for their JavaScript position.
category: JavaScript
order: 271
page: javascript
pageOrder: 30
-- input.gsx --
package views

component Menu() {
	<button @click=js`openMenu()`>Open</button>
}
-- invoke --
Menu()
-- render.golden --
<button @click="openMenu()">Open</button>
