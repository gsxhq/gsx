-- doc --
name: RawJS event handler
summary: gsx.RawJS vouches for trusted JS in event-handler attributes; values without RawJS are JSON-encoded, not executed as code.
category: JavaScript
order: 271
page: javascript
pageOrder: 30
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Menu() {
	<button @click={ gsx.RawJS("openMenu()") }>Open</button>
}
-- invoke --
Menu()
-- render.golden --
<button @click="openMenu()">Open</button>
