-- doc --
name: Field access
summary: Struct fields and typed values interpolate directly with `{ p.Field }`.
category: Basics
page: interpolation
pageOrder: 20
-- model.go --
package views

type User struct {
	Name string
	Age  int
}
-- input.gsx --
package views

component Profile(user User) {
	<p>{user.Name} is {user.Age}</p>
}
-- invoke --
Profile(User{Name: "Alice", Age: 30})
-- render.golden --
<p>Alice is 30</p>
