-- doc --
name: Spread Attributes
summary: "{ bag... }" spreads a gsx.Attrs bag onto an element; keys render in source order.
category: Basics
page: attributes
pageOrder: 40
-- input.gsx --
package views

import "github.com/gsxhq/gsx"

component Card(extra gsx.Attrs) {
	<div { extra... }>content</div>
}
-- invoke --
Card(gsx.Attrs{{Key: "id", Value: "box"}, {Key: "data-active", Value: "true"}})
-- render.golden --
<div id="box" data-active="true">content</div>
