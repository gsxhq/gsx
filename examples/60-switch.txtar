-- doc --
name: Switch
summary: { switch … } selects one branch of markup; default handles the rest.
category: Control flow
order: 60
page: control-flow
pageOrder: 30
-- input.gsx --
package views

component Badge(kind string) {
	<span>{ switch kind {
	case "warn":
		<b>warning</b>
	case "err":
		<b>error</b>
	default:
		<b>info</b>
	} }</span>
}
-- invoke --
Badge("warn")
-- render.golden --
<span><b>warning</b></span>
