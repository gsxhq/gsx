-- doc --
name: Filter arguments
summary: Filters can take extra arguments in parentheses — { count |> format("%d comments") } or { s |> trim |> truncate(5) }.
category: Transforming values
page: pipelines
pageOrder: 20
-- input.gsx --
package views

component Stats(s string, count int) {
	<p>{ s |> trim |> truncate(5) }</p>
	<p>{ count |> format("%d comments") }</p>
}
-- invoke --
Stats(StatsProps{S: "  hello world  ", Count: 42})
-- render.golden --
<p>hello</p><p>42 comments</p>
