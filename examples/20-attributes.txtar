-- doc --
name: Expression Attributes
summary: Expression attributes (attr={expr}) bind Go values to HTML attributes; the value is auto-escaped for its context.
category: Basics
order: 20
page: attributes
pageOrder: 10
-- input.gsx --
package views

component Link(url string, label string, count int) {
	<a href={url} data-count={count}>{ label }</a>
}
-- invoke --
Link("/p?q=a&b", "Docs", 42)
-- render.golden --
<a href="/p?q=a&amp;b" data-count="42">Docs</a>
